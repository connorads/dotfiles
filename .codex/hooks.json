{
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "sh \"$HOME/.config/tmux/scripts/agent-state.sh\" clear codex || true", "timeout": 10 } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "sh \"$HOME/.config/tmux/scripts/agent-state.sh\" working codex || true", "timeout": 10 } ] }
    ],
    "PreToolUse": [
      { "hooks": [ { "type": "command", "command": "sh \"$HOME/.config/tmux/scripts/agent-state.sh\" working codex || true", "timeout": 10 } ] },
      { "matcher": "^Bash$", "hooks": [ { "type": "command", "command": "python3 \"$HOME/.claude/hooks/guard-secret-paths-codex.py\"" } ] },
      { "matcher": "^Bash$", "hooks": [ { "type": "command", "command": "atuin hook codex" } ] }
    ],
    "PostToolUse": [
      { "hooks": [ { "type": "command", "command": "sh \"$HOME/.config/tmux/scripts/agent-state.sh\" working codex || true", "timeout": 10 } ] },
      { "matcher": "^Bash$", "hooks": [ { "type": "command", "command": "atuin hook codex" } ] }
    ],
    "PostToolUseFailure": [
      { "matcher": "^Bash$", "hooks": [ { "type": "command", "command": "atuin hook codex" } ] }
    ],
    "PermissionRequest": [
      { "hooks": [ { "type": "command", "command": "sh \"$HOME/.config/tmux/scripts/agent-state.sh\" blocked codex || true", "timeout": 10 } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "sh \"$HOME/.config/tmux/scripts/agent-state.sh\" done codex || true", "timeout": 10 } ] }
    ]
  }
}

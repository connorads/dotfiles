prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Use `trash` outside temporary directories; leave temporary paths for system cleanup.",
    match = [
        "rm -rf build",
        "rm -rf /tmp/agent-work",
    ],
    not_match = [
        "rm -f file.txt",
        "rm -r directory",
    ],
)

prefix_rule(
    pattern = ["git", "add", ["-A", "--all", "."]],
    decision = "forbidden",
    justification = "Sweeping stages pick up unintended changes (AGENTS.md); stage explicit paths, or `git hunks` for partial files.",
    match = [
        "git add -A",
        "git add --all",
        "git add .",
    ],
    not_match = [
        "git add file.txt",
        "git add src/",
    ],
)

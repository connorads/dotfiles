+/* Get number of status lines reserved at the top of the terminal. */
+u_int
+status_top_lines(struct client *c)
+{
+	struct session	*s = c->session;
+
+	if (status_split_top_bottom(c))
+		return (1);
+	if (status_line_size(c) == 0 || s == NULL || s->statusat != 0)
+		return (0);
+	return (status_line_size(c));
+}
+
+/* Get number of status lines reserved at the bottom of the terminal. */
+u_int
+status_bottom_lines(struct client *c)
+{
+	struct session	*s = c->session;
+
+	if (status_split_top_bottom(c))
+		return (1);
+	if (status_line_size(c) == 0 || s == NULL || s->statusat == 0)
+		return (0);
+	return (status_line_size(c));
+}
+
+/* Get terminal y coordinate for a logical status line. -1 means offscreen. */
+int
+status_line_y(struct client *c, u_int line)
+{
+	u_int	lines = status_line_size(c);
+
+	if (lines == 0 || line >= lines || c->tty.sy == 0)
+		return (-1);
+	if (status_split_top_bottom(c)) {
+		if (line == 0)
+			return (0);
+		if (line == 1 && c->tty.sy > 0)
+			return (c->tty.sy - 1);
+		return (-1);
+	}
+	if (status_at_line(c) == 0)
+		return (line);
+	return (c->tty.sy - lines + line);
+}
+
+/* Map terminal y coordinate to a logical status line. */
+int
+status_line_at_y(struct client *c, u_int y, u_int *line)
+{
+	int	statusat;
+	u_int	lines;
+
+	lines = status_line_size(c);
+	if (lines == 0)
+		return (0);
+	if (status_split_top_bottom(c)) {
+		if (y == 0) {
+			*line = 0;
+			return (1);
+		}
+		if (y == c->tty.sy - 1) {
+			*line = 1;
+			return (1);
+		}
+		return (0);
+	}
+
+	statusat = status_at_line(c);
+	if (statusat == -1)
+		return (0);
+	if (y >= (u_int)statusat && y < (u_int)statusat + lines) {
+		*line = y - statusat;
+		return (1);
+	}
+	return (0);
+}
+
+/* Get screen line of status line. -1 means off. */
+int
+status_at_line(struct client *c)
+{
+	struct session	*s = c->session;
+
+	if (c->flags & (CLIENT_STATUSOFF|CLIENT_CONTROL))
+		return (-1);
+	if (status_split_top_bottom(c))
+		return (0);
+	if (s->statusat != 1)
+		return (s->statusat);
+	return (c->tty.sy - status_line_size(c));
 }
 

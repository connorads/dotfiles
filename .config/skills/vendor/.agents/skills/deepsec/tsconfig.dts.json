{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": {
      "@deepsec/core": ["../core/dist/index.d.ts"],
      "@deepsec/scanner": ["../scanner/dist/index.d.ts"]
    }
  },
  "include": ["src/config.ts"]
}

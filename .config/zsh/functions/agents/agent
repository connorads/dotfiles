#!/usr/bin/env zsh
# agent: orchestrate coding-agent panes over @agent_state (ls/state/wait/prompt/name/pick)
# usage: agent <ls|state|wait|prompt|name|unname|pick> [args]
emulate -L zsh
setopt local_options pipe_fail

# Path seams (agent-popup.sh's env-var style) so bats can inject.
local _agent_scripts=${AGENT_SCRIPTS_DIR:-$HOME/.config/tmux/scripts}
local _agent_cli_lib=${AGENT_CLI_LIB:-$_agent_scripts/agent-cli-lib.sh}
local _agent_state_sh=${AGENT_STATE_SH:-$_agent_scripts/agent-state.sh}
local _agent_sweep=${AGENT_SWEEP:-$_agent_scripts/agent-sweep.sh}
local AGENT_STATE_LIB=${AGENT_STATE_LIB:-$_agent_scripts/agent-state-lib.sh}

[[ -r $_agent_cli_lib ]] || {
  print -u2 "agent: lib not found: $_agent_cli_lib"
  return 1
}
# shellcheck disable=SC1090
source "$_agent_cli_lib"

_agent_usage() {
  cat <<'EOF'
usage: agent <subcommand> [args]

  ls [--json]       list live agent panes (pane/state/kind/name/loc/window/cwd),
                    ranked blocked > done > working > idle
  state <target>    print a pane's @agent_state (bare word; empty if untracked)
  wait <target> [--for state[,state]] [--timeout secs]
                    block until @agent_state reaches a wanted state
                    (default --for done,idle,blocked; timeout 120s)
  prompt <target> <text...> [--force]
                    paste a prompt + submit, then verify the agent starts;
                    refuses blocked/working panes unless --force
  name [<target>] <name>
                    label a pane (default: this pane); unique among live
                    agents, grammar [a-z][a-z0-9_-]{0,31}
  unname [<target>] remove a pane's label (default: this pane)
  pick              fzf picker over live agents; Enter jumps to the pane

<target> = %pane_id | session:win.pane | agent name (@agent_name exact match)

exit codes: 0 ok · 1 wait timeout · 2 usage · 3 target unresolvable/pane gone
            · 4 prompt refused · 5 prompt stall (sent but agent never started)
EOF
}

# agent ls [--json] — the enumerator, human (column) or machine (JSON) shaped.
_agent_ls() {
  local json=0
  while (( $# )); do
    case $1 in
      --json) json=1; shift ;;
      -h|--help) _agent_usage; return 0 ;;
      *) print -u2 "agent ls: unknown argument: $1"; return 2 ;;
    esac
  done

  local rows
  rows=$(agent_list_rows | agent_rank_sort)
  if (( json )); then
    printf '%s\n' "$rows" | jq -R -s '
      split("\n") | map(select(length > 0)) | map(split("\t"))
      | map({
          pane: .[0],
          state: .[1],
          kind: (if .[2] == "" then null else .[2] end),
          name: (if .[3] == "" then null else .[3] end),
          loc: .[4],
          window: .[5],
          cwd: .[6]
        })'
  else
    [[ -n $rows ]] || return 0
    # Empty fields become "-" so BSD column (which merges consecutive
    # delimiters) cannot shift later columns.
    printf '%s\n' "$rows" | awk -F '\t' 'BEGIN { OFS = "\t" }
      { for (i = 1; i <= NF; i++) if ($i == "") $i = "-"; print }' |
      column -t -s '	'
  fi
}

# agent state <target> — cheapest read primitive; no polling.
_agent_state() {
  (( $# == 1 )) || {
    print -u2 "usage: agent state <target>"
    return 2
  }
  local pane
  pane=$(agent_resolve_target "$1") || return $?
  agent_pane_state "$pane"
}

# agent wait — block until the pane's @agent_state reaches a wanted state.
# Polls the option (the documented pattern: done/idle both mean turn-complete);
# the journal was rejected as the mechanism - it is fail-open and transition-
# only, so a waiter starting after the transition would hang. Liveness-checks
# the resolved pane each loop so a killed pane exits 3, not 1.
_agent_wait() {
  local forset="done,idle,blocked" timeout=120 target=
  while (( $# )); do
    case $1 in
      --for)
        [[ -n ${2:-} ]] || {
          print -u2 "agent wait: --for needs a value"
          return 2
        }
        forset=$2
        shift 2
        ;;
      --timeout)
        [[ ${2:-} == <-> ]] || {
          print -u2 "agent wait: --timeout needs a number of seconds"
          return 2
        }
        timeout=$2
        shift 2
        ;;
      -h|--help) _agent_usage; return 0 ;;
      -*) print -u2 "agent wait: unknown flag: $1"; return 2 ;;
      *)
        [[ -z $target ]] || {
          print -u2 "agent wait: too many targets"
          return 2
        }
        target=$1
        shift
        ;;
    esac
  done
  [[ -n $target ]] || {
    print -u2 "usage: agent wait <target> [--for state[,state]] [--timeout secs]"
    return 2
  }

  local tok
  for tok in ${(s:,:)forset}; do
    case $tok in
      blocked|done|working|idle) ;;
      *)
        print -u2 "agent wait: invalid state '$tok' (blocked|done|working|idle)"
        return 2
        ;;
    esac
  done

  local pane
  pane=$(agent_resolve_target "$target") || return $?

  local poll=${AGENT_WAIT_POLL:-2} s
  local deadline=$(( SECONDS + timeout ))
  while :; do
    # Liveness: check the output, not the exit status - display-message on a
    # dead pane id prints empty and still exits 0.
    [[ -n $(tmux display-message -p -t "$pane" '#{pane_id}' 2>/dev/null) ]] || {
      print -u2 "agent wait: pane gone: $pane"
      return 3
    }
    s=$(agent_pane_state "$pane")
    if agent_state_matches "$s" "$forset"; then
      return 0
    fi
    (( SECONDS >= deadline )) && {
      print -u2 "agent wait: timeout after ${timeout}s (state: ${s:-none})"
      return 1
    }
    sleep "$poll"
  done
}

# _agent_prompt_verify SNAPSHOT PANE — poll @agent_state for any transition
# away from SNAPSHOT (working, blocked, or a fresh done: a fast no-tool turn
# can pass through working between polls). Empty reads never count - a cleared
# state means the agent died, not that the prompt landed.
_agent_prompt_verify() {
  local snapshot=$1 pane=$2 s
  local vpoll=${AGENT_PROMPT_VERIFY_POLL:-0.3}
  local -i iters=$(( ${AGENT_PROMPT_VERIFY_TIMEOUT:-5} / vpoll ))
  (( iters >= 1 )) || iters=1
  local -i i
  for (( i = 0; i < iters; i++ )); do
    s=$(agent_pane_state "$pane")
    [[ -n $s && $s != "$snapshot" ]] && return 0
    sleep "$vpoll"
  done
  return 1
}

# agent prompt — the only mutating verb: paste the prompt into the pane and
# submit it, never touching @agent_state (it only sends keystrokes and observes
# the option the agent's own hooks set).
_agent_prompt() {
  local force=0 target=
  local -a words
  while (( $# )); do
    case $1 in
      --force) force=1; shift ;;
      -h|--help) _agent_usage; return 0 ;;
      -*) print -u2 "agent prompt: unknown flag: $1"; return 2 ;;
      *)
        if [[ -z $target ]]; then
          target=$1
        else
          words+=("$1")
        fi
        shift
        ;;
    esac
  done
  [[ -n $target && ${#words} -gt 0 ]] || {
    print -u2 "usage: agent prompt <target> <text...> [--force]"
    return 2
  }
  local text="${(j: :)words}"

  local pane
  pane=$(agent_resolve_target "$target") || return $?

  local snapshot kind gate
  snapshot=$(agent_pane_state "$pane")
  kind=$(agent_pane_kind "$pane")
  gate=$(agent_prompt_gate "$snapshot" "$force")
  case $gate in
    refuse-blocked)
      print -u2 "agent prompt: $pane is blocked (a human approval surface); use --force to override"
      return 4
      ;;
    refuse-working)
      print -u2 "agent prompt: $pane is working; compose with \`agent wait $target && agent prompt ...\` or use --force"
      return 4
      ;;
  esac

  # Send: buffer-paste the body atomically (bracketed-paste-safe, multi-line
  # arrives as one paste), settle, then submit with a *separate* keystroke -
  # pasting text and Enter together races bracketed paste and the TUI can
  # swallow the submit.
  printf '%s' "$text" | tmux load-buffer -b agent-input - || {
    print -u2 "agent prompt: load-buffer failed"
    return 3
  }
  tmux paste-buffer -d -p -b agent-input -t "$pane" || {
    print -u2 "agent prompt: paste-buffer failed (pane gone?)"
    return 3
  }
  sleep "${AGENT_PROMPT_SETTLE:-0.4}"
  local key
  key=$(agent_submit_key "$kind")
  tmux send-keys -t "$pane" "$key"

  # Stall verify - only for kinds whose hooks verifiably set @agent_state on
  # prompt submit (claude and codex fire `working` synchronously); other kinds
  # send-and-return.
  local verify_kinds=${AGENT_PROMPT_VERIFY_KINDS:-claude codex}
  [[ " $verify_kinds " == *" $kind "* ]] || return 0

  _agent_prompt_verify "$snapshot" "$pane" && return 0
  # The text may have landed unsubmitted (the Enter-swallow race): retry the
  # submit key once, then give up.
  tmux send-keys -t "$pane" "$key"
  _agent_prompt_verify "$snapshot" "$pane" && return 0
  print -u2 "agent prompt: sent but $pane never left '${snapshot:-none}' (stall)"
  return 5
}

# _agent_pane_or_self [TARGET] — resolve TARGET, or default to this pane.
_agent_pane_or_self() {
  if [[ -n ${1:-} ]]; then
    agent_resolve_target "$1"
  elif [[ -n ${TMUX_PANE:-} ]]; then
    printf '%s\n' "$TMUX_PANE"
  else
    print -u2 "agent: not inside tmux; pass a target pane"
    return 3
  fi
}

# agent name — thin wrapper over agent-state.sh's name verb (the canonical
# @agent_* mutator, which owns the grammar + has-state checks) plus the
# cross-pane live-uniqueness check the mutator cannot do alone: sweep first so
# a dead pane's name is freed, then reject a collision with a survivor.
# Check-then-set spans two tmux calls (tmux has no compare-and-set), so two
# concurrent `agent name` calls can race - accepted single-user limitation.
_agent_name() {
  local target= name=
  case $# in
    1) name=$1 ;;
    2) target=$1 name=$2 ;;
    *)
      print -u2 "usage: agent name [<target>] <name>"
      return 2
      ;;
  esac
  local pane
  pane=$(_agent_pane_or_self "$target") || return $?
  valid_agent_name "$name" || {
    print -u2 "agent name: invalid name '$name' (grammar: [a-z][a-z0-9_-]{0,31})"
    return 2
  }
  [[ -r $_agent_sweep ]] && sh "$_agent_sweep" >/dev/null 2>&1
  if agent_name_taken "$name" "$pane"; then
    print -u2 "agent name: '$name' is already held by a live agent"
    return 2
  fi
  AGENT_STATE_PANE=$pane sh "$_agent_state_sh" name "$name"
}

# agent unname — drop the label; no validation or uniqueness needed.
_agent_unname() {
  (( $# <= 1 )) || {
    print -u2 "usage: agent unname [<target>]"
    return 2
  }
  local pane
  pane=$(_agent_pane_or_self "${1:-}") || return $?
  AGENT_STATE_PANE=$pane sh "$_agent_state_sh" unname
}

# agent pick — the shell-callable "wts for agents": delegate to the popup
# script's pick (sweep + shared enumerator + fzf + jump) on this TTY. The
# prefix + A binding keeps its display-popup; running from a shell needs none.
_agent_pick() {
  command -v fzf >/dev/null 2>&1 || {
    print -u2 "agent pick: fzf required"
    return 1
  }
  local popup=${AGENT_POPUP:-$_agent_scripts/agent-popup.sh}
  [[ -r $popup ]] || {
    print -u2 "agent pick: script not found: $popup"
    return 1
  }
  sh "$popup" pick
}

local _agent_sub=${1:-}
(( $# )) && shift
case ${_agent_sub:-ls} in
  ls|list) _agent_ls "$@" ;;
  state) _agent_state "$@" ;;
  wait) _agent_wait "$@" ;;
  prompt) _agent_prompt "$@" ;;
  name) _agent_name "$@" ;;
  unname) _agent_unname "$@" ;;
  pick) _agent_pick "$@" ;;
  help|-h|--help) _agent_usage ;;
  *)
    print -u2 "agent: unknown subcommand: $_agent_sub"
    _agent_usage >&2
    return 2
    ;;
esac

#!/usr/bin/env zsh
# ai-usage: combined Claude + Codex API usage
# alias: aiu
emulate -L zsh

local mode="plain"
case "${1:-}" in
  --fancy|fancy)
    mode="fancy"
    shift
    ;;
  --plain|plain|"")
    [[ "${1:-}" == "--plain" || "${1:-}" == "plain" ]] && shift
    ;;
  -h|--help)
    cat <<'EOF'
Usage: ai-usage [--plain|--fancy]

Show combined Claude + Codex usage.
  --plain   Original text output from claude-usage/codex-usage
  --fancy   Dashboard with usage bars and recent agent-run totals
EOF
    return 0
    ;;
  *)
    print -u2 "ai-usage: unknown option: $1"
    return 2
    ;;
esac

local has_output=0

_resolve_tool() {
  local command_name="$1"
  local file_path="$2"

  if [[ -x "$HOME/.local/bin/$command_name" ]]; then
    print -r -- "$HOME/.local/bin/$command_name"
  elif [[ -x "$file_path" ]]; then
    print -r -- "$file_path"
  elif command -v "$command_name" &>/dev/null; then
    command -v "$command_name"
  elif typeset -f "$command_name" &>/dev/null; then
    print -r -- "$command_name"
  elif [[ -f "$file_path" ]]; then
    fpath=("${file_path:h}" $fpath)
    autoload -Uz "$command_name" 2>/dev/null || return 1
    print -r -- "$command_name"
  else
    return 1
  fi
}

_run_tool() {
  local label="$1"
  local colour="$2"
  local command_name="$3"
  local file_path="$4"
  local tool=""

  tool=$(_resolve_tool "$command_name" "$file_path") || return 1

  (( has_output )) && echo
  printf '\033[1;%sm── %s ──\033[0m\n' "$colour" "$label"
  "$tool"
  has_output=1
}

_refresh_tool_quiet() {
  local command_name="$1"
  local file_path="$2"
  local tool=""

  tool=$(_resolve_tool "$command_name" "$file_path") || return 0
  "$tool" >/dev/null 2>&1 || true
}

_render_fancy() {
  python3 <<'PY'
import json
import os
import re
import shutil
import sys
from collections import deque
from datetime import datetime, timezone
from pathlib import Path

HOME = Path(os.environ.get("HOME", ""))
NOW = datetime.now(timezone.utc)
NOW_TS = NOW.timestamp()
USE_COLOUR = sys.stdout.isatty() and "NO_COLOR" not in os.environ
ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")

PALETTE = {
    "reset": "\033[0m",
    "bold": "\033[1m",
    "dim": "\033[2m",
    "border": "\033[38;5;63m",
    "muted": "\033[38;5;245m",
    "green": "\033[38;5;120m",
    "yellow": "\033[38;5;228m",
    "red": "\033[38;5;210m",
    "claude": "\033[38;5;215m",
    "codex": "\033[38;5;117m",
    "sonnet": "\033[38;5;183m",
    "accent": "\033[38;5;141m",
}


def c(name: str, text: str) -> str:
    if not USE_COLOUR:
        return text
    return f"{PALETTE.get(name, '')}{text}{PALETTE['reset']}"


def visible_len(text: str) -> int:
    return len(ANSI_RE.sub("", text))


def pad(text: str, width: int) -> str:
    return text + " " * max(0, width - visible_len(text))


def load_json(path: Path):
    try:
        with path.open() as f:
            return json.load(f)
    except Exception:
        return None


def mtime(path):
    try:
        return path.stat().st_mtime
    except OSError:
        return None


def iso_ts(value):
    if not value:
        return None
    try:
        return datetime.fromisoformat(value.replace("Z", "+00:00")).timestamp()
    except Exception:
        return None


def fmt_duration(secs):
    if secs is None:
        return "-"
    secs = max(0, int(secs))
    if secs >= 86400:
        days = secs // 86400
        hours = (secs % 86400) // 3600
        return f"{days}d {hours}h"
    if secs >= 3600:
        hours = secs // 3600
        mins = (secs % 3600) // 60
        return f"{hours}h {mins}m"
    return f"{secs // 60}m"


def fmt_age(path: Path) -> str:
    ts = mtime(path)
    if ts is None:
        return "missing"
    return fmt_duration(NOW_TS - ts) + " ago"


def as_pct(value):
    try:
        if value is None or value == "":
            return None
        return float(value)
    except Exception:
        return None


def stale_after(window_secs):
    # How old a reading may get before we distrust it, scaled to the window it
    # describes: a 7d utilisation barely moves in a few hours, a 5h one does.
    # ~4% of the window — 15 min for the 5h window, ~6.7h for the 7d window —
    # floored at 15 min so short windows are not flagged the instant they age.
    return max(900, (window_secs or 0) * 0.04)


def pace_ratio(pct, remaining, window_secs, stale):
    if stale or remaining is None or pct <= 0:
        return None
    elapsed = window_secs - max(0, remaining)
    if elapsed < 180:
        return None
    elapsed_pct = max(1, elapsed * 100 / window_secs)
    return pct / elapsed_pct


def usage_colour(pct, remaining, window_secs, stale):
    if stale:
        return "muted"
    if pct <= 0:
        return "green"
    if remaining is None:
        return "green" if pct < 70 else "yellow" if pct < 90 else "red"
    pace = pace_ratio(pct, remaining, window_secs, stale)
    if pace is None:
        return "green"
    if pace >= 1.4:
        return "red"
    if pace >= 1.2:
        return "yellow"
    return "green"


def burn_note(row):
    if row.get("stale"):
        return "cache stale", "yellow"
    pct = float(row.get("pct") or 0)
    remaining = row.get("remaining")
    window_secs = int(row.get("window_secs") or 0)
    if pct >= 100:
        return "limit now", "red"
    pace = pace_ratio(pct, remaining, window_secs, False)
    if pace is None:
        return "fresh window", "muted"
    elapsed = window_secs - max(0, float(remaining or 0))
    if elapsed <= 0:
        return "pace unknown", "muted"
    hit_secs = (100 - pct) / max(0.001, pct / elapsed)
    if pace >= 1.2 and remaining is not None and hit_secs < remaining:
        colour_name = "red" if pace >= 1.4 else "yellow"
        return f"hits in ~{fmt_duration(hit_secs)}", colour_name
    if pace >= 1.2:
        return "warm pace", "yellow"
    return "pace OK", "green"


def bar(pct: float, width: int, colour_name: str, stale: bool = False) -> str:
    pct = max(0, min(100, pct))
    filled = int(round(pct * width / 100))
    fill = "▒" if stale else "█"  # hatched fill marks a reading we no longer trust
    raw = fill * filled + "░" * (width - filled)
    if not USE_COLOUR:
        return raw
    return c(colour_name, fill * filled) + c("muted", "░" * (width - filled))


def fmt_num(value) -> str:
    try:
        n = float(value or 0)
    except Exception:
        n = 0
    sign = "-" if n < 0 else ""
    n = abs(n)
    if n >= 1_000_000:
        return f"{sign}{n / 1_000_000:.1f}M".replace(".0M", "M")
    if n >= 1_000:
        return f"{sign}{n / 1_000:.1f}k".replace(".0k", "k")
    return f"{sign}{int(n)}"


def fmt_money(value) -> str:
    try:
        n = float(value or 0)
    except Exception:
        n = 0
    if n == 0:
        return "$0"
    if abs(n) < 1:
        return f"${n:.3f}".rstrip("0").rstrip(".")
    return f"${n:.2f}"


def short_limit_name(name):
    name = str(name or "").strip()
    if not name:
        return "Codex+"
    if "Spark" in name:
        return "Spark"
    name = name.replace("GPT-", "").replace("Codex", "").replace("codex", "")
    name = re.sub(r"[-_]+", " ", name).strip()
    return (name or "Codex+")[:7]


def collect_windows():
    rows = []
    alerts = []

    claude_path = HOME / ".cache/claude-usage.json"
    claude = load_json(claude_path)
    claude_mt = mtime(claude_path)
    claude_age = NOW_TS - claude_mt if claude_mt else None
    if claude:
        for label, key, window_secs in (
            ("Claude", "five_hour", 18000),
            ("Claude", "seven_day", 604800),
            ("Sonnet", "seven_day_sonnet", 604800),
        ):
            obj = claude.get(key) or {}
            pct = as_pct(obj.get("utilization"))
            if pct is None:
                continue
            reset = iso_ts(obj.get("resets_at"))
            remaining = max(0, reset - NOW_TS) if reset else None
            rows.append({
                "provider": label,
                "window": "5h" if key == "five_hour" else "7d",
                "pct": pct,
                "remaining": remaining,
                "window_secs": window_secs,
                "stale": claude_age is not None and claude_age >= stale_after(window_secs),
                "provider_colour": "sonnet" if label == "Sonnet" else "claude",
                "source": "claude",
            })
        extra = claude.get("extra_usage") or {}
        if extra.get("is_enabled") is not None:
            try:
                used = float(extra.get("used_credits") or 0) / 100
                limit = float(extra.get("monthly_limit") or 0) / 100
                if extra.get("is_enabled"):
                    alerts.append(("Extra", f"Claude {fmt_money(used)}/{fmt_money(limit)} enabled", "yellow"))
                elif used > 0:
                    alerts.append(("Extra", f"Claude disabled after {fmt_money(used)}", "yellow"))
            except Exception:
                pass
        if claude_age is not None and claude_age >= 900:
            alerts.append(("Stale", f"Claude cache {fmt_age(claude_path)}", "yellow"))
    elif not claude_path.exists():
        alerts.append(("Missing", "Claude usage cache", "yellow"))

    codex_path = HOME / ".cache/codex-usage.json"
    codex = load_json(codex_path)
    codex_mt = mtime(codex_path)
    codex_age = NOW_TS - codex_mt if codex_mt else None
    if codex:
        rl = codex.get("rate_limit") or {}
        for label, key, window_secs in (
            ("Codex", "primary_window", 18000),
            ("Codex", "secondary_window", 604800),
        ):
            obj = rl.get(key) or {}
            pct = as_pct(obj.get("used_percent"))
            if pct is None:
                continue
            reset_secs = as_pct(obj.get("reset_after_seconds"))
            remaining = max(0, reset_secs - (NOW_TS - codex_mt)) if reset_secs is not None and codex_mt else None
            rows.append({
                "provider": label,
                "window": "5h" if key == "primary_window" else "7d",
                "pct": pct,
                "remaining": remaining,
                "window_secs": window_secs,
                "stale": codex_age is not None and codex_age >= stale_after(window_secs),
                "provider_colour": "codex",
                "source": "codex",
            })
        for extra_limit in (codex.get("additional_rate_limits") or [])[:2]:
            limit_name = short_limit_name(extra_limit.get("limit_name"))
            extra_rl = extra_limit.get("rate_limit") or {}
            for key, window_secs in (("primary_window", 18000), ("secondary_window", 604800)):
                obj = extra_rl.get(key) or {}
                pct = as_pct(obj.get("used_percent"))
                if pct is None:
                    continue
                reset_secs = as_pct(obj.get("reset_after_seconds"))
                remaining = max(0, reset_secs - (NOW_TS - codex_mt)) if reset_secs is not None and codex_mt else None
                rows.append({
                    "provider": limit_name,
                    "window": "5h" if key == "primary_window" else "7d",
                    "pct": pct,
                    "remaining": remaining,
                    "window_secs": window_secs,
                    "stale": codex_age is not None and codex_age >= stale_after(window_secs),
                    "provider_colour": "codex",
                    "source": "codex-extra",
                })
        reset_credits = ((codex.get("rate_limit_reset_credits") or {}).get("available_count") or 0)
        try:
            if int(reset_credits) > 0:
                alerts.append(("Reset", f"Codex has {reset_credits} reset credit(s)", "green"))
        except Exception:
            pass
        if (codex.get("rate_limit") or {}).get("limit_reached"):
            alerts.append(("Limit", "Codex limit reached", "red"))
        if codex_age is not None and codex_age >= 900:
            alerts.append(("Stale", f"Codex cache {fmt_age(codex_path)}", "yellow"))
    elif not codex_path.exists():
        alerts.append(("Missing", "Codex usage cache", "yellow"))

    return rows, alerts


def collect_recent():
    log = HOME / ".local/state/agents/rl-usage.jsonl"
    if not log.exists():
        return []
    records = deque(maxlen=1000)
    try:
        with log.open(errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    records.append(json.loads(line))
                except Exception:
                    continue
    except Exception:
        return []
    if not records:
        return []

    lines = []
    last = records[-1]
    last_dt = None
    try:
        last_dt = datetime.fromisoformat(str(last.get("ts") or "").replace("Z", "+00:00"))
    except Exception:
        pass
    if last_dt is not None:
        age = datetime.now().astimezone() - last_dt.astimezone()
        if age.total_seconds() <= 172800:
            provider = str(last.get("provider") or "agent")
            runner = str(last.get("runner") or "run")
            lines.append((
                "Last",
                f"{provider}/{runner} {fmt_duration(age.total_seconds())} ago · "
                + f"cached {fmt_num(last.get('cached_input_tokens'))} · "
                + f"out {fmt_num(last.get('output_tokens'))} · "
                + fmt_money(last.get("total_cost_usd")),
                "muted",
            ))

    local_today = datetime.now().astimezone().date()
    today = []
    for rec in records:
        ts = str(rec.get("ts") or "")
        try:
            dt = datetime.fromisoformat(ts.replace("Z", "+00:00")).astimezone()
        except Exception:
            continue
        if dt.date() == local_today:
            today.append(rec)
    if today:
        total = lambda key: sum(float(r.get(key) or 0) for r in today)
        lines.append((
            "Today",
            f"{len(today)} runs · "
            + f"cached {fmt_num(total('cached_input_tokens'))} · "
            + f"out {fmt_num(total('output_tokens'))} · "
            + fmt_money(total("total_cost_usd")),
            "muted",
        ))
    return lines


def collect_insights(rows):
    if not rows:
        return []
    # Stale rows still count: an hours-old 7d reading is more likely the real
    # bottleneck than a fresh-but-idle 5h one. Prefer fresh data, then the
    # tighter 5h window, on ties — and flag a stale pick rather than hide it.
    bottleneck = max(rows, key=lambda r: (
        float(r.get("pct") or 0),
        0 if r.get("stale") else 1,
        1 if r.get("window") == "5h" else 0,
    ))
    note, note_colour = burn_note(bottleneck)
    lines = [(
        "Bottleneck",
        f"{bottleneck['provider']} {bottleneck['window']} {bottleneck['pct']:.0f}% · ↻ {fmt_duration(bottleneck.get('remaining'))} · {note}",
        note_colour,
    )]

    best = min(rows, key=lambda r: (
        float(r.get("pct") or 0),
        1 if r.get("stale") else 0,
        0 if r.get("window") == "5h" else 1,
    ))
    headroom = max(0, 100 - float(best.get("pct") or 0))
    suffix = " (stale)" if best.get("stale") else ""
    lines.append((
        "Headroom",
        f"{best['provider']} {best['window']} has {headroom:.0f}% free{suffix}",
        "green" if headroom >= 70 else "yellow" if headroom >= 30 else "red",
    ))
    return lines


def print_kv_lines(lines, inner, box_width):
    for label, value, colour_name in lines:
        left = c("accent", f"{label:<10}")
        content = f"{left} {c(colour_name, value)}"
        if visible_len(content) > inner:
            plain_value_max = max(0, inner - visible_len(left) - 2)
            value = value[:plain_value_max] + "…"
            content = f"{left} {c(colour_name, value)}"
        print(c("border", "│ ") + pad(content, inner) + c("border", " │"))


def render():
    term_width = shutil.get_terminal_size((80, 24)).columns
    box_width = max(46, min(86, term_width - 2))
    inner = box_width - 4
    bar_width = max(8, min(28, inner - 31))
    rows, alerts = collect_windows()
    insights = collect_insights(rows)
    recent = collect_recent()

    print(c("border", "╭" + "─" * (box_width - 2) + "╮"))
    title = c("accent", c("bold", "AI usage"))
    print(c("border", "│ ") + pad(title, inner) + c("border", " │"))
    print(c("border", "├" + "─" * (box_width - 2) + "┤"))

    if rows:
        for row in rows:
            pct = row["pct"]
            colour = usage_colour(pct, row["remaining"], row["window_secs"], row["stale"])
            provider = c(row["provider_colour"], f"{row['provider']:<7}")
            window = c("muted", f"{row['window']:<2}")
            reset = fmt_duration(row["remaining"])
            pct_text = c(colour, f"{pct:>3.0f}%")
            content = f"{provider} {window} {bar(pct, bar_width, colour, row['stale'])} {pct_text}  {c('muted', '↻')} {reset}"
            print(c("border", "│ ") + pad(content, inner) + c("border", " │"))
    else:
        print(c("border", "│ ") + pad(c("yellow", "No usage cache yet — run claude-usage or codex-usage."), inner) + c("border", " │"))

    if insights:
        print(c("border", "├" + "─" * (box_width - 2) + "┤"))
        print_kv_lines(insights, inner, box_width)

    if recent:
        print(c("border", "├" + "─" * (box_width - 2) + "┤"))
        print_kv_lines(recent[:3], inner, box_width)

    if alerts:
        print(c("border", "├" + "─" * (box_width - 2) + "┤"))
        print_kv_lines(alerts[:3], inner, box_width)

    sys.stdout.write(c("border", "╰" + "─" * (box_width - 2) + "╯"))
    sys.stdout.flush()


render()
PY
}

if [[ "$mode" == "fancy" ]]; then
  _refresh_tool_quiet "claude-usage" "$HOME/.config/zsh/functions/claude-usage" &
  local claude_pid=$!
  _refresh_tool_quiet "codex-usage" "$HOME/.config/zsh/functions/codex-usage" &
  local codex_pid=$!
  wait "$claude_pid" 2>/dev/null || true
  wait "$codex_pid" 2>/dev/null || true

  _render_fancy || {
    print -u2 "ai-usage: fancy renderer failed; falling back to plain output"
    _run_tool "Claude" "34" "claude-usage" "$HOME/.config/zsh/functions/claude-usage"
    _run_tool "Codex" "32" "codex-usage" "$HOME/.config/zsh/functions/codex-usage"
    (( has_output )) || { print -u2 "no usage tools available"; return 1; }
  }
  return 0
fi

_run_tool "Claude" "34" "claude-usage" "$HOME/.config/zsh/functions/claude-usage"
_run_tool "Codex" "32" "codex-usage" "$HOME/.config/zsh/functions/codex-usage"

(( has_output )) || { print -u2 "no usage tools available"; return 1; }

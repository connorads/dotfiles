#!/usr/bin/env zsh
# ai-usage: combined Claude + Codex + Cosine API usage
# alias: aiu
emulate -L zsh

local mode="plain"
case "${1:-}" in
  --fancy|fancy)
    mode="fancy"
    shift
    ;;
  --plain|plain|"")
    [[ "${1:-}" == "--plain" || "${1:-}" == "plain" ]] && shift
    ;;
  -h|--help)
    cat <<'EOF'
Usage: ai-usage [--plain|--fancy]

Show combined Claude + Codex + Cosine usage.
  --plain   Original text output from claude-usage/codex-usage/cosine-usage
  --fancy   Dashboard with usage bars and recent agent-run totals
EOF
    return 0
    ;;
  *)
    print -u2 "ai-usage: unknown option: $1"
    return 2
    ;;
esac

local has_output=0

_resolve_tool() {
  local command_name="$1"
  local file_path="$2"

  if [[ -x "$HOME/.local/bin/$command_name" ]]; then
    print -r -- "$HOME/.local/bin/$command_name"
  elif [[ -x "$file_path" ]]; then
    print -r -- "$file_path"
  elif command -v "$command_name" &>/dev/null; then
    command -v "$command_name"
  elif typeset -f "$command_name" &>/dev/null; then
    print -r -- "$command_name"
  elif [[ -f "$file_path" ]]; then
    fpath=("${file_path:h}" $fpath)
    autoload -Uz "$command_name" 2>/dev/null || return 1
    print -r -- "$command_name"
  else
    return 1
  fi
}

_run_tool() {
  local label="$1"
  local colour="$2"
  local command_name="$3"
  local file_path="$4"
  local tool=""

  tool=$(_resolve_tool "$command_name" "$file_path") || return 1

  (( has_output )) && echo
  printf '\033[1;%sm── %s ──\033[0m\n' "$colour" "$label"
  "$tool"
  has_output=1
}

_refresh_tool_quiet() {
  local command_name="$1"
  local file_path="$2"
  local tool=""

  tool=$(_resolve_tool "$command_name" "$file_path") || return 0
  "$tool" >/dev/null 2>&1 || true
}

_render_fancy() {
  python3 <<'PY'
import json
import os
import re
import shutil
import sys
from collections import deque
from datetime import datetime, timezone
from pathlib import Path

HOME = Path(os.environ.get("HOME", ""))
NOW = datetime.now(timezone.utc)
NOW_TS = NOW.timestamp()
USE_COLOUR = sys.stdout.isatty() and "NO_COLOR" not in os.environ
ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")

PALETTE = {
    "reset": "\033[0m",
    "bold": "\033[1m",
    "dim": "\033[2m",
    "border": "\033[38;5;63m",
    "muted": "\033[38;5;245m",
    "green": "\033[38;5;120m",
    "yellow": "\033[38;5;228m",
    "red": "\033[38;5;210m",
    "claude": "\033[38;5;215m",
    "codex": "\033[38;5;117m",
    "cosine": "\033[38;5;120m",
    "sonnet": "\033[38;5;183m",
    "accent": "\033[38;5;141m",
}


def c(name: str, text: str) -> str:
    if not USE_COLOUR:
        return text
    return f"{PALETTE.get(name, '')}{text}{PALETTE['reset']}"


def visible_len(text: str) -> int:
    return len(ANSI_RE.sub("", text))


def pad(text: str, width: int) -> str:
    return text + " " * max(0, width - visible_len(text))


def load_json(path: Path):
    try:
        with path.open() as f:
            return json.load(f)
    except Exception:
        return None


def mtime(path):
    try:
        return path.stat().st_mtime
    except OSError:
        return None


def iso_ts(value):
    if not value:
        return None
    try:
        return datetime.fromisoformat(value.replace("Z", "+00:00")).timestamp()
    except Exception:
        return None


def fmt_duration(secs):
    if secs is None:
        return "-"
    secs = max(0, int(secs))
    if secs >= 86400:
        days = secs // 86400
        hours = (secs % 86400) // 3600
        return f"{days}d {hours}h"
    if secs >= 3600:
        hours = secs // 3600
        mins = (secs % 3600) // 60
        return f"{hours}h {mins}m"
    return f"{secs // 60}m"


def fmt_age(path: Path) -> str:
    ts = mtime(path)
    if ts is None:
        return "missing"
    return fmt_duration(NOW_TS - ts) + " ago"


def as_pct(value):
    try:
        if value is None or value == "":
            return None
        return float(value)
    except Exception:
        return None


def stale_after(window_secs):
    # How old a reading may get before we distrust it, scaled to the window it
    # describes: a 7d utilisation barely moves in a few hours, a 5h one does.
    # ~4% of the window — 15 min for the 5h window, ~6.7h for the 7d window —
    # floored at 15 min so short windows are not flagged the instant they age.
    return max(900, (window_secs or 0) * 0.04)


def ideal_pct(remaining, window_secs, stale):
    if stale or remaining is None or not window_secs:
        return None
    elapsed = window_secs - max(0, remaining)
    if elapsed < 0:
        return None
    return max(0, min(100, elapsed * 100 / window_secs))


def pace_delta(pct, remaining, window_secs, stale):
    ideal = ideal_pct(remaining, window_secs, stale)
    if ideal is None:
        return None
    return ideal - pct


def pace_ratio(pct, remaining, window_secs, stale):
    if stale or remaining is None or pct <= 0:
        return None
    ideal = ideal_pct(remaining, window_secs, stale)
    if ideal is None:
        return None
    elapsed = window_secs - max(0, remaining)
    if elapsed < 180:
        return None
    return pct / max(1, ideal)


def usage_colour(pct, remaining, window_secs, stale):
    if stale:
        return "muted"
    if pct <= 0:
        return "green"
    if remaining is None:
        return "green" if pct < 70 else "yellow" if pct < 90 else "red"
    pace = pace_ratio(pct, remaining, window_secs, stale)
    if pace is None:
        return "green"
    if pace >= 1.4:
        return "red"
    if pace >= 1.2:
        return "yellow"
    return "green"


def pool_colour(pct, stale, pace=None):
    if stale:
        return "muted"
    if pct >= 90 or (pace is not None and pace >= 1.4):
        return "red"
    if pct >= 70 or (pace is not None and pace >= 1.2):
        return "yellow"
    return "green"


def pool_note(row):
    if row.get("stale"):
        return "cache stale", "yellow"
    pct = float(row.get("pct") or 0)
    if pct >= 100:
        return "pool exhausted", "red"
    if pct >= 90:
        return "credits critical", "red"
    if pct >= 70:
        return "credits warm", "yellow"
    pace = row.get("pace_ratio")
    projected = row.get("projected_exhaustion")
    remaining = row.get("remaining")
    if pace is not None and pace >= 1.2:
        colour_name = "red" if pace >= 1.4 else "yellow"
        if projected is not None and remaining is not None and projected < remaining:
            return f"projects empty in ~{fmt_duration(projected)}", colour_name
        return "critical pace" if pace >= 1.4 else "warm pace", colour_name
    return "credits OK", "green"


def burn_note(row):
    if row.get("kind") == "pool":
        return pool_note(row)
    if row.get("stale"):
        return "cache stale", "yellow"
    pct = float(row.get("pct") or 0)
    remaining = row.get("remaining")
    window_secs = int(row.get("window_secs") or 0)
    if pct >= 100:
        return "limit now", "red"
    pace = row.get("pace_ratio")
    if pace is None:
        return "fresh window", "muted"
    elapsed = window_secs - max(0, float(remaining or 0))
    if elapsed <= 0:
        return "pace unknown", "muted"
    hit_secs = (100 - pct) / max(0.001, pct / elapsed)
    if pace >= 1.2 and remaining is not None and hit_secs < remaining:
        colour_name = "red" if pace >= 1.4 else "yellow"
        return f"hits in ~{fmt_duration(hit_secs)}", colour_name
    if pace >= 1.2:
        return "warm pace", "yellow"
    return "pace OK", "green"


def severity_rank(colour_name):
    return {"red": 3, "yellow": 2, "green": 1, "muted": 0}.get(colour_name, 0)


def attach_row_metadata(row):
    if row.get("kind") == "pool":
        row["colour"] = pool_colour(row["pct"], row["stale"], row.get("pace_ratio"))
    else:
        row["colour"] = usage_colour(row["pct"], row["remaining"], row["window_secs"], row["stale"])
    note, note_colour = burn_note(row)
    row["note"] = note
    row["note_colour"] = note_colour
    if row.get("stale"):
        row["risk_rank"] = severity_rank("green")
    else:
        row["risk_rank"] = max(severity_rank(row["colour"]), severity_rank(note_colour))
    return row


def make_window_row(provider, window, pct, remaining, window_secs, stale, provider_colour, source):
    ideal = ideal_pct(remaining, window_secs, stale)
    row = {
        "kind": "window",
        "provider": provider,
        "window": window,
        "pct": pct,
        "remaining": remaining,
        "window_secs": window_secs,
        "stale": stale,
        "ideal_pct": ideal,
        "pace_delta": ideal - pct if ideal is not None else None,
        "pace_ratio": pace_ratio(pct, remaining, window_secs, stale),
        "note": "",
        "provider_colour": provider_colour,
        "source": source,
    }
    return attach_row_metadata(row)


def make_pool_row(provider, window, pct, remaining, stale, provider_colour, source, start_ts=None, reset_ts=None):
    ideal = None
    delta = None
    ratio = None
    projected = None
    period_secs = None
    elapsed_secs = None
    if not stale and start_ts is not None and reset_ts is not None:
        period_secs = reset_ts - start_ts
        elapsed_secs = NOW_TS - start_ts
        if period_secs > 0 and elapsed_secs >= 0:
            ideal = max(0, min(100, elapsed_secs * 100 / period_secs))
            delta = ideal - pct
            if pct > 0 and ideal > 0:
                ratio = pct / ideal
            if pct > 0 and elapsed_secs > 0:
                projected = (100 - pct) / (pct / elapsed_secs)
    row = {
        "kind": "pool",
        "provider": provider,
        "window": window,
        "pct": pct,
        "remaining": remaining,
        "window_secs": period_secs or 0,
        "stale": stale,
        "ideal_pct": ideal,
        "pace_delta": delta,
        "pace_ratio": ratio,
        "projected_exhaustion": projected,
        "elapsed_secs": elapsed_secs,
        "note": "",
        "provider_colour": provider_colour,
        "source": source,
    }
    return attach_row_metadata(row)


def bar(pct: float, width: int, colour_name: str, stale: bool = False, marker_pct=None) -> str:
    pct = max(0, min(100, pct))
    filled = int(round(pct * width / 100))
    fill = "▒" if stale else "█"  # hatched fill marks a reading we no longer trust
    marker_idx = None
    if marker_pct is not None and width > 0:
        marker_pct = max(0, min(100, float(marker_pct)))
        marker_idx = int(round(marker_pct * (width - 1) / 100))

    if not USE_COLOUR:
        chars = []
        for idx in range(width):
            chars.append("┃" if idx == marker_idx else fill if idx < filled else "░")
        return "".join(chars)

    out = []
    for idx in range(width):
        if idx == marker_idx:
            out.append(c("muted" if stale else "accent", "┃"))
        elif idx < filled:
            out.append(c(colour_name, fill))
        else:
            out.append(c("muted", "░"))
    return "".join(out)


def pace_delta_label(delta) -> str:
    if delta is None:
        return ""
    rounded = int(round(delta))
    if rounded == 0:
        return c("muted", "pace 0")
    colour_name = "green" if rounded > 0 else "yellow" if rounded >= -10 else "red"
    return c(colour_name, f"pace {rounded:+d}")


def fmt_num(value) -> str:
    try:
        n = float(value or 0)
    except Exception:
        n = 0
    sign = "-" if n < 0 else ""
    n = abs(n)
    if n >= 1_000_000:
        return f"{sign}{n / 1_000_000:.1f}M".replace(".0M", "M")
    if n >= 1_000:
        return f"{sign}{n / 1_000:.1f}k".replace(".0k", "k")
    return f"{sign}{int(n)}"


def fmt_money(value) -> str:
    try:
        n = float(value or 0)
    except Exception:
        n = 0
    if n == 0:
        return "$0"
    if abs(n) < 1:
        return f"${n:.3f}".rstrip("0").rstrip(".")
    return f"${n:.2f}"


def short_limit_name(name):
    name = str(name or "").strip()
    if not name:
        return "Codex+"
    if "Spark" in name:
        return "Spark"
    name = name.replace("GPT-", "").replace("Codex", "").replace("codex", "")
    name = re.sub(r"[-_]+", " ", name).strip()
    return (name or "Codex+")[:7]


def collect_windows():
    rows = []
    alerts = []

    claude_path = HOME / ".cache/claude-usage.json"
    claude_meta = load_json(HOME / ".cache/claude-usage.meta.json") or {}
    claude = load_json(claude_path)
    claude_mt = mtime(claude_path)
    claude_age = NOW_TS - claude_mt if claude_mt else None
    if claude_meta.get("last_error") == "auth_expired":
        alerts.append(("Auth", "Claude expired — use Claude or run claude auth login", "yellow"))
    if claude:
        for label, key, window_secs in (
            ("Claude", "five_hour", 18000),
            ("Claude", "seven_day", 604800),
            ("Sonnet", "seven_day_sonnet", 604800),
        ):
            obj = claude.get(key) or {}
            pct = as_pct(obj.get("utilization"))
            if pct is None:
                continue
            reset = iso_ts(obj.get("resets_at"))
            remaining = max(0, reset - NOW_TS) if reset else None
            rows.append(make_window_row(
                label,
                "5h" if key == "five_hour" else "7d",
                pct,
                remaining,
                window_secs,
                claude_age is not None and claude_age >= stale_after(window_secs),
                "sonnet" if label == "Sonnet" else "claude",
                "claude",
            ))
        # Model-scoped weekly windows (e.g. Fable) now arrive via .limits[] with a
        # scope.model.display_name; the legacy seven_day_<model> keys are null.
        for lim in claude.get("limits") or []:
            if lim.get("kind") != "weekly_scoped":
                continue
            model = ((lim.get("scope") or {}).get("model") or {}).get("display_name")
            pct = as_pct(lim.get("percent"))
            if not model or pct is None:
                continue
            reset = iso_ts(lim.get("resets_at"))
            remaining = max(0, reset - NOW_TS) if reset else None
            rows.append(make_window_row(
                model[:7],
                "7d",
                pct,
                remaining,
                604800,
                claude_age is not None and claude_age >= stale_after(604800),
                "sonnet",
                "claude",
            ))
        extra = claude.get("extra_usage") or {}
        if extra.get("is_enabled") is not None:
            try:
                used = float(extra.get("used_credits") or 0) / 100
                limit = float(extra.get("monthly_limit") or 0) / 100
                if extra.get("is_enabled"):
                    alerts.append(("Extra", f"Claude {fmt_money(used)}/{fmt_money(limit)} enabled", "yellow"))
                elif used > 0:
                    alerts.append(("Extra", f"Claude disabled after {fmt_money(used)}", "yellow"))
            except Exception:
                pass
        if claude_age is not None and claude_age >= 900:
            alerts.append(("Stale", f"Claude cache {fmt_age(claude_path)}", "yellow"))
    elif not claude_path.exists():
        alerts.append(("Missing", "Claude usage cache", "yellow"))

    codex_path = HOME / ".cache/codex-usage.json"
    codex = load_json(codex_path)
    codex_mt = mtime(codex_path)
    codex_age = NOW_TS - codex_mt if codex_mt else None
    if codex:
        rl = codex.get("rate_limit") or {}
        for label, key, window_secs in (
            ("Codex", "primary_window", 18000),
            ("Codex", "secondary_window", 604800),
        ):
            obj = rl.get(key) or {}
            pct = as_pct(obj.get("used_percent"))
            if pct is None:
                continue
            reset_secs = as_pct(obj.get("reset_after_seconds"))
            remaining = max(0, reset_secs - (NOW_TS - codex_mt)) if reset_secs is not None and codex_mt else None
            rows.append(make_window_row(
                label,
                "5h" if key == "primary_window" else "7d",
                pct,
                remaining,
                window_secs,
                codex_age is not None and codex_age >= stale_after(window_secs),
                "codex",
                "codex",
            ))
        for extra_limit in (codex.get("additional_rate_limits") or [])[:2]:
            limit_name = short_limit_name(extra_limit.get("limit_name"))
            extra_rl = extra_limit.get("rate_limit") or {}
            for key, window_secs in (("primary_window", 18000), ("secondary_window", 604800)):
                obj = extra_rl.get(key) or {}
                pct = as_pct(obj.get("used_percent"))
                if pct is None:
                    continue
                reset_secs = as_pct(obj.get("reset_after_seconds"))
                remaining = max(0, reset_secs - (NOW_TS - codex_mt)) if reset_secs is not None and codex_mt else None
                rows.append(make_window_row(
                    limit_name,
                    "5h" if key == "primary_window" else "7d",
                    pct,
                    remaining,
                    window_secs,
                    codex_age is not None and codex_age >= stale_after(window_secs),
                    "codex",
                    "codex-extra",
                ))
        reset_credits = ((codex.get("rate_limit_reset_credits") or {}).get("available_count") or 0)
        try:
            if int(reset_credits) > 0:
                alerts.append(("Reset", f"Codex has {reset_credits} reset credit(s)", "green"))
        except Exception:
            pass
        if (codex.get("rate_limit") or {}).get("limit_reached"):
            alerts.append(("Limit", "Codex limit reached", "red"))
        if codex_age is not None and codex_age >= 900:
            alerts.append(("Stale", f"Codex cache {fmt_age(codex_path)}", "yellow"))
    elif not codex_path.exists():
        alerts.append(("Missing", "Codex usage cache", "yellow"))

    cosine_path = HOME / ".cache/cosine-usage.json"
    cosine = load_json(cosine_path)
    cosine_mt = mtime(cosine_path)
    cosine_age = NOW_TS - cosine_mt if cosine_mt else None
    if cosine:
        used = as_pct(cosine.get("usedTokens"))
        total = as_pct(cosine.get("totalAvailableTokens"))
        start = iso_ts(cosine.get("billingPeriodStartsAt"))
        reset = iso_ts(cosine.get("billingPeriodResetsAt"))
        if used is not None and total is not None and total > 0:
            pct = used * 100 / total
            rows.append(make_pool_row(
                "Cosine",
                "mo",
                pct,
                max(0, reset - NOW_TS) if reset else None,
                cosine_age is not None and cosine_age >= 900,
                "cosine",
                "cosine",
                start,
                reset,
            ))
        if cosine_age is not None and cosine_age >= 900:
            alerts.append(("Stale", f"Cosine cache {fmt_age(cosine_path)}", "yellow"))
    elif not cosine_path.exists():
        alerts.append(("Missing", "Cosine usage cache", "yellow"))

    return rows, alerts


def collect_recent():
    log = HOME / ".local/state/agents/rl-usage.jsonl"
    if not log.exists():
        return []
    records = deque(maxlen=1000)
    try:
        with log.open(errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    records.append(json.loads(line))
                except Exception:
                    continue
    except Exception:
        return []
    if not records:
        return []

    lines = []
    last = records[-1]
    last_dt = None
    try:
        last_dt = datetime.fromisoformat(str(last.get("ts") or "").replace("Z", "+00:00"))
    except Exception:
        pass
    if last_dt is not None:
        age = datetime.now().astimezone() - last_dt.astimezone()
        if age.total_seconds() <= 172800:
            provider = str(last.get("provider") or "agent")
            runner = str(last.get("runner") or "run")
            lines.append((
                "Last",
                f"{provider}/{runner} {fmt_duration(age.total_seconds())} ago · "
                + f"cached {fmt_num(last.get('cached_input_tokens'))} · "
                + f"out {fmt_num(last.get('output_tokens'))} · "
                + fmt_money(last.get("total_cost_usd")),
                "muted",
            ))

    local_today = datetime.now().astimezone().date()
    today = []
    for rec in records:
        ts = str(rec.get("ts") or "")
        try:
            dt = datetime.fromisoformat(ts.replace("Z", "+00:00")).astimezone()
        except Exception:
            continue
        if dt.date() == local_today:
            today.append(rec)
    if today:
        total = lambda key: sum(float(r.get(key) or 0) for r in today)
        lines.append((
            "Today",
            f"{len(today)} runs · "
            + f"cached {fmt_num(total('cached_input_tokens'))} · "
            + f"out {fmt_num(total('output_tokens'))} · "
            + fmt_money(total("total_cost_usd")),
            "muted",
        ))
    return lines


def collect_insights(rows):
    if not rows:
        return []
    # Stale rows still count: an hours-old 7d reading is more likely the real
    # bottleneck than a fresh-but-idle 5h one. Pace can now make a lower absolute
    # pool usage more urgent, so severity ranks first, then absolute usage.
    bottleneck = max(rows, key=lambda r: (
        int(r.get("risk_rank") or 0),
        float(r.get("pct") or 0),
        0 if r.get("stale") else 1,
        1 if r.get("window") == "5h" else 0,
    ))
    note = bottleneck.get("note") or burn_note(bottleneck)[0]
    note_colour = bottleneck.get("note_colour") or burn_note(bottleneck)[1]
    lines = [(
        "Bottleneck",
        f"{bottleneck['provider']} {bottleneck['window']} {bottleneck['pct']:.0f}% · ↻ {fmt_duration(bottleneck.get('remaining'))} · {note}",
        note_colour,
    )]

    best = min(rows, key=lambda r: (
        float(r.get("pct") or 0),
        1 if r.get("stale") else 0,
        0 if r.get("window") == "5h" else 1,
    ))
    headroom = max(0, 100 - float(best.get("pct") or 0))
    suffix = " (stale)" if best.get("stale") else ""
    lines.append((
        "Headroom",
        f"{best['provider']} {best['window']} has {headroom:.0f}% free{suffix}",
        "green" if headroom >= 70 else "yellow" if headroom >= 30 else "red",
    ))
    return lines


def print_kv_lines(lines, inner, box_width, left_pad=""):
    for label, value, colour_name in lines:
        left = c("accent", f"{label:<10}")
        content = f"{left} {c(colour_name, value)}"
        if visible_len(content) > inner:
            plain_value_max = max(0, inner - visible_len(left) - 2)
            value = value[:plain_value_max] + "…"
            content = f"{left} {c(colour_name, value)}"
        print(left_pad + c("border", "│ ") + pad(content, inner) + c("border", " │"))


def render():
    term_width = shutil.get_terminal_size((80, 24)).columns
    available_width = max(1, term_width - 2)
    # Use a proportional width with a sane cap, then centre it in the popup.
    # This grows on roomy popups without turning bars into full-width rulers.
    box_width = min(available_width, max(68, min(104, int(available_width * 0.72))))
    left_pad = " " * max(0, (term_width - box_width) // 2)
    inner = box_width - 4
    show_pace = inner >= 52
    row_reserved = 36 if show_pace else 27
    bar_width = max(8, inner - row_reserved)
    rows, alerts = collect_windows()
    insights = collect_insights(rows)
    recent = collect_recent()

    def emit(line):
        print(left_pad + line)

    emit(c("border", "╭" + "─" * (box_width - 2) + "╮"))
    title = c("accent", c("bold", "AI usage")) + c("muted", "  ┃=constant pace")
    emit(c("border", "│ ") + pad(title, inner) + c("border", " │"))
    emit(c("border", "├" + "─" * (box_width - 2) + "┤"))

    if rows:
        for row in rows:
            pct = row["pct"]
            colour = row.get("colour") or usage_colour(pct, row["remaining"], row["window_secs"], row["stale"])
            ideal = row.get("ideal_pct")
            delta = row.get("pace_delta")
            provider = c(row["provider_colour"], f"{row['provider']:<7}")
            window = c("muted", f"{row['window']:<2}")
            reset = fmt_duration(row["remaining"])
            pct_text = c(colour, f"{pct:>3.0f}%")
            pace_part = f" {pace_delta_label(delta)}" if show_pace and delta is not None else ""
            content = f"{provider} {window} {bar(pct, bar_width, colour, row['stale'], ideal)} {pct_text}{pace_part}  {c('muted', '↻')} {reset}"
            emit(c("border", "│ ") + pad(content, inner) + c("border", " │"))
    else:
        emit(c("border", "│ ") + pad(c("yellow", "No usage cache yet — run claude-usage, codex-usage, or cosine-usage."), inner) + c("border", " │"))

    if insights:
        emit(c("border", "├" + "─" * (box_width - 2) + "┤"))
        print_kv_lines(insights, inner, box_width, left_pad)

    if recent:
        emit(c("border", "├" + "─" * (box_width - 2) + "┤"))
        print_kv_lines(recent[:3], inner, box_width, left_pad)

    if alerts:
        emit(c("border", "├" + "─" * (box_width - 2) + "┤"))
        print_kv_lines(alerts[:3], inner, box_width, left_pad)

    sys.stdout.write(left_pad + c("border", "╰" + "─" * (box_width - 2) + "╯"))
    sys.stdout.flush()


render()
PY
}


#!/usr/bin/env zsh
# cxys: codex yolo stream - non-interactive codex with live formatted output
# alias: cxy e (codex exec with yolo + json streaming)
emulate -L zsh
setopt pipefail
setopt localtraps

local self_name="${funcstack[1]:-${${(%):-%N}:t}}"
local agent_file=
local candidate_dir
for candidate_dir in $fpath; do
  if [[ -r "$candidate_dir/$self_name" ]]; then
    agent_file="$candidate_dir/$self_name"
    break
  fi
done
[[ -n "$agent_file" ]] || agent_file="${${(%):-%N}:A}"
[[ -r "$agent_file" ]] || agent_file="${0:A}"
local agent_dir="${agent_file:A:h}"
source "$agent_dir/agent-stream-colours"
source "$agent_dir/agent-usage-log"
agent_stream_setup_colours

# exec is baked in below — strip if caller passes it redundantly (e.g. cxys exec "prompt")
[[ $1 == exec ]] && { print -P "%F{yellow}[cxys]%f stripping redundant 'exec' (already baked in)"; shift; }

local tmp_dir="${TMPDIR:-/tmp}"
local usage_file raw_stream_file
usage_file=$(mktemp "${tmp_dir%/}/cxys-usage.XXXXXX.json") || return 1
raw_stream_file=$(mktemp "${tmp_dir%/}/cxys-stream.XXXXXX.jsonl") || {
  rm -f "$usage_file"
  return 1
}

TRAPEXIT() {
  rm -f "$usage_file" "$raw_stream_file"
}

codex exec --dangerously-bypass-approvals-and-sandbox --json "$@" 2>/dev/null \
  | tee "$raw_stream_file" \
  | jq --unbuffered -r "${AGENT_STREAM_JQ_ARGS[@]}" '
    def paint($colour; $text): $colour + $text + $c_reset;
    def bucket($command):
      ($command // "") as $cmd
      | if $cmd == "" then "shell"
        elif $cmd | test("^(rg|sed|cat|less|head|tail|ls|find|fd|tree|wc|sort|uniq|cut|awk|jq|git (status|diff|show|log)\b|dotfiles status\b)") then "read"
        elif $cmd | test("^(git\b|dotfiles\b)") then "git"
        elif $cmd | test("^(mise\b|hk\b|bats\b|npm (test|run\b)|pnpm (test|run\b)|bun (test|run\b)|cargo (test|check|build|clippy)\b|pytest\b|uv run\b|nix\b)") then "test"
        elif $cmd | test("^(gh\b|curl\b|wget\b|http\b|exa\b)") then "web"
        elif $cmd | test("^(apply_patch|mv\b|cp\b|rm\b|touch\b|mkdir\b|chmod\b|chown\b|perl -0pi\b|python .*write|shfmt\b|prettier\b|eslint .*--fix\b|sed -i\b)") then "write"
        else "shell"
        end;
    def bucket_colour($bucket):
      if $bucket == "read" then $c_read
      elif $bucket == "git" then $c_agent
      elif $bucket == "test" then $c_success
      elif $bucket == "web" then $c_web
      elif $bucket == "write" then $c_write
      else $c_shell
      end;
    def command_line($command; $suffix):
      bucket($command) as $bucket
      | paint(bucket_colour($bucket); "⚙ " + ($command // "cmd"))
      + paint($c_dim; $suffix);

    if .type == "item.completed" then
      .item
      | if .type == "agent_message" then paint($c_assistant; "▶ " + .text)
        elif .type == "command_execution" then
          command_line(.command; " ")
          + paint(if (.exit_code // 1) == 0 then $c_success else $c_error end; "(exit " + (.exit_code | tostring) + ")")
        elif .type == "error" then paint($c_error; "⚠ " + .message)
        else empty end
    elif .type == "item.started" and .item.type == "command_execution" then
      command_line(.item.command; " …")
    elif .type == "turn.completed" then
      paint($c_success; "✓ turn done")
      + paint(
          $c_dim;
          ([
            "in " + ((.usage.input_tokens // 0) | tostring),
            "cached " + ((.usage.cached_input_tokens // 0) | tostring),
            "out " + ((.usage.output_tokens // 0) | tostring)
          ] | join(", ")) as $summary
          | " (" + $summary + ")"
        )
    else empty end
  '
local rc=$?

if [[ -s "$raw_stream_file" ]]; then
  jq -rc '
    select(.type == "turn.completed" and .usage != null) |
    {
      input_tokens: (.usage.input_tokens // 0),
      cached_input_tokens: (.usage.cached_input_tokens // 0),
      output_tokens: (.usage.output_tokens // 0),
      success: true
    }
  ' "$raw_stream_file" | tail -n 1 > "$usage_file"
fi

if [[ -s "$usage_file" ]]; then
  local usage_payload
  usage_payload=$(<"$usage_file")
  agent_usage_append_record "codex" "cxys" "$usage_payload"
fi

return $rc

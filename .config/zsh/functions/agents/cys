#!/usr/bin/env zsh
# cys: claude yolo stream - non-interactive claude with live formatted output
emulate -L zsh
setopt pipefail
setopt localtraps

local self_name="${funcstack[1]:-${${(%):-%N}:t}}"
local agent_file=
local candidate_dir
for candidate_dir in $fpath; do
  if [[ -r "$candidate_dir/$self_name" ]]; then
    agent_file="$candidate_dir/$self_name"
    break
  fi
done
[[ -n "$agent_file" ]] || agent_file="${${(%):-%N}:A}"
[[ -r "$agent_file" ]] || agent_file="${0:A}"
local agent_dir="${agent_file:A:h}"
source "$agent_dir/agent-stream-colours"
source "$agent_dir/agent-usage-log"
agent_stream_setup_colours

# -p is baked in below — strip if caller passes it redundantly (e.g. cys -p "prompt")
[[ $1 == -p ]] && { print -P "%F{yellow}[cys]%f stripping redundant '-p' (already baked in)"; shift; }

local tmp_dir="${TMPDIR:-/tmp}"
local usage_file raw_stream_file
usage_file=$(mktemp "${tmp_dir%/}/cys-usage.XXXXXX.json") || return 1
raw_stream_file=$(mktemp "${tmp_dir%/}/cys-stream.XXXXXX.jsonl") || {
  rm -f "$usage_file"
  return 1
}

TRAPEXIT() {
  rm -f "$usage_file" "$raw_stream_file"
}

claude --dangerously-skip-permissions -p --verbose --output-format stream-json "$@" 2>/dev/null \
  | tee "$raw_stream_file" \
  | jq --unbuffered -r "${AGENT_STREAM_JQ_ARGS[@]}" '
    def paint($colour; $text): $colour + $text + $c_reset;
    def usage_obj: (.usage // .message.usage // {});
    def tool_colour($name):
      if ($name // "") | test("^(Read|Glob|Grep|LS|Task)$") then $c_read
      elif ($name // "") | test("^(Edit|MultiEdit|Write|NotebookEdit)$") then $c_write
      elif ($name // "") | test("^(Web|WebFetch|Fetch|Search)$") then $c_web
      elif ($name // "") | test("^(Bash)$") then $c_shell
      else $c_agent
      end;

    if .type == "assistant" then
      .message.content[]
      | if .type == "text" then paint($c_assistant; "▶ " + .text)
        elif .type == "tool_use" then
          paint(tool_colour(.name); "⚙ " + .name)
          + paint($c_dim; " — " + ((.input | tostring)[:120]))
        else empty end
    elif .type == "result" then
      paint($c_success; "✓ done")
      + paint(
          $c_dim;
          ([
            "in " + ((usage_obj.input_tokens // 0) | tostring),
            "cached " + ((usage_obj.cache_read_input_tokens // 0) | tostring),
            "out " + ((usage_obj.output_tokens // 0) | tostring),
            (((.duration_ms // 0) / 1000 | tostring)[:5]) + "s",
            "$" + ((.total_cost_usd | tostring)[:6])
          ] | join(", ")) as $summary
          | " (" + $summary + ")"
        )
    else empty end
  '
local rc=$?

if [[ -s "$raw_stream_file" ]]; then
  jq -rc '
    select(.type == "result")
    | (.usage // .message.usage // {}) as $usage
    | {
        input_tokens: ($usage.input_tokens // 0),
        cached_input_tokens: ($usage.cache_read_input_tokens // 0),
        output_tokens: ($usage.output_tokens // 0),
        duration_ms: (.duration_ms // 0),
        total_cost_usd: .total_cost_usd,
        success: (if (.is_error // false) or ((.subtype // "success") != "success") then false else true end)
      }
  ' "$raw_stream_file" | tail -n 1 > "$usage_file"
fi

if [[ -s "$usage_file" ]]; then
  local usage_payload
  usage_payload=$(<"$usage_file")
  agent_usage_append_record "claude" "cys" "$usage_payload"
fi

return $rc

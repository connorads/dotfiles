#!/usr/bin/env zsh
# rl: ralph loop - run a command in a naive loop
emulate -L zsh
setopt localtraps
setopt trapsasync
setopt no_monitor 2>/dev/null  # suppress [N] job notifications if possible
zmodload zsh/datetime

# Parse: rl [max] [-t timeout] [--promise-token token | --no-promise-token] -- <command...>
local max=0
local timeout_secs=0
local promise_token="__PROMISE_RL_DONE__"
if [[ $1 =~ ^[0-9]+$ ]]; then
  max=$1; shift
fi
while [[ $1 == -* && $1 != "--" ]]; do
  case $1 in
    -t|--timeout)
      shift
      local raw=$1; shift
      case $raw in
        *h) timeout_secs=$(( ${raw%h} * 3600 )) ;;
        *m) timeout_secs=$(( ${raw%m} * 60 )) ;;
        *s) timeout_secs=${raw%s} ;;
        *)  timeout_secs=$raw ;;
      esac
      ;;
    --promise-token)
      shift
      promise_token=$1; shift
      ;;
    --no-promise-token)
      promise_token=
      shift
      ;;
    *) print -P "%F{red}[rl]%f unknown option: $1"; return 1 ;;
  esac
done
if [[ $1 != "--" ]]; then
  print 'rl - ralph loop: run a command in a naive loop

Usage: rl [max] [-t timeout] [--promise-token token | --no-promise-token] -- <command...>

  max       Optional max iterations (default: unlimited, Ctrl+C once to stop, twice within 2s+ to force-stop)
  -t, --timeout DURATION  Kill iteration if it exceeds DURATION (e.g. 30m, 2h, 90s, 90)
  --promise-token TOKEN   Override the default promise token / completion promise (__PROMISE_RL_DONE__ on its own final line)
  --no-promise-token      Disable promise-token detection for this run
  --        Separator (required)

Examples:
  rl -- claude -p "Follow the session protocol in CLAUDE.md"
  rl 10 -- claude -p --verbose "Fix the next backlog item"
  rl 5 -- claude -p --dangerously-skip-permissions "Run the sweep"
  rl -- codex exec "Follow the session protocol in AGENTS.md"
  rl 10 -- codex exec --full-auto "Fix the next backlog item"
  rl -- cys "Read and follow TASKS/demo/PROMPT.md"
  rl --no-promise-token -- cargo test
  rl 36 -t 30m -- cys "One task per run"
  rl -- cargo test'
  return 1
fi
shift  # consume --

# Resolve aliases from interactive shell (script mode doesn't load them)
local expanded
expanded=$(zsh -ic "whence $1" 2>/dev/null)
if [[ -n $expanded && $expanded != "$1" ]]; then
  shift
  set -- ${=expanded} "$@"
fi

local i=0
local rc=0
local stop_requested=0
local force_stop_requested=0
local child_wait_interrupted=0
local child_pid=
local child_pgid=
local pause_pid=
local phase=idle
local first_int_at=0
local promise_stop_requested=0

debug_log() {
  (( ${RL_DEBUG:-0} )) || return 0
  print -u2 -r -- "[rl-debug] $*"
}

start_child() {
  local parent_pid=$$

  if command -v setsid >/dev/null 2>&1; then
    setsid --wait -- zsh -c '
      emulate -L zsh
      local parent_pid=$1
      shift

      if command -v perl >/dev/null 2>&1; then
        perl -MPOSIX=setsid -e '"'"'
          POSIX::setsid();
          my ($parent_pid, $target_pgid, $leader_pid) = @ARGV;
          while (kill 0, $leader_pid) {
            unless (kill 0, $parent_pid) {
              kill 15, -$target_pgid;
              select undef, undef, undef, 0.1;
              kill 9, -$target_pgid;
              exit 0;
            }
            select undef, undef, undef, 0.05;
          }
        '"'"' -- "$parent_pid" "$$" "$$" </dev/null >/dev/null 2>&1 &
        sleep 0.05
      fi

      exec "$@"
    ' _ "$parent_pid" "$@" &
    return 0
  fi

  perl -MPOSIX=setsid,getpgrp -e '
    my $parent_pid = shift @ARGV;
    POSIX::setsid() or die "setsid failed\n";
    my $leader_pid = $$;
    my $target_pgid = POSIX::getpgrp();
    my $watchdog = fork();
    die "fork failed\n" unless defined $watchdog;

    if ($watchdog == 0) {
      POSIX::setsid();
      while (kill 0, $leader_pid) {
        unless (kill 0, $parent_pid) {
          # macOS can leave the iteration tree running after rl exits on a
          # second Ctrl+C, so the detached watchdog kills the whole process
          # group once the parent loop disappears.
          kill 15, -$target_pgid;
          select undef, undef, undef, 0.1;
          kill 9, -$target_pgid;
          exit 0;
        }
        select undef, undef, undef, 0.05;
      }
      exit 0;
    }

    exec @ARGV or die "exec failed\n";
  ' -- "$parent_pid" "$@" &
}

start_child_pty() {
  start_child python3 -c '
import os
import pty
import sys

argv = sys.argv[1:]
if not argv:
    raise SystemExit(1)

status = pty.spawn(argv)
raise SystemExit(os.waitstatus_to_exitcode(status))
  ' "$@"
}

pty_supported() {
  [[ -t 1 ]] || return 1
  command -v python3 >/dev/null 2>&1 || return 1
}

refresh_child_pgid() {
  local attempt

  child_pgid=
  [[ -z $child_pid ]] && return 0

  for (( attempt = 1; attempt <= 20; attempt++ )); do
    child_pgid=$(ps -o pgid= -p $child_pid 2>/dev/null | tr -d ' ')
    [[ -n $child_pgid ]] && return 0
    sleep 0.05
  done
}

TRAPINT() {
  if (( stop_requested )); then
    local elapsed=$(( EPOCHSECONDS - first_int_at ))
    if (( elapsed < 2 )); then
      debug_log "ignoring Ctrl+C during ${elapsed}s cooldown (need 2s)"
      print -P "\n%F{yellow}[rl]%f hold on — wait 2s after first Ctrl+C to force-stop"
      child_wait_interrupted=1
      return 0
    fi
    force_stop_requested=1
    print -P "\n%F{red}[rl]%f force stopping"
    [[ -n $pause_pid ]] && kill $pause_pid 2>/dev/null
    child_wait_interrupted=1
    return 0
  fi

  stop_requested=1
  first_int_at=$EPOCHSECONDS
  case $phase in
    child)
      child_wait_interrupted=1
      print -P "\n%F{yellow}[rl]%f stopping after current iteration (Ctrl+C again to force)"
      ;;
    pause)
      print -P "\n%F{yellow}[rl]%f stopping before next iteration (Ctrl+C again to force)"
      [[ -n $pause_pid ]] && kill $pause_pid 2>/dev/null
      ;;
    *)
      print -P "\n%F{yellow}[rl]%f stopping before next iteration (Ctrl+C again to force)"
      ;;
  esac

  return 0
}

export RL_SESSION="$$:$EPOCHSECONDS"

while (( max == 0 || i < max )); do
  (( stop_requested )) && break
  (( i++ ))
  print -P "%F{cyan}[rl]%f iteration $i${max:+/$max}: $*"
  phase=child
  local promise_marker=
  local output_fifo=
  local output_scanner_pid=
  local use_pty=0
  if [[ -n $promise_token ]]; then
    promise_marker="${TMPDIR:-/tmp}/rl-promise-$$-$i"
    output_fifo="${TMPDIR:-/tmp}/rl-output-$$-$i.fifo"
    rm -f "$promise_marker" "$output_fifo"
    mkfifo "$output_fifo" || return 1
    pty_supported && use_pty=1
    PROMISE_TOKEN="$promise_token" PROMISE_MARKER="$promise_marker" perl -ne '
      our $last_nonempty;
      print $_;
      my $clean = $_;
      $clean =~ s/\e\[[0-9;?]*[ -\/]*[@-~]//g;
      $clean =~ s/\r//g;
      for my $line (split /\n/, $clean) {
        if ($line =~ /\S/) {
          $last_nonempty = $line;
        }
      }
      END {
        if (defined $last_nonempty && $last_nonempty eq $ENV{PROMISE_TOKEN}) {
        open my $fh, ">>", $ENV{PROMISE_MARKER} or die $!;
        close $fh;
      }
      }
    ' < "$output_fifo" &
    output_scanner_pid=$!
    if (( use_pty )); then
      start_child_pty "$@" > "$output_fifo" 2>&1
    else
      start_child "$@" > "$output_fifo" 2>&1
    fi
  else
    start_child "$@"
  fi
  child_pid=$!
  refresh_child_pgid
  local timeout_pid=
  local timeout_sleep_pid=
  local timed_out=0
  local timeout_marker="${TMPDIR:-/tmp}/rl-timeout-$$-$i"
  if (( timeout_secs > 0 && child_pgid )); then
    # Watchdog: sleep then kill child process group. Track inner sleep PID for cleanup.
    local sleep_pid_file="${TMPDIR:-/tmp}/rl-timeout-sleep-$$-$i"
    (
      sleep "$timeout_secs" &
      echo $! > "$sleep_pid_file"
      wait $!
      touch "$timeout_marker"
      kill -TERM -"$child_pgid" 2>/dev/null
      sleep 0.1
      kill -KILL -"$child_pgid" 2>/dev/null
    ) &
    timeout_pid=$!
    # Wait briefly for the sleep PID file to be written
    local _w; for _w in {1..10}; do [[ -f $sleep_pid_file ]] && break; sleep 0.01; done
    timeout_sleep_pid=$(cat "$sleep_pid_file" 2>/dev/null)
    rm -f "$sleep_pid_file"
  fi
  while true; do
    wait $child_pid
    rc=$?
    # Ctrl+C interrupts wait in the parent shell, not the backgrounded child.
    if (( force_stop_requested )); then
      if [[ -n $child_pgid ]]; then
        kill -TERM -"$child_pgid" 2>/dev/null
        sleep 0.1
        kill -KILL -"$child_pgid" 2>/dev/null
      fi
      rc=130
      break
    fi

    if (( child_wait_interrupted )); then
      print -P "%F{cyan}[rl]%f waiting for iteration $i to finish..."
      child_wait_interrupted=0
      continue
    fi

    break
  done
  if [[ -n $timeout_pid ]]; then
    [[ -n $timeout_sleep_pid ]] && kill "$timeout_sleep_pid" 2>/dev/null
    kill "$timeout_pid" 2>/dev/null
    wait "$timeout_pid" 2>/dev/null || true
    if [[ -f $timeout_marker ]]; then
      timed_out=1
      rm -f "$timeout_marker"
    fi
  fi
  if [[ -n $output_scanner_pid ]]; then
    wait "$output_scanner_pid" 2>/dev/null || true
    rm -f "$output_fifo"
  fi
  phase=idle
  if (( timed_out )); then
    print -P "%F{yellow}[rl]%f iteration $i timed out after ${timeout_secs}s"
  else
    print -P "%F{cyan}[rl]%f iteration $i done (exit $rc)"
  fi
  if [[ -n $promise_marker && -f $promise_marker ]]; then
    rm -f "$promise_marker"
    if (( rc == 0 && !timed_out && !force_stop_requested )); then
      promise_stop_requested=1
      print -P "%F{green}[rl]%f promise token seen (completion promise); stopping after iteration $i"
    fi
  fi
  (( stop_requested || force_stop_requested || promise_stop_requested )) && break
  child_pid=
  child_pgid=
  child_wait_interrupted=0
  if (( rc != 0 )); then
    print -P "%F{yellow}[rl]%f non-zero exit, pausing 5s..."
    phase=pause
    sleep 5 &
    pause_pid=$!
    wait $pause_pid
    pause_pid=
    phase=idle
    (( stop_requested )) && break
  fi
done

if (( stop_requested )); then
  print -P "%F{yellow}[rl]%f stopped after $i iterations"
  return 130
else
  print -P "%F{green}[rl]%f finished after $i iterations"
fi

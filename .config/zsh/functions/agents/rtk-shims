#!/usr/bin/env zsh
# rtk-shims: manage RTK agent shims in ~/.local/lib/rtk-shims/
# Shims intercept commands in agent contexts, delegating to rtk for token reduction.
# In interactive shells, they pass through to the real command (~1ms overhead).
#
# Subcommands:
#   rtk-shims sync    create/update shims + README (default)
#   rtk-shims list    show current shims with status
#   rtk-shims clean   remove all shims and the directory
emulate -L zsh

local verbose=0 dry_run=0
local subcommand=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -v|--verbose) verbose=1; shift ;;
    -n|--dry-run) dry_run=1; verbose=1; shift ;;
    -h|--help)
      cat <<'EOF'
Usage: rtk-shims [sync|list|clean] [-v|--verbose] [-n|--dry-run]

Subcommands:
  sync    create/update shims + README (default)
  list    show current shims with status
  clean   remove all shims and the directory
EOF
      return 0
      ;;
    sync|list|clean)
      subcommand="$1"; shift ;;
    *)
      print -u2 "Unknown option: $1"; return 1 ;;
  esac
done

[[ -z "$subcommand" ]] && subcommand="sync"

local shim_dir="$HOME/.local/lib/rtk-shims"
local shim_source="$HOME/.config/zsh/functions/agents/.rtk-shim"

# Full command list from RTK src/discover/rules.rs (v0.31.0)
local -a RTK_COMMANDS=(
  git gh cargo pnpm npm npx cat rg grep ls find tsc eslint biome prettier
  vitest jest playwright prisma docker kubectl tree diff curl wget mypy ruff pytest
  pip pip3 uv go golangci golangci-lint aws psql ansible-playbook brew composer df
  dotnet du fail2ban-client gcloud hadolint helm iptables make markdownlint mix mvn
  ping pio poetry pre-commit ps quarto rsync shellcheck shopify sops swift systemctl
  terraform tofu trunk yamllint next
)

_rtk_sync() {
  local created=0 removed=0 unchanged=0

  if (( ! dry_run )); then
    command mkdir -p "$shim_dir"
  fi

  # Ensure .rtk-shim symlink exists
  local shim_link="$shim_dir/.rtk-shim"
  if [[ -L "$shim_link" ]] && [[ "$(readlink "$shim_link")" == "$shim_source" ]]; then
    (( verbose )) && echo "Unchanged: $shim_link"
  elif (( ! dry_run )); then
    command ln -sf "$shim_source" "$shim_link"
    (( verbose )) && echo "Creating: $shim_link -> $shim_source"
  else
    (( verbose )) && echo "Would create: $shim_link -> $shim_source"
  fi

  # Create command symlinks (relative, pointing to .rtk-shim in same dir)
  local cmd dest
  for cmd in "${RTK_COMMANDS[@]}"; do
    dest="$shim_dir/$cmd"
    if [[ -L "$dest" ]] && [[ "$(readlink "$dest")" == ".rtk-shim" ]]; then
      (( verbose )) && echo "Unchanged: $cmd"
      (( unchanged++ ))
      continue
    fi
    (( verbose )) && echo "Creating: $cmd -> .rtk-shim"
    if (( ! dry_run )); then
      command ln -sf ".rtk-shim" "$dest"
    fi
    (( created++ ))
  done

  # Remove stale symlinks (commands no longer in the list)
  local -A expected
  for cmd in "${RTK_COMMANDS[@]}"; do
    expected[$cmd]=1
  done

  local link name
  for link in "$shim_dir"/*(N); do
    name="${link:t}"
    [[ "$name" == .rtk-shim || "$name" == README.md ]] && continue
    if [[ -z "${expected[$name]+x}" ]]; then
      (( verbose )) && echo "Removing stale: $name"
      if (( ! dry_run )); then
        command rm "$link"
      fi
      (( removed++ ))
    fi
  done

  # Generate README
  if (( ! dry_run )); then
    cat > "$shim_dir/README.md" <<'READMEEOF'
# RTK Agent Shims

Auto-generated by `rtk-shims sync`. Do not edit manually.

These symlinks intercept commands when running inside a coding agent,
delegating to [RTK](https://github.com/rtk-ai/rtk) for 60-90% token
reduction. In interactive shells, they pass through with ~1ms overhead.

## Agent detection env vars

| Variable | Source |
|----------|--------|
| `CLAUDECODE` | Claude Code |
| `AGENT` | Goose, Amp, Bun |
| `AI_AGENT` | Vercel |
| `COPILOT_CLI` | GitHub Copilot CLI |
| `GEMINI_CLI` | Gemini CLI |
| `RTK_AGENT` | Manual opt-in |

## Management

```bash
rtk-shims sync    # create/update shims (default)
rtk-shims list    # show shims with status
rtk-shims clean   # remove everything
```
READMEEOF
  fi

  echo "Created $created, removed $removed, unchanged $unchanged"
}

_rtk_list() {
  if [[ ! -d "$shim_dir" ]]; then
    echo "No shims directory at $shim_dir"
    echo "Run: rtk-shims sync"
    return 0
  fi

  local -a present missing
  local cmd
  for cmd in "${RTK_COMMANDS[@]}"; do
    if [[ -L "$shim_dir/$cmd" ]]; then
      present+=("$cmd")
    else
      missing+=("$cmd")
    fi
  done

  echo "Shim directory: $shim_dir"
  echo "Present: ${#present} / ${#RTK_COMMANDS}"
  if (( ${#missing} > 0 )); then
    echo "Missing: ${(j:, :)missing}"
  fi

  # Check for stale shims
  local -A expected
  for cmd in "${RTK_COMMANDS[@]}"; do
    expected[$cmd]=1
  done
  local -a stale
  local link name
  for link in "$shim_dir"/*(N); do
    name="${link:t}"
    [[ "$name" == .rtk-shim || "$name" == README.md ]] && continue
    [[ -z "${expected[$name]+x}" ]] && stale+=("$name")
  done
  if (( ${#stale} > 0 )); then
    echo "Stale: ${(j:, :)stale}"
  fi
}

_rtk_clean() {
  if [[ ! -d "$shim_dir" ]]; then
    echo "Nothing to clean"
    return 0
  fi

  if (( dry_run )); then
    echo "Would remove: $shim_dir"
  else
    command rm -rf "$shim_dir"
    echo "Removed $shim_dir"
  fi
}

case "$subcommand" in
  sync)  _rtk_sync ;;
  list)  _rtk_list ;;
  clean) _rtk_clean ;;
esac

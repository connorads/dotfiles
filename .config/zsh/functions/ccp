#!/usr/bin/env zsh
# ccp: launch Claude Code under a chosen account.
# "default" = the plain ~/.claude account; any other name = an isolated
# ~/.claude-profiles/code/<name> profile (via claude-code-profile, which scrubs
# ambient auth-override env vars). Private 2-char aliases live in ~/.zshrc.local.
emulate -L zsh
setopt pipefail

_ccp_usage() {
    print -u2 "usage: ccp [-y|--yolo] [<name>|default] [claude-args...]"
}

local root="$HOME/.claude-profiles/code"
local choice
# Flags injected ahead of the user's claude-args. -y mirrors the `cy` alias:
# the git-policy system prompt plus --dangerously-skip-permissions.
local -a inject

# Leading flags own the front of the arg list; everything after the account
# name forwards to claude untouched.
while [[ "${1:-}" == -* ]]; do
    case "$1" in
        -h|--help)
            _ccp_usage
            return 0
            ;;
        -y|--yolo)
            inject=(
                --append-system-prompt-file "$HOME/.claude/system-append.md"
                --dangerously-skip-permissions
            )
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
            break
            ;;
    esac
done

if [[ -z "${1:-}" ]]; then
    # No account given: pick from default + discovered profiles via fzf.
    if ! command -v fzf &>/dev/null; then
        print -u2 "ccp: no account given and fzf is unavailable"
        _ccp_usage
        return 2
    fi
    local -a profiles
    local prof_dir
    for prof_dir in "$root"/*(/N); do
        profiles+=("${prof_dir:t}")
    done
    choice=$(print -rl -- default "${profiles[@]}" |
        fzf --prompt="claude account> " --height 40% --no-multi) || return 130
    [[ -n "$choice" ]] || return 130
else
    choice="$1"
    shift
fi

# "default" is the plain ~/.claude config - no profile isolation, ambient env as-is.
if [[ "$choice" == "default" ]]; then
    claude "${inject[@]}" "$@"
    return
fi

# Delegate name validation + auth scrubbing to claude-code-profile.
claude-code-profile "$choice" "${inject[@]}" "$@"

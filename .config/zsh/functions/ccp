#!/usr/bin/env zsh
# ccp: launch Claude Code under a chosen account.
# "default" = the plain ~/.claude account; any other name = an isolated
# ~/.claude-profiles/code/<name> profile (via claude-code-profile, which scrubs
# ambient auth-override env vars). Private 2-char aliases live in ~/.zshrc.local.
emulate -L zsh
setopt pipefail

_ccp_usage() {
    print -u2 "usage: ccp [-y|--yolo] [--mcp <bundle>] [<name>|default] [claude-args...]"
}

local root="$HOME/.claude-profiles/code"
local choice
local yolo=""
local mcp_bundle=""

# Leading flags own the front of the arg list; everything after the account
# name forwards to claude untouched.
while [[ "${1:-}" == -* ]]; do
    case "$1" in
        -h|--help)
            _ccp_usage
            return 0
            ;;
        -y|--yolo)
            yolo=1
            shift
            ;;
        --mcp)
            mcp_bundle="${2:-}"
            [[ -n "$mcp_bundle" ]] || { print -u2 "ccp: --mcp needs a bundle"; return 2 }
            shift 2
            ;;
        --)
            shift
            break
            ;;
        *)
            break
            ;;
    esac
done

# Flags injected ahead of the user's claude-args, from the shared owner - ccp
# launches are interactive, mirroring the `c` alias (append), and -y adds
# skip-permissions on top, mirroring `cy`. zsh word-splits the substitution.
local -a inject
inject=( $(claude-launch-flags ${yolo:+--yolo}) )

if [[ -z "${1:-}" ]]; then
    # No account given: pick from default + discovered profiles via fzf.
    if ! command -v fzf &>/dev/null; then
        print -u2 "ccp: no account given and fzf is unavailable"
        _ccp_usage
        return 2
    fi
    local -a profiles
    local prof_dir
    for prof_dir in "$root"/*(/N); do
        profiles+=("${prof_dir:t}")
    done
    choice=$(print -rl -- default "${profiles[@]}" |
        fzf --prompt="claude account> " --height 40% --no-multi) || return 130
    [[ -n "$choice" ]] || return 130
else
    choice="$1"
    shift
fi

# --mcp may also follow the account name (`ccp <acct> --mcp <bundle>`), the shape
# the tmux launcher and the human aliases use. Consume it here too; a bare `--`
# ends ccp option parsing, and any other flag (e.g. --model) forwards untouched.
while [[ "${1:-}" == -* ]]; do
    case "$1" in
        --mcp)
            mcp_bundle="${2:-}"
            [[ -n "$mcp_bundle" ]] || { print -u2 "ccp: --mcp needs a bundle"; return 2 }
            shift 2
            ;;
        --)
            shift
            break
            ;;
        *)
            break
            ;;
    esac
done

# --mcp delegates the terminal claude exec to `mcpz run claude <bundle>`, which
# adds the inline --mcp-config/--strict-mcp-config and resolves secrets fresh.
# ccp keeps owning account isolation; an unknown bundle makes mcpz exit 2.

# "default" is the plain ~/.claude config - no profile isolation, ambient env as-is.
if [[ "$choice" == "default" ]]; then
    if [[ -n "$mcp_bundle" ]]; then
        mcpz run claude "$mcp_bundle" -- "${inject[@]}" "$@"
    else
        claude "${inject[@]}" "$@"
    fi
    return
fi

# Delegate name validation + auth scrubbing to claude-code-profile; pass the
# bundle through so it runs mcpz under the scrubbed, relocated env.
local -a mcp_flag=()
[[ -n "$mcp_bundle" ]] && mcp_flag=(--mcp "$mcp_bundle")
claude-code-profile "${mcp_flag[@]}" "$choice" "${inject[@]}" "$@"

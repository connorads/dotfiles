#!/usr/bin/env zsh
# claude-code-profile: launch Claude Code with an isolated config directory.
emulate -L zsh
setopt pipefail

_claude_code_profile_usage() {
    print -u2 "usage: claude-code-profile [--mcp <bundle>] <name> [claude-args...]"
}

local mcp_bundle=""

# Leading flags mirror ccp's; everything from the name onward is the account
# plus claude-args.
while [[ "${1:-}" == -* ]]; do
    case "$1" in
        -h|--help)
            _claude_code_profile_usage
            return 0
            ;;
        --mcp)
            mcp_bundle="${2:-}"
            [[ -n "$mcp_bundle" ]] || { print -u2 "claude-code-profile: --mcp needs a bundle"; return 2 }
            shift 2
            ;;
        --)
            shift
            break
            ;;
        *)
            break
            ;;
    esac
done

local name="${1:-}"
if [[ -z "$name" ]]; then
    _claude_code_profile_usage
    return 2
fi
shift

if [[ ! "$name" =~ '^[A-Za-z0-9][A-Za-z0-9._-]*$' ]]; then
    print -u2 "claude-code-profile: profile name must match [A-Za-z0-9][A-Za-z0-9._-]*"
    return 2
fi

local root="$HOME/.claude-profiles/code"
local profile_dir="$root/$name"

mkdir -p "$profile_dir" || return
chmod 700 "$HOME/.claude-profiles" "$root" "$profile_dir" 2>/dev/null || true

# CLAUDE_CONFIG_DIR fully relocates the user scope, so an isolated profile never
# reads shared ~/.claude config. Materialise it into the profile so statusLine,
# hooks, env, permissions and CLAUDE.md memory apply to every account. Bare-name
# call resolves via ~/.local/bin (same convention ccp uses to call this).
claude-profile-materialise "$profile_dir"

# Claude Code auth precedence lets ambient env vars override subscription OAuth.
# Make profile selection explicit and avoid silently billing an unrelated API key.
# With --mcp, mcpz runs inside the scrubbed+relocated env: it resolves secrets,
# then execs claude, which inherits the scrub, CLAUDE_CONFIG_DIR and secret vars.
# --strict-mcp-config keeps the inline bundle authoritative, so it never conflicts
# with the materialised settings.json (which never writes MCP config).
if [[ -n "$mcp_bundle" ]]; then
    env \
        -u ANTHROPIC_API_KEY \
        -u ANTHROPIC_AUTH_TOKEN \
        -u CLAUDE_CODE_OAUTH_TOKEN \
        -u CLAUDE_CODE_USE_BEDROCK \
        -u CLAUDE_CODE_USE_VERTEX \
        -u CLAUDE_CODE_USE_FOUNDRY \
        CLAUDE_CONFIG_DIR="$profile_dir" \
        mcpz run claude "$mcp_bundle" -- "$@"
else
    env \
        -u ANTHROPIC_API_KEY \
        -u ANTHROPIC_AUTH_TOKEN \
        -u CLAUDE_CODE_OAUTH_TOKEN \
        -u CLAUDE_CODE_USE_BEDROCK \
        -u CLAUDE_CODE_USE_VERTEX \
        -u CLAUDE_CODE_USE_FOUNDRY \
        CLAUDE_CONFIG_DIR="$profile_dir" \
        claude "$@"
fi

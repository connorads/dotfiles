#!/usr/bin/env zsh
# claude-usage: Show Claude API usage limits with cache/backoff protection
# Usage: claude-usage [-h|--help]
emulate -L zsh
setopt pipefail

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: claude-usage [-h|--help]"
    echo
    echo "Shows Claude API usage limits (5-hour and 7-day windows)"
    echo "Uses cache + retry backoff to avoid API hammering"
    echo
    echo "If not logged in:"
    echo "  - In Claude CLI: /login"
    echo "  - In terminal: claude setup-token"
    return 0
fi

local cache="$HOME/.cache/claude-usage.json"
local meta="$HOME/.cache/claude-usage.meta.json"
local lockdir="$HOME/.cache/claude-usage.lock"
local ttl=300
local lock_stale_after=600
local backoff_base=120
local backoff_max=1800
local now age next_retry fail_count last_success
local hdr="" body=""
now=$(date +%s)

# Resolve this function file's directory (autoload, ~/.local/bin symlink, or
# direct run) so the shared cache/lock/backoff engine sources cleanly. Mirrors
# the agent-usage-log idiom used by pis/cys.
local self_name="${funcstack[1]:-${${(%):-%N}:t}}"
local self_file= candidate_dir
for candidate_dir in $fpath; do
    [[ -r "$candidate_dir/$self_name" ]] && { self_file="$candidate_dir/$self_name"; break }
done
[[ -n "$self_file" ]] || self_file="${${(%):-%N}:A}"
[[ -r "$self_file" ]] || self_file="${0:A}"
source "${self_file:A:h}/usage-cache-lib"

if [[ ! -f "$meta" ]]; then
    _write_meta 0 0 "" "" 0
fi

next_retry=$(jq -r '.next_retry_at // 0' "$meta" 2>/dev/null || echo 0)
fail_count=$(jq -r '.fail_count // 0' "$meta" 2>/dev/null || echo 0)
last_success=$(jq -r '.last_success_at // 0' "$meta" 2>/dev/null || echo 0)
age=$(_cache_age "$cache")

local should_fetch=0
if [[ ! -f "$cache" ]]; then
    [[ "$now" -ge "$next_retry" ]] && should_fetch=1
elif [[ "$age" -ge "$ttl" && "$now" -ge "$next_retry" ]]; then
    should_fetch=1
fi

if [[ "$should_fetch" -eq 1 ]] && _acquire_lock; then
    trap _cleanup EXIT INT TERM HUP

    # Keychain-first on macOS, but fall back to the file store: recent Claude
    # Code keeps credentials in ~/.claude/.credentials.json and leaves the
    # keychain item empty, so an empty keychain read must not mean "logged out".
    local token=""
    if [[ "$OSTYPE" == darwin* ]] && command -v security &>/dev/null; then
        token=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null | jq -r '.claudeAiOauth.accessToken // empty' 2>/dev/null)
    fi
    if [[ -z "$token" && -f "$HOME/.claude/.credentials.json" ]]; then
        token=$(jq -r '.claudeAiOauth.accessToken // empty' "$HOME/.claude/.credentials.json" 2>/dev/null)
    fi

    if [[ -z "$token" ]]; then
        _cleanup
        trap - EXIT INT TERM HUP
        echo "Not logged in"
        echo
        echo "To login:"
        echo "  - In Claude CLI: /login"
        echo "  - In terminal: claude setup-token"
        return 1
    fi

    local claude_ver http_code retry_after resp err
    claude_ver=$(claude --version 2>/dev/null | awk '{print $1}')
    hdr=$(mktemp)
    body=$(mktemp)

    if curl -sS --max-time 8 \
        -D "$hdr" \
        -o "$body" \
        "https://api.anthropic.com/api/oauth/usage" \
        -H "Authorization: Bearer $token" \
        -H "anthropic-beta: oauth-2025-04-20" \
        -H "User-Agent: claude-code/${claude_ver:-unknown}"; then
        http_code=$(awk 'BEGIN{IGNORECASE=1} /^HTTP/{code=$2} END{print code+0}' "$hdr")
        retry_after=$(awk 'BEGIN{IGNORECASE=1} /^retry-after:/ {print $2; exit}' "$hdr" | tr -d '\r')
        resp=$(<"$body")

        if [[ "$http_code" -eq 200 ]] && jq -e '.five_hour' "$body" >/dev/null 2>&1; then
            mkdir -p "$(dirname "$cache")"
            print -r -- "$resp" > "${cache}.tmp.$$"
            mv "${cache}.tmp.$$" "$cache"
            _write_meta 0 0 "$http_code" "" "$now"
            age=0
        else
            err=$(jq -r '.error.message? // .message? // "fetch_failed"' "$body" 2>/dev/null)
            _record_failure "$fail_count" "$retry_after" "${http_code:-0}" "$err" "$last_success"
        fi
    else
        _record_failure "$fail_count" "" "0" "network_error" "$last_success"
    fi

    _cleanup
    trap - EXIT INT TERM HUP
fi

if [[ ! -f "$cache" ]]; then
    next_retry=$(jq -r '.next_retry_at // 0' "$meta" 2>/dev/null || echo 0)
    if [[ "$next_retry" -gt "$now" ]]; then
        echo "Usage refresh paused for $(_fmt_secs $((next_retry - now)))"
    else
        echo "Failed to fetch usage data"
    fi
    echo
    echo "Possible causes:"
    echo "  - Not logged in (try /login in Claude CLI)"
    echo "  - Network error"
    echo "  - API temporarily unavailable"
    return 1
fi

age=$(_cache_age "$cache")
local cache_stale=0
[[ "$age" -ge "$ttl" ]] && cache_stale=1

local u5 u7 r5 r7
u5=$(jq -r '.five_hour.utilization // 0' "$cache")
u7=$(jq -r '.seven_day.utilization // 0' "$cache")
r5=$(jq -r '.five_hour.resets_at // empty' "$cache")
r7=$(jq -r '.seven_day.resets_at // empty' "$cache")

_remaining() {
    local reset_iso="$1"
    [[ -z "$reset_iso" ]] && { print -r -- "-"; return; }
    local normalised ts
    normalised=$(printf '%s\n' "$reset_iso" | sed -E 's/\.[0-9]+//; s/Z$/+0000/; s/([+-][0-9]{2}):([0-9]{2})$/\1\2/')
    ts=$(date -d "$reset_iso" +%s 2>/dev/null || date -j -f "%Y-%m-%dT%H:%M:%S%z" "$normalised" +%s 2>/dev/null)
    [[ -z "$ts" ]] && { print -r -- "-"; return; }
    local diff=$((ts - now))
    if [[ "$diff" -le 0 ]]; then
        [[ "$cache_stale" -eq 1 ]] && { echo "__STALE__"; return; }
        echo "0h 0m"
        return
    fi
    _fmt_secs "$diff"
}

_print_window() {
    local label="$1"
    local usage="$2"
    local remaining="$3"
    if [[ "$remaining" == "__STALE__" ]]; then
        printf "%-9s %3.0f%%  cache stale\n" "$label" "$usage"
        return
    fi
    printf "%-9s %3.0f%%  resets in %s\n" "$label" "$usage" "$remaining"
}

_print_window "5-hour:" "$u5" "$(_remaining "$r5")"
_print_window "7-day:" "$u7" "$(_remaining "$r7")"

# Sonnet-only window (shown when present)
local us rs
us=$(jq -r '.seven_day_sonnet.utilization // empty' "$cache")
rs=$(jq -r '.seven_day_sonnet.resets_at // empty' "$cache")
[[ -n "$us" ]] && _print_window "Sonnet:" "$us" "$(_remaining "$rs")"

# Extra usage (spend-based, not time-windowed)
local ex_enabled ex_limit ex_used
ex_enabled=$(jq -r '.extra_usage.is_enabled // empty' "$cache")
if [[ -n "$ex_enabled" ]]; then
    ex_limit=$(jq -r '.extra_usage.monthly_limit // 0' "$cache")
    ex_used=$(jq -r '.extra_usage.used_credits // 0' "$cache")
    local limit_fmt used_fmt status_label
    limit_fmt=$(printf "%.2f" "$((ex_limit))e-2")
    used_fmt=$(printf "%.2f" "${ex_used}e-2")
    if [[ "$ex_enabled" == "true" ]]; then
        status_label="enabled"
    else
        status_label="disabled"
    fi
    printf "%-9s %s/%s  (%s)\n" "Extra:" "$used_fmt" "$limit_fmt" "$status_label"
fi

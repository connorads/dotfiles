#!/usr/bin/env zsh
# claude-usage: Show Claude API usage limits with cache/backoff protection
# Usage: claude-usage [-h|--help]
emulate -L zsh
setopt pipefail

local profile="" all=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            cat <<'EOF'
Usage: claude-usage [--profile <name>] [--all] [-h|--help]

Shows Claude API usage limits (5-hour and 7-day windows)
Uses cache + retry backoff to avoid API hammering

  --profile <name>  Read the ~/.claude-profiles/code/<name> account instead of
                    the default ~/.claude account
  --all             Refresh the default account plus every profile in parallel

If not logged in:
  - In Claude CLI: /login
  - In terminal: claude setup-token
EOF
            return 0
            ;;
        --all)
            all=1
            shift
            ;;
        --profile)
            profile="${2:-}"
            shift 2
            ;;
        --profile=*)
            profile="${1#--profile=}"
            shift
            ;;
        *)
            print -u2 "claude-usage: unknown option: $1"
            return 2
            ;;
    esac
done

if [[ -n "$profile" && ! "$profile" =~ '^[A-Za-z0-9][A-Za-z0-9._-]*$' ]]; then
    print -u2 "claude-usage: profile name must match [A-Za-z0-9][A-Za-z0-9._-]*"
    return 2
fi

# Resolve this function file's directory (autoload, ~/.local/bin symlink, or
# direct run) so the shared cache/lock/backoff engine sources cleanly and --all
# can re-invoke this script per account. Mirrors the agent-usage-log idiom.
local self_name="${funcstack[1]:-${${(%):-%N}:t}}"
local self_file= candidate_dir
for candidate_dir in $fpath; do
    [[ -r "$candidate_dir/$self_name" ]] && { self_file="$candidate_dir/$self_name"; break }
done
[[ -n "$self_file" ]] || self_file="${${(%):-%N}:A}"
[[ -r "$self_file" ]] || self_file="${0:A}"

if [[ "$all" -eq 1 ]]; then
    # Refresh the default account plus every discovered profile, each in its own
    # process so the shared lock/backoff engine keys off that account's own
    # cache. Not-logged-in profiles fail quietly (output discarded).
    zsh "$self_file" >/dev/null 2>&1 &
    local prof_dir
    for prof_dir in "$HOME/.claude-profiles/code"/*(/N); do
        zsh "$self_file" --profile "${prof_dir:t}" >/dev/null 2>&1 &
    done
    wait
    return 0
fi

# Per-account paths. The default account is CLAUDE_CONFIG_DIR-less (~/.claude,
# un-suffixed keychain service); a profile lives under ~/.claude-profiles/code
# and its keychain item is namespaced by an 8-char hash of its config dir - the
# same scheme Claude Code uses when CLAUDE_CONFIG_DIR is set.
local config_dir cache meta lockdir cred_service
if [[ -n "$profile" ]]; then
    config_dir="$HOME/.claude-profiles/code/$profile"
    cache="$HOME/.cache/claude-usage-$profile.json"
    meta="$HOME/.cache/claude-usage-$profile.meta.json"
    lockdir="$HOME/.cache/claude-usage-$profile.lock"
    cred_service="Claude Code-credentials-$(printf %s "$config_dir" | shasum -a 256 | cut -c1-8)"
else
    config_dir="$HOME/.claude"
    cache="$HOME/.cache/claude-usage.json"
    meta="$HOME/.cache/claude-usage.meta.json"
    lockdir="$HOME/.cache/claude-usage.lock"
    cred_service="Claude Code-credentials"
fi
local ttl=300
local lock_stale_after=600
local backoff_base=120
local backoff_max=1800
local now age next_retry fail_count last_success
local hdr="" body=""
now=$(date +%s)

source "${self_file:A:h}/usage-cache-lib"

# Read the OAuth credentials JSON for a given config dir. File-first: recent
# Claude Code keeps the token in <config-dir>/.credentials.json and may leave
# the keychain item empty, so an empty keychain read must not mean "logged out".
# Falls back to the per-config-dir keychain service (the default account uses
# the un-suffixed "Claude Code-credentials"; profiles are hash-suffixed).
_read_claude_credentials_json() {
    local dir="$1"
    local service="$2"
    local credentials_json=""
    if [[ -f "$dir/.credentials.json" ]]; then
        credentials_json=$(<"$dir/.credentials.json")
    fi
    if [[ -z "$credentials_json" && "$OSTYPE" == darwin* ]] && command -v security &>/dev/null; then
        credentials_json=$(security find-generic-password -s "$service" -w 2>/dev/null || true)
    fi
    print -r -- "$credentials_json"
}

_auth_failure() {
    local http_status="$1"
    local err="${(L)2}"
    [[ "$http_status" -eq 401 ]] 2>/dev/null && return 0
    [[ "$err" == *"invalid authentication credentials"* ]] && return 0
    [[ "$err" == *"authentication_error"* ]] && return 0
    return 1
}

_auth_paused_meta() {
    local http_status="$1"
    local err="${(L)2}"
    [[ "$err" == "auth_expired" ]] && return 0
    _auth_failure "$http_status" "$err"
}

if [[ ! -f "$meta" ]]; then
    _write_meta 0 0 "" "" 0
fi

next_retry=$(jq -r '.next_retry_at // 0' "$meta" 2>/dev/null || echo 0)
fail_count=$(jq -r '.fail_count // 0' "$meta" 2>/dev/null || echo 0)
last_success=$(jq -r '.last_success_at // 0' "$meta" 2>/dev/null || echo 0)
local last_error last_http_status meta_auth_expires_at credentials_json current_auth_expires_at auth_fetch_paused=0
last_error=$(jq -r '.last_error // ""' "$meta" 2>/dev/null || echo "")
last_http_status=$(jq -r '.last_http_status // ""' "$meta" 2>/dev/null || echo "")
meta_auth_expires_at=$(jq -r '.auth_expires_at // empty' "$meta" 2>/dev/null || echo "")
credentials_json=$(_read_claude_credentials_json "$config_dir" "$cred_service")
current_auth_expires_at=$(print -r -- "$credentials_json" | jq -r '.claudeAiOauth.expiresAt // empty' 2>/dev/null || echo "")
age=$(_cache_age "$cache")

local should_fetch=0 auth_pause_current=0
if _auth_paused_meta "$last_http_status" "$last_error"; then
    if [[ -n "$current_auth_expires_at" && ( -z "$meta_auth_expires_at" || "$current_auth_expires_at" != "$meta_auth_expires_at" ) ]]; then
        # Claude Code refreshed credentials since the auth failure; retry now.
        next_retry=0
        fail_count=0
    else
        auth_pause_current=1
        auth_fetch_paused=1
    fi
fi

if [[ "$auth_pause_current" -eq 0 ]]; then
    if [[ ! -f "$cache" ]]; then
        [[ "$now" -ge "$next_retry" ]] && should_fetch=1
    elif [[ "$age" -ge "$ttl" && "$now" -ge "$next_retry" ]]; then
        should_fetch=1
    fi
fi

if [[ "$should_fetch" -eq 1 ]] && _acquire_lock; then
    trap _cleanup EXIT INT TERM HUP

    local token=""
    token=$(print -r -- "$credentials_json" | jq -r '.claudeAiOauth.accessToken // empty' 2>/dev/null)

    if [[ -z "$token" ]]; then
        _cleanup
        trap - EXIT INT TERM HUP
        echo "Not logged in"
        echo
        echo "To login:"
        echo "  - In Claude CLI: /login"
        echo "  - In terminal: claude setup-token"
        return 1
    fi

    local claude_ver http_code retry_after resp err
    claude_ver=$(claude --version 2>/dev/null | awk '{print $1}')
    hdr=$(mktemp)
    body=$(mktemp)

    if curl -sS --max-time 8 \
        -D "$hdr" \
        -o "$body" \
        "https://api.anthropic.com/api/oauth/usage" \
        -H "Authorization: Bearer $token" \
        -H "anthropic-beta: oauth-2025-04-20" \
        -H "User-Agent: claude-code/${claude_ver:-unknown}"; then
        http_code=$(awk 'BEGIN{IGNORECASE=1} /^HTTP/{code=$2} END{print code+0}' "$hdr")
        retry_after=$(awk 'BEGIN{IGNORECASE=1} /^retry-after:/ {print $2; exit}' "$hdr" | tr -d '\r')
        resp=$(<"$body")

        if [[ "$http_code" -eq 200 ]] && jq -e '.five_hour' "$body" >/dev/null 2>&1; then
            mkdir -p "$(dirname "$cache")"
            if [[ -n "$profile" ]]; then
                # Stamp the profile + display label into the cache so the
                # dashboard renders per-account rows without re-reading config
                # dirs. Label = optional one-line $config_dir/label, else name.
                local prof_label=""
                [[ -f "$config_dir/label" ]] && prof_label=$(<"$config_dir/label")
                [[ -n "$prof_label" ]] || prof_label="$profile"
                print -r -- "$resp" | jq --arg l "$prof_label" --arg p "$profile" \
                    '. + {_label: $l, _profile: $p}' > "${cache}.tmp.$$"
            else
                print -r -- "$resp" > "${cache}.tmp.$$"
            fi
            mv "${cache}.tmp.$$" "$cache"
            _write_meta 0 0 "$http_code" "" "$now"
            auth_fetch_paused=0
            age=0
        else
            err=$(jq -r '.error.type? // .error.message? // .message? // "fetch_failed"' "$body" 2>/dev/null)
            if _auth_failure "${http_code:-0}" "$err"; then
                _write_auth_paused "${http_code:-401}" "$err" "$last_success" "$current_auth_expires_at"
                auth_fetch_paused=1
            else
                _record_failure "$fail_count" "$retry_after" "${http_code:-0}" "$err" "$last_success"
            fi
        fi
    else
        _record_failure "$fail_count" "" "0" "network_error" "$last_success"
    fi

    _cleanup
    trap - EXIT INT TERM HUP
fi

if [[ ! -f "$cache" ]]; then
    next_retry=$(jq -r '.next_retry_at // 0' "$meta" 2>/dev/null || echo 0)
    last_error=$(jq -r '.last_error // ""' "$meta" 2>/dev/null || echo "")
    if [[ "$last_error" == "auth_expired" || "$auth_fetch_paused" -eq 1 ]]; then
        echo "Claude auth expired — use Claude or run claude auth login"
    elif [[ "$next_retry" -gt "$now" ]]; then
        echo "Usage refresh paused for $(_fmt_secs $((next_retry - now)))"
    else
        echo "Failed to fetch usage data"
    fi
    echo
    echo "Possible causes:"
    echo "  - Not logged in (try /login in Claude CLI)"
    echo "  - Network error"
    echo "  - API temporarily unavailable"
    return 1
fi

age=$(_cache_age "$cache")
local cache_stale=0
[[ "$age" -ge "$ttl" ]] && cache_stale=1

local u5 u7 r5 r7
u5=$(jq -r '.five_hour.utilization // 0' "$cache")
u7=$(jq -r '.seven_day.utilization // 0' "$cache")
r5=$(jq -r '.five_hour.resets_at // empty' "$cache")
r7=$(jq -r '.seven_day.resets_at // empty' "$cache")

_remaining() {
    local reset_iso="$1"
    [[ -z "$reset_iso" ]] && { print -r -- "-"; return; }
    local normalised ts
    normalised=$(printf '%s\n' "$reset_iso" | sed -E 's/\.[0-9]+//; s/Z$/+0000/; s/([+-][0-9]{2}):([0-9]{2})$/\1\2/')
    ts=$(date -d "$reset_iso" +%s 2>/dev/null || date -j -f "%Y-%m-%dT%H:%M:%S%z" "$normalised" +%s 2>/dev/null)
    [[ -z "$ts" ]] && { print -r -- "-"; return; }
    local diff=$((ts - now))
    if [[ "$diff" -le 0 ]]; then
        [[ "$cache_stale" -eq 1 ]] && { echo "__STALE__"; return; }
        echo "0h 0m"
        return
    fi
    _fmt_secs "$diff"
}

_print_window() {
    local label="$1"
    local usage="$2"
    local remaining="$3"
    if [[ "$remaining" == "__STALE__" ]]; then
        printf "%-9s %3.0f%%  cache stale\n" "$label" "$usage"
        return
    fi
    printf "%-9s %3.0f%%  resets in %s\n" "$label" "$usage" "$remaining"
}

_print_window "5-hour:" "$u5" "$(_remaining "$r5")"
_print_window "7-day:" "$u7" "$(_remaining "$r7")"

# Sonnet-only window (shown when present)
local us rs
us=$(jq -r '.seven_day_sonnet.utilization // empty' "$cache")
rs=$(jq -r '.seven_day_sonnet.resets_at // empty' "$cache")
[[ -n "$us" ]] && _print_window "Sonnet:" "$us" "$(_remaining "$rs")"

# Model-scoped weekly windows (e.g. Fable). These now arrive via .limits[] with
# a scope.model.display_name; the legacy seven_day_<model> keys are null. Label
# each by its model name so new scoped models show without a code change.
local scoped_tsv sm_name sm_pct sm_reset
scoped_tsv=$(jq -r '
    .limits[]?
    | select(.kind == "weekly_scoped" and (.scope.model.display_name // "") != "")
    | [.scope.model.display_name, (.percent // 0), (.resets_at // "")]
    | @tsv' "$cache" 2>/dev/null)
if [[ -n "$scoped_tsv" ]]; then
    while IFS=$'\t' read -r sm_name sm_pct sm_reset; do
        [[ -z "$sm_name" ]] && continue
        _print_window "${sm_name}:" "$sm_pct" "$(_remaining "$sm_reset")"
    done <<<"$scoped_tsv"
fi

# Extra usage (spend-based, not time-windowed)
local ex_enabled ex_limit ex_used
ex_enabled=$(jq -r '.extra_usage.is_enabled // empty' "$cache")
if [[ -n "$ex_enabled" ]]; then
    ex_limit=$(jq -r '.extra_usage.monthly_limit // 0' "$cache")
    ex_used=$(jq -r '.extra_usage.used_credits // 0' "$cache")
    local limit_fmt used_fmt status_label
    limit_fmt=$(printf "%.2f" "$((ex_limit))e-2")
    used_fmt=$(printf "%.2f" "${ex_used}e-2")
    if [[ "$ex_enabled" == "true" ]]; then
        status_label="enabled"
    else
        status_label="disabled"
    fi
    printf "%-9s %s/%s  (%s)\n" "Extra:" "$used_fmt" "$limit_fmt" "$status_label"
fi

last_error=$(jq -r '.last_error // ""' "$meta" 2>/dev/null || echo "")
if [[ "$last_error" == "auth_expired" || "$auth_fetch_paused" -eq 1 ]]; then
    printf "%-9s expired — use Claude or run claude auth login\n" "Auth:"
fi

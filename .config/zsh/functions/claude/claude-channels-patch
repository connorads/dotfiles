#!/usr/bin/env zsh
# claude-channels-patch: bypass tengu_harbor gate so --channels works with DISABLE_TELEMETRY=1
# usage: claude-channels-patch [--check|--restore|--all|--reapply] [path-to-claude-binary]
# --reapply: install-hook-friendly patch — clears the stale marker on success,
#            but on a missing needle warns loudly, writes the marker, exits 0.
#
# Why: cJH() in the bundled JS returns I_("tengu_harbor", false). When telemetry is
# disabled (DISABLE_TELEMETRY=1, DO_NOT_TRACK=1, CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1),
# I_ short-circuits to the default false, so channels are gated as "not currently available"
# even with claude.ai auth and managed-settings.json configured. Patching the bundled
# default from !1 to !0 forces cJH() true regardless of telemetry / rollout.

emulate -L zsh
setopt no_unset pipe_fail

local wrapper="${${(%):-%x}:A}"
local patch_name=claude-channels-patch
local patch_label=--channels
local needle='tengu_harbor",!1)'
local replace='tengu_harbor",!0)'
local marker="$HOME/.cache/claude-channels-patch.stale"
local missing_body=$'The flag was likely renamed upstream; --channels will silently\nrevert until the needle in claude-channels-patch is updated.'
local missing_banner='--channels will revert'

source "${wrapper:h}/_claude-gate-patch-lib"

#!/usr/bin/env zsh
# claude-computer-use-patch: force the computer-use MCP server eligible so it
# appears in /mcp with DISABLE_TELEMETRY=1
# usage: claude-computer-use-patch [--check|--restore|--all|--reapply] [path-to-claude-binary]
# --reapply: install-hook-friendly patch — clears the stale marker on success,
#            but on a missing needle warns loudly, writes the marker, exits 0.
#
# Why: eligibility is GDn() = Bjd() && $Qr().enabled, where Bjd() is the Pro/Max
# plan check and $Qr() reads the "tengu_malort_pedway" GrowthBook dynamic config,
# defaulting to the bundled object jca={enabled:!1,...}. When telemetry is disabled
# (DISABLE_TELEMETRY=1, DO_NOT_TRACK=1, CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1),
# the config fetch short-circuits to that default, so .enabled stays false and the
# server is hidden even on Pro/Max with claude.ai auth. Patching the bundled default
# from enabled:!1 to enabled:!0 forces $Qr().enabled true regardless of telemetry.
# The plan check Bjd() is independent of telemetry, so non-Pro/Max users still won't
# see it — this only restores what an eligible account would get with telemetry on.

emulate -L zsh
setopt no_unset pipe_fail

local needle='{enabled:!1,pixelValidation:!1,clipboardPasteMultiline:!0,mouseAnimation:!0,hideBeforeAction:!0,autoTargetDisplay:!0,clipboardGuard:!0,coordinateMode:"pixels"}'
local replace='{enabled:!0,pixelValidation:!1,clipboardPasteMultiline:!0,mouseAnimation:!0,hideBeforeAction:!0,autoTargetDisplay:!0,clipboardGuard:!0,coordinateMode:"pixels"}'
local mode=patch
local select_all=0

while (( $# )); do
  case $1 in
    --check)   mode=check;   shift ;;
    --restore) mode=restore; shift ;;
    --reapply) mode=reapply; shift ;;
    --all)     select_all=1; shift ;;
    --help|-h)
      sed -n '2,15p' "${(%):-%x}"
      return 0
      ;;
    *) break ;;
  esac
done

# Resolve target binaries (deduped by realpath so symlinks don't double up).
# `command -v claude` returns the mise shim, which is itself a symlink to the
# mise binary (mise dispatches by argv[0]). Resolve via `mise which`, falling
# back to the highest-versioned install in ~/.local/share/mise/installs/claude/.
local -a raw_targets targets
local -A seen
local rp t miseout
if (( $# )); then
  raw_targets=("$@")
elif (( select_all )); then
  raw_targets=( "$HOME"/.local/share/mise/installs/claude/*/claude(N) )
else
  miseout=""
  if command -v mise >/dev/null 2>&1; then
    miseout=$(mise which claude 2>/dev/null || true)
  fi
  if [[ -n $miseout && -f $miseout ]]; then
    raw_targets=( "$miseout" )
  else
    # Fall back to highest version from mise installs (lexicographic on x.y.z
    # is correct only for zero-padded; use sort -V).
    local -a installs=( "$HOME"/.local/share/mise/installs/claude/*/claude(N.) )
    if (( ${#installs} == 0 )); then
      print -u2 "no claude install found under ~/.local/share/mise/installs/claude/"
      return 1
    fi
    local highest
    highest=$(printf '%s\n' "${installs[@]}" | awk -F/ '{print $(NF-1)}' \
      | /usr/bin/sort -V | /usr/bin/tail -1)
    raw_targets=( "$HOME/.local/share/mise/installs/claude/$highest/claude" )
  fi
fi

for t in "${raw_targets[@]}"; do
  [[ -e $t ]] || { targets+=("$t"); continue }
  rp=$(/usr/bin/python3 -c "import os,sys;print(os.path.realpath(sys.argv[1]))" "$t")
  if [[ -z ${seen[$rp]:-} ]]; then
    seen[$rp]=1
    targets+=("$rp")
  fi
done

if (( ${#targets} == 0 )); then
  print -u2 "no claude binaries found"
  return 1
fi

local marker="$HOME/.cache/claude-computer-use-patch.stale"
local reapply_missing=0

# Warn loudly and drop a marker when the needle is gone (likely an upstream
# rename). Keeps exit status 0 so a Claude install/update is never blocked; the
# next shell start surfaces the marker so the rename cannot be forgotten.
_cu_warn_missing() {
  local target="$1"
  local when
  when=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null)
  mkdir -p "${marker:h}" 2>/dev/null || true
  {
    print -r -- "claude-computer-use-patch could not reapply the computer-use patch."
    print -r -- "binary: $target"
    print -r -- "needle: $needle"
    print -r -- "when:   $when"
    print -r -- "The default config was likely reshaped upstream; computer-use will"
    print -r -- "silently revert until the needle in claude-computer-use-patch is updated."
  } > "$marker" 2>/dev/null || true
  print -u2 ""
  print -u2 "################################################################"
  print -u2 "# claude-computer-use-patch: NEEDLE NOT FOUND — computer-use will revert"
  print -u2 "#   binary: $target"
  print -u2 "#   needle: $needle"
  print -u2 "# Update the needle in claude-computer-use-patch. Marker: $marker"
  print -u2 "################################################################"
}

local rc=0 real before after
for real in "${targets[@]}"; do
  if [[ ! -f $real ]]; then
    print -u2 "skip (missing): $real"
    rc=1
    continue
  fi
  before=$(LC_ALL=C /usr/bin/grep -aoF -- "$needle"  "$real" | /usr/bin/wc -l | /usr/bin/tr -d ' ')
  after=$( LC_ALL=C /usr/bin/grep -aoF -- "$replace" "$real" | /usr/bin/wc -l | /usr/bin/tr -d ' ')

  case $mode in
    check)
      if   (( after  > 0 && before == 0 )); then print "patched:    $real"
      elif (( before > 0 && after  == 0 )); then print "unpatched:  $real ($before occurrence(s))"
      elif (( before == 0 && after == 0 )); then print "no-pattern: $real (different version?)"; rc=1
      else                                       print "mixed:      $real (before=$before after=$after)"; rc=1
      fi
      ;;
    restore)
      if [[ -f $real.unpatched ]]; then
        cp -p "$real.unpatched" "$real"
        if [[ $OSTYPE == darwin* ]]; then
          /usr/bin/codesign --force --sign - "$real" 2>/dev/null || true
        fi
        print "restored:   $real (from $real.unpatched)"
      else
        print -u2 "no backup at $real.unpatched: $real"
        rc=1
      fi
      ;;
    patch|all|reapply)
      if (( after > 0 && before == 0 )); then
        print "skip (already patched): $real"
        continue
      fi
      if (( before == 0 )); then
        if [[ $mode == reapply ]]; then
          _cu_warn_missing "$real"
          reapply_missing=1
          continue
        fi
        print -u2 "skip (pattern not found): $real"
        rc=1
        continue
      fi
      [[ -f $real.unpatched ]] || cp -p "$real" "$real.unpatched"
      /usr/bin/python3 - "$real" "$needle" "$replace" <<'PY'
import os, sys, pathlib
path, needle, repl = sys.argv[1], sys.argv[2].encode(), sys.argv[3].encode()
p = pathlib.Path(path)
mode = p.stat().st_mode
data = p.read_bytes()
new = data.replace(needle, repl)
if new == data:
    sys.exit("no replacement made")
tmp = p.with_suffix(p.suffix + ".tmp")
tmp.write_bytes(new)
os.chmod(tmp, mode)
tmp.replace(p)
PY
      if [[ $OSTYPE == darwin* ]]; then
        /usr/bin/codesign --force --sign - "$real" 2>/dev/null || true
      fi
      after=$(LC_ALL=C /usr/bin/grep -aoF -- "$replace" "$real" | /usr/bin/wc -l | /usr/bin/tr -d ' ')
      print "patched:    $real ($after occurrence(s); backup at $real.unpatched)"
      ;;
  esac
done

if [[ $mode == reapply ]]; then
  (( reapply_missing )) || rm -f "$marker" 2>/dev/null
  return 0
fi

return $rc

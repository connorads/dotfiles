#!/usr/bin/env zsh
# codex-usage: Query Codex API usage limits with cache/backoff protection
emulate -L zsh
setopt pipefail

local cache="$HOME/.cache/codex-usage.json"
local meta="$HOME/.cache/codex-usage.meta.json"
local lockdir="$HOME/.cache/codex-usage.lock"
local ttl=300
local lock_stale_after=600
local backoff_base=120
local backoff_max=1800
local now age next_retry fail_count last_success
local hdr="" body=""
now=$(date +%s)

# Resolve this function file's directory (autoload, ~/.local/bin symlink, or
# direct run) so the shared cache/lock/backoff engine sources cleanly. Mirrors
# the agent-usage-log idiom used by pis/cys.
local self_name="${funcstack[1]:-${${(%):-%N}:t}}"
local self_file= candidate_dir
for candidate_dir in $fpath; do
    [[ -r "$candidate_dir/$self_name" ]] && { self_file="$candidate_dir/$self_name"; break }
done
[[ -n "$self_file" ]] || self_file="${${(%):-%N}:A}"
[[ -r "$self_file" ]] || self_file="${0:A}"
source "${self_file:A:h}/usage-cache-lib"

if [[ ! -f "$meta" ]]; then
    _write_meta 0 0 "" "" 0
fi

next_retry=$(jq -r '.next_retry_at // 0' "$meta" 2>/dev/null || echo 0)
fail_count=$(jq -r '.fail_count // 0' "$meta" 2>/dev/null || echo 0)
last_success=$(jq -r '.last_success_at // 0' "$meta" 2>/dev/null || echo 0)
age=$(_cache_age "$cache")

local should_fetch=0
if [[ ! -f "$cache" ]]; then
    [[ "$now" -ge "$next_retry" ]] && should_fetch=1
elif [[ "$age" -ge "$ttl" && "$now" -ge "$next_retry" ]]; then
    should_fetch=1
fi

if [[ "$should_fetch" -eq 1 ]] && _acquire_lock; then
    trap _cleanup EXIT INT TERM HUP

    local auth_file="$HOME/.codex/auth.json"
    if [[ ! -f "$auth_file" ]]; then
        _cleanup
        trap - EXIT INT TERM HUP
        echo "Not logged in (run: codex login)"
        return 1
    fi

    local token usage_resp usage_http usage_retry usage_ok=0
    token=$(jq -r '.tokens.access_token // empty' "$auth_file" 2>/dev/null)
    [[ -z "$token" ]] && { _cleanup; trap - EXIT INT TERM HUP; echo "No access token found in $auth_file"; return 1; }

    _fetch_usage() {
        local tk="$1"
        hdr=$(mktemp)
        body=$(mktemp)
        if curl -sS --max-time 8 -D "$hdr" -o "$body" "https://chatgpt.com/backend-api/wham/usage" -H "Authorization: Bearer $tk"; then
            usage_http=$(awk 'BEGIN{IGNORECASE=1} /^HTTP/{code=$2} END{print code+0}' "$hdr")
            usage_retry=$(awk 'BEGIN{IGNORECASE=1} /^retry-after:/ {print $2; exit}' "$hdr" | tr -d '\r')
            usage_resp=$(<"$body")
            if [[ "$usage_http" -eq 200 ]] && jq -e '.rate_limit' "$body" >/dev/null 2>&1; then
                usage_ok=1
            fi
        else
            usage_http=0
            usage_resp='{"message":"network_error"}'
            usage_retry=""
        fi
        rm -f "$hdr" "$body"
    }

    _fetch_usage "$token"

    if [[ "$usage_ok" -ne 1 ]]; then
        local refresh_token new_access new_refresh new_id payload refresh_resp
        refresh_token=$(jq -r '.tokens.refresh_token // empty' "$auth_file" 2>/dev/null)
        if [[ -n "$refresh_token" ]]; then
            payload=$(jq -n --arg rt "$refresh_token" '{
                client_id: "app_EMoamEEZ73f0CkXaXp7hrann",
                grant_type: "refresh_token",
                refresh_token: $rt,
                scope: "openid profile email"
            }')
            refresh_resp=$(curl -sS --max-time 8 -X POST "https://auth.openai.com/oauth/token" -H "Content-Type: application/json" -d "$payload")
            new_access=$(print -r -- "$refresh_resp" | jq -r '.access_token // empty' 2>/dev/null)
            if [[ -n "$new_access" ]]; then
                new_refresh=$(print -r -- "$refresh_resp" | jq -r '.refresh_token // empty' 2>/dev/null)
                new_id=$(print -r -- "$refresh_resp" | jq -r '.id_token // empty' 2>/dev/null)
                local tmp
                tmp=$(mktemp)
                jq --arg at "$new_access" \
                   --arg rt "${new_refresh:-$refresh_token}" \
                   --arg it "$new_id" \
                   --arg lr "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
                   '.tokens.access_token = $at | .tokens.refresh_token = $rt |
                    (if $it != "" then .tokens.id_token = $it else . end) |
                    .last_refresh = $lr' "$auth_file" > "$tmp" && mv "$tmp" "$auth_file"
                chmod 600 "$auth_file"
                usage_ok=0
                _fetch_usage "$new_access"
            fi
        fi
    fi

    if [[ "$usage_ok" -eq 1 ]]; then
        mkdir -p "$(dirname "$cache")"
        print -r -- "$usage_resp" > "${cache}.tmp.$$"
        mv "${cache}.tmp.$$" "$cache"
        _write_meta 0 0 "${usage_http:-200}" "" "$now"
        age=0
    else
        local err
        err=$(print -r -- "$usage_resp" | jq -r '.error.message? // .message? // "fetch_failed"' 2>/dev/null)
        _record_failure "$fail_count" "$usage_retry" "${usage_http:-0}" "$err" "$last_success"
    fi

    _cleanup
    trap - EXIT INT TERM HUP
fi

if [[ ! -f "$cache" ]]; then
    next_retry=$(jq -r '.next_retry_at // 0' "$meta" 2>/dev/null || echo 0)
    if [[ "$next_retry" -gt "$now" ]]; then
        echo "Usage refresh paused for $(_fmt_secs $((next_retry - now)))"
    else
        echo "Failed to fetch usage"
    fi
    return 1
fi

age=$(_cache_age "$cache")
local cache_stale=0
[[ "$age" -ge "$ttl" ]] && cache_stale=1

local u5 u7 r5_raw r7_raw r5 r7
u5=$(jq -r '.rate_limit.primary_window.used_percent // 0' "$cache")
u7=$(jq -r '.rate_limit.secondary_window.used_percent // 0' "$cache")
r5_raw=$(jq -r '.rate_limit.primary_window.reset_after_seconds // 0' "$cache")
r7_raw=$(jq -r '.rate_limit.secondary_window.reset_after_seconds // 0' "$cache")
r5=$((r5_raw - age))
r7=$((r7_raw - age))

_fmt_remaining() {
    local secs="$1"
    if [[ "$secs" -le 0 ]]; then
        [[ "$cache_stale" -eq 1 ]] && { echo "__STALE__"; return; }
        echo "0h 0m"
        return
    fi
    _fmt_secs "$secs"
}

_print_window() {
    local label="$1"
    local usage="$2"
    local remaining="$3"
    if [[ "$remaining" == "__STALE__" ]]; then
        printf "%-9s %3d%%  cache stale\n" "$label" "$usage"
        return
    fi
    printf "%-9s %3d%%  resets in %s\n" "$label" "$usage" "$remaining"
}

_print_window "5-hour:" "$u5" "$(_fmt_remaining "$r5")"
_print_window "7-day:" "$u7" "$(_fmt_remaining "$r7")"

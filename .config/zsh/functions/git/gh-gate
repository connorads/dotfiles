#!/usr/bin/env zsh
# gh-gate: manage scoped gh CLI tokens on remote machines via GitHub App
# usage: gh-gate <init|grant|revoke|status> [user@host]
emulate -L zsh

local cmd=${1:-}
local target
local config_dir="${HOME}/.config/gh-gate"
local config_file="${config_dir}/config"

_gh_gate_help() {
  cat <<'HELP'
Usage: gh-gate <command> [user@host]

Manage scoped gh CLI tokens on remote dev machines. Uses a GitHub App to
generate time-boxed write tokens; the remote machine defaults to read-only.

Commands:
  setup                 Interactive first-time configuration
  init    <user@host>   Create read-only PAT and deploy to target
  grant   <user@host>   Generate a 1-hour write token and push to target
  revoke  <user@host>   Remove write token, restore read-only on target
  status  [user@host]   Check which token is active on target

init/grant/revoke require an explicit target (no silent default — it once
deployed a token to the wrong machine). status falls back to DEFAULT_TARGET.

Setup:
  Run 'gh-gate setup' for interactive guided setup, or manually:

  1. Create a GitHub App (https://github.com/settings/apps/new):
     - Webhook: uncheck "Active"
     - Permissions (Read & write): Actions, Contents, Issues, Pull requests
     - Install on your account
     - Note the App ID and Installation ID

  2. Store the private key:
     macOS:  security add-generic-password -a "$USER" -s "gh-gate" \
               -w "$(<gh-gate-private-key.pem)" -T "" -U
     Linux:  mkdir -p ~/.config/gh-gate && chmod 700 ~/.config/gh-gate
             cp gh-gate-private-key.pem ~/.config/gh-gate/private-key.pem
             chmod 600 ~/.config/gh-gate/private-key.pem

  3. Create ~/.config/gh-gate/config (mkdir -p ~/.config/gh-gate first):
       APP_ID=123456
       INSTALLATION_ID=789012
       DEFAULT_TARGET=connor@dev

  4. Deploy read-only token to remote machine:
     gh-gate init [user@host]
     (Opens browser to pre-filled PAT form, prompts for token, deploys via SSH)

Config: ~/.config/gh-gate/config
  APP_ID=<number>            GitHub App ID
  INSTALLATION_ID=<number>   App installation ID
  DEFAULT_TARGET=<user@host> Fallback target for 'status' only (via Tailscale)

Permissions:
  Read-only PAT (init):    actions:read  contents:read  issues:read  pull_requests:read
  Write token (grant):     actions:write contents:write issues:write pull_requests:write
  GitHub App ceiling:      actions:rw    contents:rw    issues:rw    pull_requests:rw

Security:
  - Private key never leaves the host machine (macOS Keychain / local file)
  - Write tokens expire after 1 hour automatically
  - App permissions are an absolute ceiling for generated tokens
  - Emergency: uninstall the app at https://github.com/settings/installations
    to immediately invalidate ALL tokens
HELP
}

_gh_gate_setup() {
  print -r "gh-gate setup"
  print -r "============="
  print -r ""

  # Step 1: GitHub App
  print -r "Step 1: Create a GitHub App"
  print -r "  Go to: https://github.com/settings/apps/new"
  print -r "  - Webhook: uncheck \"Active\""
  print -r "  - Permissions (Read & write): Actions, Contents, Issues, Pull requests"
  print -r "  - Install on your account"
  print -r ""

  local app_id installation_id default_target pem_path

  print -rn "App ID: "
  read -r app_id
  if [[ -z "$app_id" || ! "$app_id" =~ '^[0-9]+$' ]]; then
    print -r "Error: App ID must be a number" >&2
    return 1
  fi

  # Step 2: Private key path + validation (needed before we can auth)
  print -r ""
  print -r "Step 2: Private key"

  local pem_default pem_candidates
  pem_candidates=(${HOME}/Downloads/*gh-gate*.pem(N.om))
  (( ${#pem_candidates[@]} )) && pem_default=${pem_candidates[1]}

  if [[ -n "$pem_default" ]]; then
    print -rn "Path to private key PEM file [${pem_default}]: "
  else
    print -rn "Path to private key PEM file: "
  fi
  read -r pem_path
  [[ -z "$pem_path" && -n "$pem_default" ]] && pem_path=$pem_default
  pem_path=${~pem_path}  # expand tilde

  if [[ ! -r "$pem_path" ]]; then
    print -r "Error: cannot read ${pem_path}" >&2
    return 1
  fi

  # Validate before doing anything irreversible — GNU base64 used to silently
  # break key storage (BSD-only -b flag), so we belt-and-brace the check.
  if ! openssl rsa -in "$pem_path" -check -noout 2>/dev/null && \
     ! openssl pkey -in "$pem_path" -noout 2>/dev/null; then
    print -r "Error: ${pem_path} is not a valid private key" >&2
    return 1
  fi

  # Step 3: Authenticate as the App; discover Installation ID
  print -r ""
  print -r "Authenticating as App ${app_id}..."
  local APP_ID=$app_id pem jwt body_file http_code app_name
  pem=$(<"$pem_path")
  jwt=$(_gh_gate_generate_jwt "$pem")
  unset pem

  body_file=$(mktemp)
  http_code=$(curl -s -o "$body_file" -w '%{http_code}' \
    -H "Authorization: Bearer ${jwt}" \
    -H "Accept: application/vnd.github+json" \
    -H "X-GitHub-Api-Version: 2022-11-28" \
    "https://api.github.com/app/installations")

  if [[ "$http_code" != "200" ]]; then
    print -r "Error: GitHub App authentication failed (HTTP ${http_code})" >&2
    cat "$body_file" >&2
    rm -f "$body_file"
    return 1
  fi

  app_name=$(jq -r 'first(.[]) | .app_slug // empty' < "$body_file" 2>/dev/null)
  print -r "Authenticated as GitHub App: ${app_name:-<unknown>}"

  local installation_ids
  installation_ids=("${(@f)$(jq -r '.[].id' < "$body_file")}")
  installation_ids=("${(@)installation_ids:#}")

  if (( ${#installation_ids[@]} == 1 )); then
    installation_id=${installation_ids[1]}
    print -r "Installation ID: ${installation_id} (auto-discovered)"
  else
    if (( ${#installation_ids[@]} > 1 )); then
      print -r "Multiple installations found:"
      jq -r '.[] | "  \(.id)  \(.account.login // .account.slug)"' < "$body_file"
    else
      print -r "No installations found — install the App on your account first."
    fi
    print -rn "Installation ID (found at https://github.com/settings/installations/<NUMBER>): "
    read -r installation_id
    if [[ -z "$installation_id" || ! "$installation_id" =~ '^[0-9]+$' ]]; then
      print -r "Error: Installation ID must be a number" >&2
      rm -f "$body_file"
      return 1
    fi
  fi
  rm -f "$body_file"

  # Step 4: Default target
  print -r ""
  print -rn "Default SSH target (e.g. connor@dev): "
  read -r default_target
  if [[ -z "$default_target" ]]; then
    print -r "Error: target is required" >&2
    return 1
  fi

  # Step 5: Store the PEM (only after auth succeeded)
  mkdir -p "$config_dir" && chmod 700 "$config_dir"
  if [[ "$(uname -s)" == "Darwin" ]]; then
    security add-generic-password -a "$USER" -s "gh-gate" \
      -w "$(<"$pem_path")" -T "" -U || {
      print -r "Error: failed to store key in Keychain" >&2
      return 1
    }
    print -r "Private key stored in macOS Keychain"
  else
    cp "$pem_path" "${config_dir}/private-key.pem"
    chmod 600 "${config_dir}/private-key.pem"
    print -r "Private key stored at ${config_dir}/private-key.pem"
  fi

  # Step 6: Write config
  cat > "$config_file" <<EOF
APP_ID=${app_id}
INSTALLATION_ID=${installation_id}
DEFAULT_TARGET=${default_target}
EOF
  chmod 600 "$config_file"
  print -r "Config written to ${config_file}"

  # Step 7: Offer to delete the original PEM
  print -r ""
  print -rn "Delete original key at ${pem_path}? [y/N]: "
  local delete_answer
  read -r delete_answer
  if [[ "$delete_answer" == [yY] ]]; then
    rm -f "$pem_path" && print -r "Deleted ${pem_path}"
  fi

  print -r ""
  print -r "Setup complete. Next: gh-gate init ${default_target}"
}

_gh_gate_load_config() {
  if [[ ! -r "$config_file" ]]; then
    print -r "Error: config not found at ${config_file}" >&2
    print -r "Run 'gh-gate setup' for guided configuration" >&2
    return 1
  fi
  source "$config_file"
  if [[ -z "${APP_ID:-}" || -z "${INSTALLATION_ID:-}" ]]; then
    print -r "Error: APP_ID and INSTALLATION_ID must be set in ${config_file}" >&2
    return 1
  fi
}

_gh_gate_resolve_target() {
  # $1 = target arg (may be empty); $2 = "required" forbids the DEFAULT_TARGET
  # fallback. Mutating ops (init/grant/revoke) require an explicit target so a
  # stray default can't silently deploy a token to the wrong machine.
  if [[ -n "${1:-}" ]]; then
    target=$1
  elif [[ "${2:-}" != "required" && -n "${DEFAULT_TARGET:-}" ]]; then
    target=$DEFAULT_TARGET
  else
    print -r "Error: target required (e.g. gh-gate ${cmd:-init} mini)" >&2
    return 1
  fi
  print -r "Target: ${target}" >&2
}

_gh_gate_get_pem() {
  local pem
  if [[ "$(uname -s)" == "Darwin" ]]; then
    # macOS: retrieve from Keychain (triggers Touch ID / password prompt)
    pem=$(security find-generic-password -a "$USER" -s "gh-gate" -w 2>/dev/null) || {
      print -r "Error: PEM not found in Keychain (service: gh-gate)" >&2
      print -r "Run 'gh-gate setup' to configure" >&2
      return 1
    }
    # `security -w` hexdumps multi-line secrets (a PEM has newlines); decode if so.
    if [[ "$pem" =~ '^[0-9a-fA-F]+$' ]]; then
      pem=$(printf '%s' "$pem" | xxd -r -p)
    fi
  else
    local pem_file="${config_dir}/private-key.pem"
    if [[ ! -r "$pem_file" ]]; then
      print -r "Error: PEM not found at ${pem_file}" >&2
      return 1
    fi
    pem=$(<"$pem_file")
  fi
  print -r -- "$pem"
}

_gh_gate_base64url() {
  # Base64url encode from stdin (no padding)
  openssl base64 -A | tr '+/' '-_' | tr -d '='
}

_gh_gate_generate_jwt() {
  local pem=$1
  local now=$EPOCHSECONDS
  local iat=$((now - 60))
  local exp=$((now + 600))

  local header
  header=$(printf '{"alg":"RS256","typ":"JWT"}' | _gh_gate_base64url)

  local payload
  payload=$(printf '{"iat":%d,"exp":%d,"iss":"%s"}' "$iat" "$exp" "$APP_ID" | _gh_gate_base64url)

  local unsigned="${header}.${payload}"
  local signature
  signature=$(printf '%s' "$unsigned" | openssl dgst -sha256 -sign <(printf '%s' "$pem") | _gh_gate_base64url)

  printf '%s.%s' "$unsigned" "$signature"
}

_gh_gate_init() {
  _gh_gate_load_config || return 1
  _gh_gate_resolve_target "${1:-}" required || return 1

  print -r ""
  print -r "gh-gate gives a remote machine two tokens:"
  print -r "  • read-only floor (this step): a 90-day fine-grained PAT, read only"
  print -r "  • 1-hour write token: minted on demand via 'gh-gate grant ${target}'"
  print -r "This step sets the read-only floor on ${target}."
  print -r ""

  local pat_url="https://github.com/settings/personal-access-tokens/new?name=dev-readonly&expires_in=90&actions=read&contents=read&issues=read&pull_requests=read"

  print -r "Opening GitHub to create a read-only fine-grained PAT..."
  print -r "Permissions: actions:read, contents:read, issues:read, pull_requests:read"
  print -r "Expiry: 90 days"
  print -r ""

  # Open browser (macOS or Linux)
  if [[ "$(uname -s)" == "Darwin" ]]; then
    open "$pat_url"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$pat_url"
  else
    print -r "Open this URL in your browser:"
    print -r "$pat_url"
  fi

  print -r ""
  print -r "After creating the token, paste it here."
  print -rn "Token: "
  local token
  read -rs token

  if [[ -z "$token" ]]; then
    print -r ""
    print -r "Error: no token provided" >&2
    return 1
  fi

  print -r ""
  print -r "Deploying read-only token to ${target}..."
  print -r -- "$token" | ssh "$target" 'umask 077 && mkdir -p ~/.config/gh-gate && cat > ~/.config/gh-gate/readonly-token' || {
    print -r "Error: failed to deploy token to ${target}" >&2
    return 1
  }

  # Verify the token works
  local verify
  verify=$(ssh "$target" "GH_TOKEN='$token' gh api /rate_limit --jq '.rate.limit' 2>/dev/null") 2>/dev/null
  if [[ -n "$verify" ]]; then
    print -r "Read-only token deployed to ${target} (verified, rate limit: ${verify})"
  else
    print -r "Read-only token deployed to ${target} (could not verify — check gh is installed on target)"
  fi
}

_gh_gate_grant() {
  _gh_gate_load_config || return 1
  _gh_gate_resolve_target "${1:-}" required || return 1

  print -r "Retrieving private key..."
  local pem
  pem=$(_gh_gate_get_pem) || return 1

  print -r "Generating JWT..."
  local jwt
  jwt=$(_gh_gate_generate_jwt "$pem")
  unset pem

  print -r "Requesting installation access token..."
  local response
  response=$(curl -sf -X POST \
    -H "Authorization: Bearer ${jwt}" \
    -H "Accept: application/vnd.github+json" \
    -H "X-GitHub-Api-Version: 2022-11-28" \
    -d '{"permissions":{"actions":"write","contents":"write","issues":"write","pull_requests":"write"}}' \
    "https://api.github.com/app/installations/${INSTALLATION_ID}/access_tokens") || {
    print -r "Error: GitHub API call failed" >&2
    print -r "Check APP_ID (${APP_ID}) and INSTALLATION_ID (${INSTALLATION_ID})" >&2
    return 1
  }

  local token expires_at
  token=$(print -r -- "$response" | jq -r '.token // empty')
  expires_at=$(print -r -- "$response" | jq -r '.expires_at // empty')

  if [[ -z "$token" ]]; then
    print -r "Error: no token in API response" >&2
    print -r "$response" | jq . >&2 2>/dev/null || print -r "$response" >&2
    return 1
  fi

  # Convert ISO 8601 expires_at to epoch (portable: macOS + GNU date)
  local expires_epoch
  expires_epoch=$(date -d "$expires_at" +%s 2>/dev/null || date -jf "%Y-%m-%dT%H:%M:%SZ" "$expires_at" +%s 2>/dev/null)

  print -r "Pushing write token to ${target}..."
  ssh "$target" 'umask 077 && mkdir -p ~/.config/gh-gate' || {
    print -r "Error: failed to prepare config dir on ${target}" >&2
    return 1
  }
  print -r -- "$token" | ssh "$target" 'cat > ~/.config/gh-gate/active-token' || {
    print -r "Error: failed to push token to ${target}" >&2
    return 1
  }
  print -r -- "$expires_epoch" | ssh "$target" 'cat > ~/.config/gh-gate/active-token-expires' || {
    print -r "Error: failed to push expiry to ${target}" >&2
    return 1
  }

  print -r "Write access granted on ${target}"
  print -r "Expires: ${expires_at}"
  print -r "Revoke with: gh-gate revoke"
}

_gh_gate_revoke() {
  _gh_gate_load_config || return 1
  _gh_gate_resolve_target "${1:-}" required || return 1

  # Try to revoke the token via API first (best-effort)
  local remote_token
  remote_token=$(ssh "$target" 'cat ~/.config/gh-gate/active-token 2>/dev/null') 2>/dev/null
  if [[ -n "$remote_token" ]]; then
    local pem jwt
    pem=$(_gh_gate_get_pem 2>/dev/null)
    if [[ -n "$pem" ]]; then
      jwt=$(_gh_gate_generate_jwt "$pem")
      unset pem
      curl -sf -X DELETE \
        -H "Authorization: Bearer ${jwt}" \
        -H "Accept: application/vnd.github+json" \
        -H "X-GitHub-Api-Version: 2022-11-28" \
        "https://api.github.com/installation/token" \
        -d "{\"token\":\"${remote_token}\"}" 2>/dev/null && \
        print -r "Token revoked via GitHub API"
    fi
  fi

  print -r "Removing write token from ${target}..."
  ssh "$target" 'rm -f ~/.config/gh-gate/active-token ~/.config/gh-gate/active-token-expires' || {
    print -r "Error: failed to remove token from ${target}" >&2
    return 1
  }

  print -r "Write access revoked on ${target} (read-only restored)"
}

_gh_gate_status() {
  _gh_gate_load_config || return 1
  _gh_gate_resolve_target "${1:-}" || return 1

  # POSIX remote check: EPOCHSECONDS is zsh/bash-only and comes back empty over
  # plain ssh (→ 0 < expiry → false "active"); date +%s is portable.
  local result
  result=$(ssh "$target" '
    d="$HOME/.config/gh-gate"
    if [ -r "$d/active-token" ]; then
      exp=$(cat "$d/active-token-expires" 2>/dev/null)
      case "$exp" in
        ""|*[!0-9]*) echo "write:expired" ;;
        *) if [ "$(date +%s)" -lt "$exp" ]; then echo "write:active"; else echo "write:expired"; fi ;;
      esac
    elif [ -r "$d/readonly-token" ]; then
      echo "readonly"
    else
      echo "none"
    fi
  ') || {
    print -r "Error: failed to check status on ${target}" >&2
    return 1
  }

  case "$result" in
    write:active)
      print -r "${target}: WRITE access (token valid)"
      ;;
    write:expired)
      print -r "${target}: write token EXPIRED (read-only effective)"
      print -r "Run 'gh-gate revoke' to clean up"
      ;;
    readonly)
      print -r "${target}: read-only (default)"
      ;;
    none)
      print -r "${target}: no gh-gate tokens configured"
      ;;
    *)
      print -r "${target}: unknown state: ${result}"
      ;;
  esac
}

# Main dispatch
case "$cmd" in
  setup)   _gh_gate_setup ;;
  init)    _gh_gate_init "${2:-}" ;;
  grant)   _gh_gate_grant "${2:-}" ;;
  revoke)  _gh_gate_revoke "${2:-}" ;;
  status)  _gh_gate_status "${2:-}" ;;
  -h|--help|help) _gh_gate_help ;;
  "")
    print -r "Usage: gh-gate <setup|init|grant|revoke|status> [user@host]" >&2
    print -r "Run 'gh-gate --help' for full documentation" >&2
    return 1
    ;;
  *)
    print -r "Unknown command: ${cmd}" >&2
    print -r "Usage: gh-gate <setup|init|grant|revoke|status> [user@host]" >&2
    return 1
    ;;
esac

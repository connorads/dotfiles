#!/usr/bin/env zsh
# wti: show status of all worktrees under ~/.trees
emulate -L zsh

local trees_dir="$HOME/.trees"
if [[ ! -d "$trees_dir" ]] || [[ -z "$(ls -A "$trees_dir" 2>/dev/null)" ]]; then
  echo "No worktrees in ~/.trees/"
  return 0
fi

printf "%-28s %-20s %-6s %s\n" "WORKTREE" "BRANCH" "STATUS" "AHEAD/BEHIND"

for wt in "$trees_dir"/*(N/); do
  local name=$(basename "$wt")
  local branch=$(git -C "$wt" branch --show-current 2>/dev/null)
  [[ -z "$branch" ]] && branch="(detached)"

  local state="clean"
  if [[ -n $(git -C "$wt" status --porcelain 2>/dev/null) ]]; then
    state="dirty"
  fi

  local ab=""
  local counts=$(git -C "$wt" rev-list --left-right --count HEAD...@{u} 2>/dev/null)
  if [[ -n "$counts" ]]; then
    local ahead=${counts%%$'\t'*}
    local behind=${counts##*$'\t'}
    if (( ahead > 0 || behind > 0 )); then
      ab="+${ahead} -${behind}"
    fi
  fi

  printf "%-28s %-20s %-6s %s\n" "$name" "$branch" "$state" "$ab"
done

#!/usr/bin/env zsh
# up: update tools, lockfiles, and rebuild for current OS
# flags: --frozen / -s / --skip-flake
#                           frozen rebuild: bump nothing. Converge tools to the
#                           committed mise.lock (mise install) and skip the flake
#                           bump/commit + brew/apt. The default (no flag) bumps both
#                           lockfiles within their ranges and commits each change.
#        --os               also install no-restart macOS updates (macOS only);
#                           restart-required (OS) updates are only reported, never
#                           applied, so a headless FileVault box is never rebooted.
#        --no-audit         skip the lockfile-audit OSV sweep (escape hatch; the
#                           sweep itself already warns-not-blocks when offline).
emulate -L zsh

local frozen=0 do_os=0 no_audit=0
for arg in "$@"; do
  case "$arg" in
    --frozen|-s|--skip-flake) frozen=1 ;;
    --os) do_os=1 ;;
    --no-audit) no_audit=1 ;;
  esac
done

# Detective OSV sweep of tracked lockfiles before any mutation: a MAL-* hit
# aborts with a clean tree (nothing bumped to revert). CVEs report non-blocking;
# scanner errors/offline warn only. `up` has no set -e, hence the explicit return.
if (( !frozen && !no_audit )); then
  lockfile-audit || return 1
fi

if (( frozen )); then
  mise install                  # converge to committed mise.lock, no bump/commit
else
  local lock=~/.config/mise/mise.lock
  # mise upgrade bumps within ranges and auto-locks every lockfile_platforms
  # entry (not just the current one) for each changed tool, plus current-platform
  # provenance — so no separate `mise lock` refresh is needed here.
  mise upgrade
  if [[ -f $lock ]]; then
    dotfiles add "$lock"
    dotfiles diff --cached --quiet -- "$lock" \
      || dotfiles commit -m "chore(mise): update tool lock"
  fi
fi
# Reassert Claude binary/plugin patches: covers no-op upgrades (postinstall only
# fires on an actual install) and manual paths. Idempotent.
claude-channels-patch --reapply
claude-channels-allowlist-patch --reapply
claude-computer-use-patch --reapply
claude-session-reaper-patch --reapply
claude-telegram-clear-patch --reapply
if (( !frozen )) && [[ "$OSTYPE" == "darwin"* ]]; then
  brew update && brew upgrade --no-ask
fi

# apt updates (non-NixOS Linux)
if (( !frozen )) && [[ "$OSTYPE" == "linux-gnu"* ]] && command -v apt-get &>/dev/null && [[ ! -f /etc/NIXOS ]]; then
  echo "=> apt update + upgrade"
  sudo apt-get update -y
  sudo env DEBIAN_FRONTEND=noninteractive apt-get upgrade -y
  sudo env DEBIAN_FRONTEND=noninteractive apt-get autoremove -y
fi

if (( !frozen )); then
  nfu
  dotfiles add ~/.config/nix/flake.lock
  if ! dotfiles diff --cached --quiet -- ~/.config/nix/flake.lock; then
    dotfiles commit -m "chore(nix): update flake lock"
  fi
fi

if [[ "$OSTYPE" == "darwin"* ]]; then
  drs
  if (( do_os )); then
    macup --safe   # install no-restart macOS updates; report OS updates only
  else
    macup-check    # cached scan, ~instant: report any pending macOS updates
  fi
elif [[ -f /etc/NIXOS ]]; then
  nrs    # system rebuild (reads NIXOS_FLAKE)
  hms    # user env rebuild (reads ~/.config/nix)
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
  hms
fi

# Check tmux plugin forks for upstream updates
if command -v tmux-upstream &>/dev/null && command -v tmux &>/dev/null; then
  echo "=> tmux plugin upstream check"
  tmux-upstream
fi

# Recheck conditional pins/excludes so escape hatches don't quietly become
# permanent. Report-only: pin-audit always exits 0 and never blocks `up`.
if (( !frozen )); then
  pin-audit
fi

# Reboot notification (apt-based Linux)
if [[ "$OSTYPE" == "linux-gnu"* ]] && [[ -f /var/run/reboot-required ]]; then
  echo ""
  echo "*** Reboot required ***"
  cat /var/run/reboot-required.pkgs 2>/dev/null
  echo "Run: sudo reboot"
fi

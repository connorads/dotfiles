#!/usr/bin/env zsh
# rs (repo setup): trust mise, install tools, and install deps for current repo
emulate -L zsh

# mise trust + install
if [[ -f mise.toml ]] || [[ -f .mise.toml ]]; then
  echo "=> mise trust + install"
  mise trust && mise install || return 1
fi

# JS/TS (mutually exclusive — a repo uses one JS package manager)
if [[ -f bun.lock ]] || [[ -f bun.lockb ]]; then
  echo "=> bun install"
  bun install || return 1
elif [[ -f pnpm-lock.yaml ]]; then
  echo "=> pnpm install"
  pnpm install || return 1
elif [[ -f yarn.lock ]]; then
  echo "=> yarn install"
  yarn install || return 1
elif [[ -f package-lock.json ]]; then
  echo "=> npm install"
  npm install || return 1
fi

# Ruby
if [[ -f Gemfile.lock ]]; then
  echo "=> bundle install"
  bundle install || return 1
fi

# Go
if [[ -f go.sum ]]; then
  echo "=> go mod download"
  go mod download || return 1
fi

# Rust
if [[ -f Cargo.lock ]]; then
  echo "=> cargo fetch"
  cargo fetch || return 1
fi

# Python (most specific lockfile first)
if [[ -f requirements.txt ]]; then
  echo "=> pip install -r requirements.txt"
  pip install -r requirements.txt || return 1
elif [[ -f uv.lock ]]; then
  echo "=> uv sync"
  uv sync || return 1
elif [[ -f poetry.lock ]]; then
  echo "=> poetry install"
  poetry install || return 1
elif [[ -f pyproject.toml ]] && command -v uv &>/dev/null; then
  echo "=> uv sync"
  uv sync || return 1
fi

# PHP
if [[ -f composer.lock ]]; then
  echo "=> composer install"
  composer install || return 1
fi

# Elixir
if [[ -f mix.lock ]]; then
  echo "=> mix deps.get"
  mix deps.get || return 1
fi

# Swift
if [[ -f Package.resolved ]]; then
  echo "=> swift package resolve"
  swift package resolve || return 1
fi

# Dart/Flutter
if [[ -f pubspec.lock ]]; then
  echo "=> dart pub get"
  dart pub get || return 1
fi

echo "=> done"

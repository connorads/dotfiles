#!/usr/bin/env zsh
# sendshot: transfer a clipboard image or image file over SSH
emulate -L zsh

local usage="Usage: sendshot [--copy] [--host HOST] <host> [file]

Uploads an image to HOST:/tmp/screenshots and prints the remote path.
If [file] is omitted, reads an image from the local clipboard."

local copy=0
local host=""
local file=""

while (($# > 0)); do
  case "$1" in
  --copy)
    copy=1
    shift
    ;;
  --host)
    if (($# < 2)); then
      print -u2 -- "sendshot: --host needs a value"
      return 2
    fi
    host="$2"
    shift 2
    ;;
  -h | --help)
    print -r -- "$usage"
    return 0
    ;;
  --)
    shift
    break
    ;;
  -*)
    print -u2 -- "sendshot: unknown option: $1"
    print -u2 -- "$usage"
    return 2
    ;;
  *)
    if [[ -z "$host" ]]; then
      host="$1"
    elif [[ -z "$file" ]]; then
      file="$1"
    else
      print -u2 -- "sendshot: too many arguments"
      print -u2 -- "$usage"
      return 2
    fi
    shift
    ;;
  esac
done

if (($# > 0)); then
  if [[ -z "$file" ]]; then
    file="$1"
    shift
  fi
  if (($# > 0)); then
    print -u2 -- "sendshot: too many arguments"
    print -u2 -- "$usage"
    return 2
  fi
fi

host="${host:-${SENDSHOT_HOST:-}}"
if [[ -z "$host" ]]; then
  print -u2 -- "$usage"
  print -u2 -- "sendshot: host required (or set SENDSHOT_HOST)"
  return 1
fi

_copy_path() {
  local value="$1"
  if command -v pbcopy >/dev/null 2>&1; then
    print -rn -- "$value" | pbcopy
  elif command -v wl-copy >/dev/null 2>&1; then
    print -rn -- "$value" | wl-copy
  elif command -v xclip >/dev/null 2>&1; then
    print -rn -- "$value" | xclip -selection clipboard
  else
    print -u2 -- "sendshot: no clipboard writer found (pbcopy/wl-copy/xclip)"
    return 1
  fi
}

local tmpfile=""
local cleanup_tmp=0
if [[ -n "$file" ]]; then
  if [[ ! -f "$file" ]]; then
    print -u2 -- "sendshot: file not found: $file"
    return 1
  fi
  tmpfile="$file"
elif [[ "$(uname)" == "Darwin" ]]; then
  if ! command -v imagepaste >/dev/null 2>&1; then
    print -u2 -- "sendshot: imagepaste not found - rebuild the darwin config"
    return 1
  fi
  cleanup_tmp=1
  local tmp_stem="${TMPDIR:-/tmp}/sendshot-$$"
  if ! tmpfile="$(imagepaste "$tmp_stem" 2>/dev/null)"; then
    rm -f "$tmp_stem.gif" "$tmp_stem.png"
    print -u2 -- "sendshot: no image in clipboard"
    return 1
  fi
else
  # Crostini: Chrome OS screenshots land in shared Downloads, not ~/Downloads.
  local screenshots_dir="/mnt/chromeos/MyFiles/Downloads"
  [[ -d "$screenshots_dir" ]] || screenshots_dir="$HOME/Downloads"
  tmpfile=(${screenshots_dir}/*.png(Nom[1]))
  if [[ -z "$tmpfile" ]]; then
    print -u2 -- "sendshot: no PNG files found in $screenshots_dir"
    return 1
  fi
fi

local filename="${tmpfile:t}"
if [[ "$filename" == sendshot-*.* ]]; then
  filename="sendshot-$(date +%s).${filename:e}"
fi
filename="${filename// /-}"

local remote_dir="/tmp/screenshots"
local remote_path="$remote_dir/$filename"

if ssh "$host" "mkdir -p '$remote_dir' && chmod 700 '$remote_dir'" &&
  scp -q "$tmpfile" "$host:$remote_path" &&
  ssh "$host" "chmod 600 '$remote_path'"; then
  print -r -- "$remote_path"
  if ((copy)); then
    _copy_path "$remote_path" || return 1
    print -u2 -- "Copied remote path to clipboard"
  fi
else
  ((cleanup_tmp)) && rm -f "$tmpfile"
  return 1
fi

if ((cleanup_tmp)); then
  rm -f "$tmpfile"
fi
return 0

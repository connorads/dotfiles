# _register_completions: register completions for custom functions (runs once)

_svc() {
  local -a subcmds=(up down restart ls ui help)
  local -a services=(remobi toad gigacode companion)
  if (( CURRENT == 2 )); then
    _describe 'subcommand' subcmds
  elif (( CURRENT == 3 )); then
    case "${words[2]}" in
      up|down|restart) _describe 'service' services ;;
    esac
  fi
}
compdef _svc svc

_tsp() {
  local -a subcmds=(ui ls up down prune help)
  if (( CURRENT == 2 )); then
    _describe 'subcommand' subcmds
  fi
}
compdef _tsp tsp

_gh_gate_complete() {
  local -a subcmds=(init grant revoke status help)
  if (( CURRENT == 2 )); then
    _describe 'subcommand' subcmds
  fi
}
compdef _gh_gate_complete gh-gate

_agentbox() {
  local -a subcmds=(start attach shell stop build list help)
  if (( CURRENT == 2 )); then
    _describe 'subcommand' subcmds
  fi
}
compdef _agentbox agentbox

_killport() {
  if [[ "${words[CURRENT]}" != -* ]]; then
    local -a ports
    ports=(${(f)"$(ss -tlnp 2>/dev/null | awk 'NR>1 {split($4,a,":"); print a[length(a)]}' | sort -un)"})
    if [[ ${#ports} -eq 0 && "$OSTYPE" == darwin* ]]; then
      ports=(${(f)"$(lsof -iTCP -sTCP:LISTEN -P -n 2>/dev/null | awk 'NR>1 {split($9,a,":"); print a[length(a)]}' | sort -un)"})
    fi
    _describe 'port' ports
  fi
}
compdef _killport killport

# Self-remove from precmd
add-zsh-hook -D precmd _register_completions

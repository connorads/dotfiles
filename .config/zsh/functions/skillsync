#!/usr/bin/env zsh
# Sync skill symlinks across all agents
#
# DEPRECATED: prefer `skills add -g <repo> --skill <name>` (the skills CLI) for
# global installs — it fans out into more tools (cline, zed, warp, …) and tracks
# upstream. Kept as the no-repo fallback for globally installing your own loose
# or private authored skills without first publishing them to a repo.
# Full rationale: ~/.config/skills/AGENTS.md.
#
# Usage: skillsync [-v|--verbose] [-n|--dry-run] [-p|--prune]
#   --prune also removes per-agent symlinks whose canonical source is gone.
#   Needed because the autoload dir is empty by design (catalogue lives in
#   ~/.config/skills, loaded on demand via skl) — emptying it leaves the
#   per-agent symlinks dangling, and the create-only sync never cleans them.
emulate -L zsh

local verbose=0 dry_run=0 prune=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    -v|--verbose) verbose=1; shift ;;
    -n|--dry-run) dry_run=1; verbose=1; shift ;;
    -p|--prune) prune=1; shift ;;
    *) print -u2 "Unknown option: $1"; return 1 ;;
  esac
done

local canonical="$HOME/.agents/skills"
if [[ ! -d "$canonical" ]]; then
  # Pruning doesn't need a canonical dir (it only removes stale links); a plain
  # sync does (nothing to create from).
  (( prune )) || { print -u2 "No skills at $canonical"; return 1; }
  canonical=""
fi

typeset -A paths=(
  [amp]="$HOME/.config/agents/skills"
  [antigravity]="$HOME/.gemini/antigravity/global_skills"
  [claude-code]="$HOME/.claude/skills"
  [codex]="$HOME/.codex/skills"
  [cursor]="$HOME/.cursor/skills"
  [gemini-cli]="$HOME/.gemini/skills"
  [github-copilot]="$HOME/.copilot/skills"
  [kiro-cli]="$HOME/.kiro/skills"
  [opencode]="$HOME/.config/opencode/skills"
  [pi]="$HOME/.pi/agent/skills"
)

# nullglob (N): the canonical dir may legitimately be empty (autoload-none).
# (-/): match directories, following symlinks — authored skills are symlinked
# into the autoload dir (real files live in ~/skills), so a plain (/) would skip
# them and only sync real-dir clones (e.g. CLI-vendored playwright-cli).
local skills=()
[[ -n "$canonical" ]] && skills=("$canonical"/*(-/N:t))
local created=0 pruned=0

# Calculate relative path from $1 to $2
_relpath() {
  local from="${1:A}" to="${2:A}"
  local -a from_parts to_parts
  from_parts=("${(@s:/:)from}")
  to_parts=("${(@s:/:)to}")

  # Find common prefix length
  local i=1 common=0
  while (( i <= $#from_parts && i <= $#to_parts )); do
    [[ "${from_parts[i]}" == "${to_parts[i]}" ]] || break
    ((common++))
    ((i++))
  done

  # Build relative path
  local -a rel_parts
  local j
  for (( j = common + 1; j <= $#from_parts; j++ )); do
    rel_parts+=("..")
  done
  for (( j = common + 1; j <= $#to_parts; j++ )); do
    rel_parts+=("${to_parts[j]}")
  done

  print -r -- "${(j:/:)rel_parts}"
}

for agent dir in "${(@kv)paths}"; do
  # Remove legacy directory symlink
  if [[ -L "$dir" ]]; then
    (( verbose )) && echo "Removing directory symlink: $dir"
    if (( ! dry_run )); then
      command rm "$dir"
    fi
  fi

  # Create skills dir
  if (( ! dry_run )); then
    command mkdir -p "$dir"
  fi

  # Create per-skill symlinks
  for skill in "${skills[@]}"; do
    local target="$dir/$skill"
    [[ -e "$target" || -L "$target" ]] && continue

    local rel
    rel=$(_relpath "$dir" "$canonical/$skill")
    (( verbose )) && echo "Creating: $target -> $rel"
    if (( ! dry_run )); then
      command ln -s "$rel" "$target"
    fi
    ((created++))
  done

  # Prune stale symlinks (symlinks only, target no longer resolves). Real dirs
  # and live links are left untouched.
  if (( prune )); then
    for link in "$dir"/*(N@); do
      [[ -e "$link" ]] && continue
      (( verbose )) && echo "Pruning: $link"
      if (( ! dry_run )); then
        command rm "$link"
      fi
      ((pruned++))
    done
  fi
done

echo "Created $created symlinks"
if (( prune )); then
  echo "Pruned $pruned symlinks"
fi

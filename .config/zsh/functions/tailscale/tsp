#!/usr/bin/env zsh
# tsp: manage Tailscale serve/funnel routes
#
# Subcommands:
#   tsp ui
#   tsp ls [--json]
#   tsp up [--public|-p] [--apex|-a] [--https PORT] [LOCAL_PORT]
#   tsp down [HTTPS_PORT] [--yes]
#   tsp prune [--yes] [--dry-run]
emulate -L zsh

_tsp_usage() {
  cat <<'EOF'
Usage:
  tsp ui
  tsp ls [--json]
  tsp up [--public|-p] [--apex|-a] [--https PORT] [LOCAL_PORT]
  tsp down [HTTPS_PORT] [--yes]
  tsp prune [--yes] [--dry-run]

Examples:
  tsp
  tsp up 3000
  tsp up --public 4321
  tsp up --apex 7681
  tsp down 3000
  tsp prune --dry-run
EOF
}

_tsp_need_cmds() {
  local -a missing
  local cmd
  for cmd in "$@"; do
    command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    print -u2 "missing required command(s): ${(j:, :)missing}"
    return 1
  fi
}

_tsp_confirm() {
  local prompt=$1
  if command -v gum >/dev/null 2>&1 && [[ -t 0 && -t 1 ]]; then
    gum confirm "$prompt"
    return $?
  fi

  if [[ -t 0 ]]; then
    local reply
    read -r "reply?$prompt [y/N] "
    [[ "$reply" == [yY] || "$reply" == [yY][eE][sS] ]]
    return $?
  fi

  return 1
}

_tsp_hostname() {
  if command -v ts-hostname >/dev/null 2>&1; then
    ts-hostname
    return $?
  fi

  local hostname
  hostname=$(ts status --self --json 2>/dev/null | jq -r '.Self.DNSName' 2>/dev/null | sed 's/\.$//')
  if [[ -z "$hostname" || "$hostname" == "null" ]]; then
    print -u2 "error: could not resolve Tailscale hostname"
    return 1
  fi
  print -r -- "$hostname"
}

_tsp_get_serve_json() {
  local serve_json
  serve_json=$(ts serve status --json 2>/dev/null)
  if [[ -z "$serve_json" || "$serve_json" == "null" || "$serve_json" == "{}" ]]; then
    print -r -- "{}"
    return 0
  fi
  print -r -- "$serve_json"
}

_tsp_listening_lines() {
  if command -v listening-lines >/dev/null 2>&1; then
    listening-lines 2>/dev/null && return 0
  fi

  if [[ "$OSTYPE" == darwin* ]]; then
    lsof -iTCP -sTCP:LISTEN -P -n 2>/dev/null | tail -n +2
  else
    ss -tlnp 2>/dev/null | tail -n +2
  fi
}

_tsp_port_valid() {
  [[ "$1" =~ '^[0-9]+$' ]]
}

_tsp_prompt_port() {
  local port
  printf "local port: "
  read -r port
  if ! _tsp_port_valid "$port"; then
    print -u2 "error: invalid port"
    return 1
  fi
  print -r -- "$port"
}

_tsp_load_listeners() {
  typeset -gA TSP_LISTEN_PID TSP_LISTEN_PROC TSP_LISTEN_BIND TSP_LISTEN_ADDR TSP_LISTEN_EXPOSURE
  typeset -ga TSP_LISTEN_PORTS
  TSP_LISTEN_PORTS=()

  local -A seen
  local -a lines
  lines=("${(@f)$(_tsp_listening_lines)}")

  local line addr pid_info cmd pid port bind exposure
  for line in "${lines[@]}"; do
    [[ -z "$line" ]] && continue

    if [[ "$OSTYPE" == darwin* ]]; then
      cmd=$(echo "$line" | awk '{print $1}')
      pid=$(echo "$line" | awk '{print $2}')
      addr=$(echo "$line" | awk '{print $9}')
    else
      addr=$(echo "$line" | awk '{print $4}')
      pid_info=$(echo "$line" | awk '{print $6}')
      cmd="-"
      if [[ "$pid_info" == *\"* ]]; then
        cmd="${pid_info#*\"}"
        cmd="${cmd%%\"*}"
      fi
      pid="-"
      if [[ "$pid_info" == *"pid="* ]]; then
        pid="${pid_info#*pid=}"
        pid="${pid%%,*}"
      fi
    fi

    port="${addr##*:}"
    bind="${addr%:*}"
    _tsp_port_valid "$port" || continue

    [[ -n "${seen[$port]}" ]] && continue
    seen[$port]=1

    exposure="public"
    case "$bind" in
      127.*|"[::1]"|"::1"|localhost|"[localhost]"|"127.0.0.53%lo"|"127.0.0.54") exposure="local" ;;
      100.*|"[fd7a:115c:a1e0"*|"fd7a:115c:a1e0"*) exposure="tailnet" ;;
    esac

    [[ -z "$pid" ]] && pid="-"
    [[ -z "$cmd" ]] && cmd="-"
    TSP_LISTEN_PID[$port]="$pid"
    TSP_LISTEN_PROC[$port]="$cmd"
    TSP_LISTEN_BIND[$port]="$bind"
    TSP_LISTEN_ADDR[$port]="$addr"
    TSP_LISTEN_EXPOSURE[$port]="$exposure"
    TSP_LISTEN_PORTS+=("$port")
  done

  TSP_LISTEN_PORTS=(${(on)TSP_LISTEN_PORTS})
}

_tsp_target_for_port() {
  local port=$1
  local has_v4=0 has_v6_loopback=0
  local -a lines
  lines=("${(@f)$(_tsp_listening_lines)}")

  local line addr bind lport
  for line in "${lines[@]}"; do
    [[ -z "$line" ]] && continue

    if [[ "$OSTYPE" == darwin* ]]; then
      addr=$(echo "$line" | awk '{print $9}')
    else
      addr=$(echo "$line" | awk '{print $4}')
    fi

    lport="${addr##*:}"
    [[ "$lport" == "$port" ]] || continue

    bind="${addr%:*}"
    case "$bind" in
      "[::1]"|"::1") has_v6_loopback=1 ;;
      *) has_v4=1 ;;
    esac
  done

  if (( has_v4 == 0 && has_v6_loopback == 1 )); then
    print -r -- "http://[::1]:$port"
  else
    print -r -- "$port"
  fi
}

_tsp_load_served() {
  typeset -gA TSP_SERVE_MODE TSP_SERVE_PROXY TSP_SERVE_LPORT TSP_SERVE_LBIND TSP_SERVE_URL TSP_SERVE_HEALTH
  typeset -ga TSP_SERVE_EPORTS
  TSP_SERVE_EPORTS=()

  local hostname serve_json rows
  hostname=$(_tsp_hostname) || return 1
  serve_json=$(_tsp_get_serve_json)

  rows=$(printf '%s' "$serve_json" | jq -r --arg host "$hostname" '
    . as $root
    | ($root.Web // {})
    | to_entries[]
    | .key as $k
    | ($k | split(":") | .[-1]) as $ep
    | (((.value.Handlers // {}) | to_entries | .[0].value.Proxy) // "") as $proxy
    | [$ep, (if $root.AllowFunnel[$host + ":" + $ep] == true then "funnel" else "tailnet" end), $proxy]
    | @tsv
  ' 2>/dev/null)

  local ep mode proxy lbind lport url health
  while IFS=$'\t' read -r ep mode proxy; do
    [[ -z "$ep" ]] && continue
    lbind=""
    lport=""

    if [[ "$proxy" =~ '^https?://(\[[^][]+\]|[^:/]+):([0-9]+)$' ]]; then
      lbind="$match[1]"
      lport="$match[2]"
    fi

    url="https://$hostname"
    [[ "$ep" != "443" ]] && url="https://$hostname:$ep"

    health="unknown"
    if [[ -n "$lport" ]]; then
      if [[ -n "${TSP_LISTEN_PID[$lport]}" ]]; then
        health="ok"
      else
        health="stale"
      fi
    fi

    TSP_SERVE_MODE[$ep]="$mode"
    TSP_SERVE_PROXY[$ep]="$proxy"
    TSP_SERVE_LPORT[$ep]="$lport"
    TSP_SERVE_LBIND[$ep]="$lbind"
    TSP_SERVE_URL[$ep]="$url"
    TSP_SERVE_HEALTH[$ep]="$health"
    TSP_SERVE_EPORTS+=("$ep")
  done <<< "$rows"

  TSP_SERVE_EPORTS=(${(on)TSP_SERVE_EPORTS})
}

_tsp_marker_for_local_port() {
  local local_port=$1
  local has_tailnet=0 has_funnel=0
  local ep
  for ep in "${TSP_SERVE_EPORTS[@]}"; do
    [[ "${TSP_SERVE_LPORT[$ep]}" == "$local_port" ]] || continue
    if [[ "${TSP_SERVE_MODE[$ep]}" == "funnel" ]]; then
      has_funnel=1
    else
      has_tailnet=1
    fi
  done

  if (( has_funnel )); then
    print -r -- "F"
  elif (( has_tailnet )); then
    print -r -- "*"
  else
    print -r -- "·"
  fi
}

_tsp_pick_local_port() {
  _tsp_need_cmds fzf || return 1
  _tsp_load_listeners

  local -a rows
  rows+=("[custom]  -       -                   -")

  local port
  for port in "${TSP_LISTEN_PORTS[@]}"; do
    rows+=("$(printf '%-8s %-7s %-20s %s' "$port" "${TSP_LISTEN_PID[$port]}" "${TSP_LISTEN_PROC[$port]}" "${TSP_LISTEN_BIND[$port]}")")
  done

  local selected
  selected=$(printf '%s\n' "${rows[@]}" | fzf --reverse --header='PORT     PID     PROCESS              BIND')
  [[ -z "$selected" ]] && return 1

  local chosen_port
  chosen_port=$(echo "$selected" | awk '{print $1}')
  if [[ "$chosen_port" == "[custom]" ]]; then
    chosen_port=$(_tsp_prompt_port) || return 1
  fi

  _tsp_port_valid "$chosen_port" || return 1
  print -r -- "$chosen_port"
}

_tsp_up_internal() {
  local local_port=$1
  local is_public=$2
  local https_port=$3

  local target
  target=$(_tsp_target_for_port "$local_port")

  local hostname url
  hostname=$(_tsp_hostname) || return 1
  url="https://$hostname"
  [[ "$https_port" != "443" ]] && url="https://$hostname:$https_port"

  if (( is_public )); then
    ts funnel --bg --yes --https="$https_port" "$target" || return 1
    echo "Funnel (public): $url  ->  $target"
  else
    ts serve --bg --https="$https_port" "$target" || return 1
    echo "Serve (tailnet): $url  ->  $target"
  fi
}

_tsp_down_internal() {
  local https_port=$1
  ts serve --https="$https_port" off
}

_tsp_up() {
  _tsp_need_cmds ts jq || return 1

  local public=0 apex=0 https_port="" local_port=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --public|-p) public=1; shift ;;
      --apex|-a) apex=1; shift ;;
      --https|--port)
        if [[ -z "$2" ]] || ! _tsp_port_valid "$2"; then
          print -u2 "error: $1 requires a numeric argument"
          return 1
        fi
        https_port="$2"
        shift 2
        ;;
      -h|--help)
        _tsp_usage
        return 0
        ;;
      *)
        if _tsp_port_valid "$1"; then
          local_port="$1"
          shift
        else
          print -u2 "error: invalid local port: $1"
          return 1
        fi
        ;;
    esac
  done

  if [[ -z "$local_port" ]]; then
    if [[ -t 0 && -t 1 ]]; then
      local_port=$(_tsp_pick_local_port) || return 1
    else
      print -u2 "error: local port required in non-interactive mode"
      return 1
    fi
  fi

  if [[ -z "$https_port" ]]; then
    if (( apex )); then
      https_port=443
    else
      https_port="$local_port"
    fi
  fi

  _tsp_up_internal "$local_port" "$public" "$https_port"
}

_tsp_down() {
  _tsp_need_cmds ts jq || return 1

  local assume_yes=0 https_port=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes|-y) assume_yes=1; shift ;;
      -h|--help)
        _tsp_usage
        return 0
        ;;
      *)
        if _tsp_port_valid "$1"; then
          https_port="$1"
          shift
        else
          print -u2 "error: invalid https port: $1"
          return 1
        fi
        ;;
    esac
  done

  _tsp_load_listeners
  _tsp_load_served || return 1

  if [[ ${#TSP_SERVE_EPORTS[@]} -eq 0 ]]; then
    echo "no active serve routes"
    return 0
  fi

  if [[ -z "$https_port" ]]; then
    if [[ ${#TSP_SERVE_EPORTS[@]} -eq 1 ]]; then
      https_port="${TSP_SERVE_EPORTS[1]}"
    else
      _tsp_need_cmds fzf || return 1
      local -a rows
      local ep
      for ep in "${TSP_SERVE_EPORTS[@]}"; do
        rows+=("$(printf '%-7s %-8s %-8s %s' "$ep" "${TSP_SERVE_MODE[$ep]}" "${TSP_SERVE_HEALTH[$ep]}" "${TSP_SERVE_PROXY[$ep]}")")
      done

      local selected
      selected=$(printf '%s\n' "${rows[@]}" | fzf --reverse --header='HTTPS   MODE     HEALTH   TARGET')
      [[ -z "$selected" ]] && return 0
      https_port=$(echo "$selected" | awk '{print $1}')
    fi
  fi

  if [[ -z "${TSP_SERVE_MODE[$https_port]}" ]]; then
    print -u2 "error: :$https_port is not currently served"
    return 1
  fi

  if (( ! assume_yes )); then
    _tsp_confirm "Remove :$https_port -> ${TSP_SERVE_PROXY[$https_port]}?" || return 1
  fi

  _tsp_down_internal "$https_port" || return 1
  echo "removed :$https_port -> ${TSP_SERVE_PROXY[$https_port]}"
}

_tsp_prune() {
  _tsp_need_cmds ts jq || return 1

  local assume_yes=0 dry_run=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes|-y) assume_yes=1; shift ;;
      --dry-run|-n) dry_run=1; shift ;;
      -h|--help)
        _tsp_usage
        return 0
        ;;
      *)
        print -u2 "error: unknown option: $1"
        return 1
        ;;
    esac
  done

  _tsp_load_listeners
  _tsp_load_served || return 1

  local -a stale_ports
  local ep
  for ep in "${TSP_SERVE_EPORTS[@]}"; do
    [[ "${TSP_SERVE_HEALTH[$ep]}" == "stale" ]] && stale_ports+=("$ep")
  done

  if [[ ${#stale_ports[@]} -eq 0 ]]; then
    echo "no stale routes"
    return 0
  fi

  echo "stale routes:"
  for ep in "${stale_ports[@]}"; do
    echo "  :$ep -> ${TSP_SERVE_PROXY[$ep]}"
  done

  if (( dry_run )); then
    return 0
  fi

  if (( ! assume_yes )); then
    _tsp_confirm "Remove ${#stale_ports[@]} stale route(s)?" || return 1
  fi

  local removed=0 failed=0
  for ep in "${stale_ports[@]}"; do
    if _tsp_down_internal "$ep" >/dev/null 2>&1; then
      echo "removed :$ep"
      (( removed++ ))
    else
      print -u2 "failed to remove :$ep"
      (( failed++ ))
    fi
  done

  echo "prune complete: removed $removed, failed $failed"
  (( failed == 0 ))
}

_tsp_ls() {
  _tsp_need_cmds ts jq || return 1

  local as_json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) as_json=1; shift ;;
      -h|--help)
        _tsp_usage
        return 0
        ;;
      *)
        print -u2 "error: unknown option: $1"
        return 1
        ;;
    esac
  done

  _tsp_load_listeners
  _tsp_load_served || return 1

  if (( as_json )); then
    if [[ ${#TSP_SERVE_EPORTS[@]} -eq 0 ]]; then
      echo '[]'
      return 0
    fi

    local -a rows
    local ep
    for ep in "${TSP_SERVE_EPORTS[@]}"; do
      rows+=("$(printf '%s\t%s\t%s\t%s\t%s\t%s' "$ep" "${TSP_SERVE_MODE[$ep]}" "${TSP_SERVE_HEALTH[$ep]}" "${TSP_SERVE_PROXY[$ep]}" "${TSP_SERVE_URL[$ep]}" "${TSP_SERVE_LPORT[$ep]}")")
    done

    printf '%s\n' "${rows[@]}" | jq -R -s '
      split("\n")
      | map(select(length > 0) | split("\t"))
      | map({
          httpsPort: (.[0] | tonumber),
          mode: .[1],
          status: .[2],
          proxy: .[3],
          url: .[4],
          localPort: (if .[5] == "" then null else (.[5] | tonumber) end)
        })
    '
    return 0
  fi

  if [[ ${#TSP_SERVE_EPORTS[@]} -eq 0 ]]; then
    echo "not serving"
    return 0
  fi

  printf '%-7s %-8s %-7s %-28s %s\n' "HTTPS" "MODE" "STATUS" "TARGET" "URL"
  local ep
  for ep in "${TSP_SERVE_EPORTS[@]}"; do
    printf '%-7s %-8s %-7s %-28s %s\n' \
      "$ep" \
      "${TSP_SERVE_MODE[$ep]}" \
      "${TSP_SERVE_HEALTH[$ep]}" \
      "${TSP_SERVE_PROXY[$ep]}" \
      "${TSP_SERVE_URL[$ep]}"
  done
}

_tsp_ui() {
  _tsp_need_cmds ts jq fzf || return 1

  while true; do
    _tsp_load_listeners
    _tsp_load_served || return 1

    local -a rows
    rows+=("$(printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s' "custom" "·" "-" "[custom]" "-" "-" "-" "-" "-" "-")")

    local ep pid proc bind serve_marker
    for ep in "${TSP_SERVE_EPORTS[@]}"; do
      pid="-"
      proc="-"
      bind="${TSP_SERVE_LBIND[$ep]}"
      if [[ -n "${TSP_SERVE_LPORT[$ep]}" && -n "${TSP_LISTEN_PID[${TSP_SERVE_LPORT[$ep]}]}" ]]; then
        pid="${TSP_LISTEN_PID[${TSP_SERVE_LPORT[$ep]}]}"
        proc="${TSP_LISTEN_PROC[${TSP_SERVE_LPORT[$ep]}]}"
        bind="${TSP_LISTEN_BIND[${TSP_SERVE_LPORT[$ep]}]}"
      fi
      serve_marker="*"
      [[ "${TSP_SERVE_MODE[$ep]}" == "funnel" ]] && serve_marker="F"
      rows+=("$(printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s' "serve" "$serve_marker" "$ep" "${TSP_SERVE_LPORT[$ep]:--}" "${TSP_SERVE_MODE[$ep]}" "${TSP_SERVE_HEALTH[$ep]}" "$pid" "$proc" "$bind" "${TSP_SERVE_PROXY[$ep]}")")
    done

    local port marker
    for port in "${TSP_LISTEN_PORTS[@]}"; do
      marker=$(_tsp_marker_for_local_port "$port")
      rows+=("$(printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s' "local" "$marker" "-" "$port" "local" "listening" "${TSP_LISTEN_PID[$port]}" "${TSP_LISTEN_PROC[$port]}" "${TSP_LISTEN_BIND[$port]}" "-")")
    done

    local header
    header="MARK HTTPS  LPORT   MODE     HEALTH     PID     PROCESS              BIND                 TARGET
enter: up  ctrl-a: up :443  ctrl-f: funnel  ctrl-d: down route  ctrl-x: prune stale  ctrl-r: refresh"

    local selection
    selection=$(printf '%s\n' "${rows[@]}" | fzf --reverse \
      --delimiter=$'\t' \
      --with-nth=2,3,4,5,6,7,8,9,10 \
      --expect=ctrl-a,ctrl-f,ctrl-d,ctrl-x,ctrl-r \
      --header="$header" \
      --preview='
        row="{}"
        type=$(printf "%s" "$row" | awk -F "\t" "{print \$1}")
        marker=$(printf "%s" "$row" | awk -F "\t" "{print \$2}")
        eport=$(printf "%s" "$row" | awk -F "\t" "{print \$3}")
        lport=$(printf "%s" "$row" | awk -F "\t" "{print \$4}")
        mode=$(printf "%s" "$row" | awk -F "\t" "{print \$5}")
        health=$(printf "%s" "$row" | awk -F "\t" "{print \$6}")
        pid=$(printf "%s" "$row" | awk -F "\t" "{print \$7}")
        proc=$(printf "%s" "$row" | awk -F "\t" "{print \$8}")
        bind=$(printf "%s" "$row" | awk -F "\t" "{print \$9}")
        target=$(printf "%s" "$row" | awk -F "\t" "{print \$10}")

        echo "Type:    $type"
        echo "Mark:    $marker"
        echo "HTTPS:   $eport"
        echo "Local:   $lport"
        echo "Mode:    $mode"
        echo "Health:  $health"
        echo "PID:     $pid"
        echo "Process: $proc"
        echo "Bind:    $bind"
        echo "Target:  $target"
      ' \
      --preview-window=right:55%:wrap)

    [[ -z "$selection" ]] && return 0

    local key chosen
    key=$(printf '%s\n' "$selection" | head -n1)
    chosen=$(printf '%s\n' "$selection" | tail -n1)
    [[ -z "$chosen" ]] && continue

    local row_type marker eport lport mode health pid proc bind target
    IFS=$'\t' read -r row_type marker eport lport mode health pid proc bind target <<< "$chosen"

    case "$key" in
      ctrl-r)
        continue
        ;;
      ctrl-x)
        _tsp_prune
        continue
        ;;
      ctrl-d)
        if [[ "$row_type" != "serve" ]] || ! _tsp_port_valid "$eport"; then
          print -u2 "select a served route to remove"
          continue
        fi
        _tsp_down "$eport"
        continue
        ;;
    esac

    local selected_port="$lport"
    if [[ "$row_type" == "custom" ]]; then
      selected_port=$(_tsp_prompt_port) || continue
    fi

    if ! _tsp_port_valid "$selected_port"; then
      print -u2 "selected row has no valid local port"
      continue
    fi

    case "$key" in
      ctrl-a)
        _tsp_up_internal "$selected_port" 0 443
        ;;
      ctrl-f)
        _tsp_up_internal "$selected_port" 1 "$selected_port"
        ;;
      *)
        _tsp_up_internal "$selected_port" 0 "$selected_port"
        ;;
    esac
  done
}

main() {
  _tsp_need_cmds ts jq || return 1

  local subcommand=""
  if [[ $# -gt 0 ]]; then
    subcommand="$1"
    shift
  else
    if [[ -t 0 && -t 1 ]]; then
      subcommand="ui"
    else
      subcommand="ls"
    fi
  fi

  case "$subcommand" in
    ui)
      _tsp_ui "$@"
      ;;
    ls|status)
      _tsp_ls "$@"
      ;;
    up)
      _tsp_up "$@"
      ;;
    down|off)
      _tsp_down "$@"
      ;;
    prune)
      _tsp_prune "$@"
      ;;
    help|-h|--help)
      _tsp_usage
      ;;
    *)
      print -u2 "unknown subcommand: $subcommand"
      _tsp_usage
      return 1
      ;;
  esac
}

main "$@"

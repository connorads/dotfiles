#!/usr/bin/env zsh
# tmux-upstream: check pinned tmux plugins for upstream updates
emulate -L zsh

local verbose=false
[[ "$1" == "-v" || "$1" == "--verbose" ]] && verbose=true

local nixmod="$HOME/.config/nix/modules/home-shared.nix"
if [[ ! -f "$nixmod" ]]; then
  print -u2 "home-shared.nix not found at $nixmod"
  return 1
fi

# Parse pins: pin_tmux_plugin "<name>" "<owner/repo>" "<sha>"
local -a pins
pins=("${(@f)$(sed -nE 's/^[[:space:]]*pin_tmux_plugin "([^"]+)" "([^"]+)" "([^"]+)".*/\1 \2 \3/p' "$nixmod")}")

if [[ ${#pins} -eq 0 || -z "${pins[1]}" ]]; then
  print -u2 "No pin_tmux_plugin entries found in $nixmod"
  return 1
fi

local max_name=0 name repo sha
for pin in "${pins[@]}"; do
  name="${pin%% *}"
  (( ${#name} > max_name )) && max_name=${#name}
done

local has_behind=false
local branch compare behind commits

for pin in "${pins[@]}"; do
  name="${pin%% *}"
  repo="${${pin#* }%% *}"
  sha="${pin##* }"

  branch=$(gh api "repos/$repo" --jq '.default_branch' 2>/dev/null)
  if [[ -z "$branch" ]]; then
    printf "  %-${max_name}s   ? could not query $repo\n" "$name"
    continue
  fi

  # Compare: base=pinned sha, head=upstream branch → ahead_by = commits behind
  compare=$(gh api "repos/$repo/compare/${sha}...${branch}" \
    --jq '{behind: .ahead_by, commits: [.commits[] | .commit.message | split("\n")[0]]}' 2>/dev/null)
  if [[ -z "$compare" ]]; then
    printf "  %-${max_name}s   ? compare failed\n" "$name"
    continue
  fi

  behind=$(echo "$compare" | jq -r '.behind')

  if [[ "$behind" -eq 0 ]]; then
    printf "  %-${max_name}s   ✓ up to date\n" "$name"
  else
    has_behind=true
    printf "  %-${max_name}s   ⚠ %d commit%s behind\n" "$name" "$behind" "$( (( behind > 1 )) && echo s)"
    if $verbose; then
      commits=$(echo "$compare" | jq -r '.commits[] | "      · " + .')
      echo "$commits"
    fi
  fi
done

if $has_behind; then
  echo ""
  echo "Update: review the upstream diff, then bump the sha in"
  echo "  $nixmod (pin_tmux_plugin line) and rebuild (drs/hms)."
fi

# usage-cache-lib: shared cache/lock/backoff engine for the usage trackers
#
# Sourced (not executed) by claude-usage, codex-usage, and cosine-usage. Defines functions
# only — no top-level side effects — so callers keep full control of options.
# The helpers read caller-scope locals via zsh dynamic scope, so each caller
# must declare these as `local` before sourcing/calling:
#   now, cache, meta, lockdir, hdr, body, ttl,
#   backoff_base, backoff_max, lock_stale_after

_mtime() {
    local file="$1"
    stat -f%m "$file" 2>/dev/null || stat -c '%Y' "$file" 2>/dev/null || echo 0
}

_cache_age() {
    local file="$1"
    [[ -f "$file" ]] || { echo 999999; return; }
    local mtime
    mtime=$(_mtime "$file")
    echo $((now - mtime))
}

_lock_age() {
    local started_file="$1/started_at"
    local started_at
    if [[ -f "$started_file" ]]; then
        started_at=$(<"$started_file")
        if [[ "$started_at" == <-> ]]; then
            echo $((now - started_at))
            return
        fi
    fi
    echo $((now - $(_mtime "$1")))
}

_lock_is_live() {
    local pid_file="$1/pid"
    local pid
    [[ -f "$pid_file" ]] || return 1
    pid=$(<"$pid_file")
    [[ "$pid" == <-> ]] || return 1
    kill -0 "$pid" 2>/dev/null
}

_cleanup_lock() {
    rm -f "$lockdir/pid" "$lockdir/started_at" 2>/dev/null
    rmdir "$lockdir" 2>/dev/null
}

_cleanup() {
    rm -f "${hdr:-}" "${body:-}"
    _cleanup_lock
}

_reap_stale_lock() {
    [[ -d "$lockdir" ]] || return 0
    local age_lock
    age_lock=$(_lock_age "$lockdir")
    if _lock_is_live "$lockdir" && [[ "$age_lock" -lt "$lock_stale_after" ]]; then
        return 1
    fi
    _cleanup_lock
    [[ ! -d "$lockdir" ]]
}

_acquire_lock() {
    if mkdir "$lockdir" 2>/dev/null; then
        print -r -- "$$" > "$lockdir/pid"
        print -r -- "$now" > "$lockdir/started_at"
        return 0
    fi
    _reap_stale_lock || return 1
    if mkdir "$lockdir" 2>/dev/null; then
        print -r -- "$$" > "$lockdir/pid"
        print -r -- "$now" > "$lockdir/started_at"
        return 0
    fi
    return 1
}

_fmt_secs() {
    local diff="$1"
    [[ "$diff" -lt 0 ]] && diff=0
    local d=$((diff / 86400))
    local h=$(((diff % 86400) / 3600))
    local m=$(((diff % 3600) / 60))
    if [[ $d -gt 0 ]]; then
        echo "${d}d ${h}h"
    else
        echo "${h}h ${m}m"
    fi
}

_write_meta() {
    local next="$1"
    local fails="$2"
    local http_status="$3"
    local err="$4"
    local success="$5"
    local tmp
    tmp="${meta}.tmp.$$"
    mkdir -p "$(dirname "$meta")"
    jq -n \
      --argjson next_retry_at "$next" \
      --argjson fail_count "$fails" \
      --arg last_http_status "$http_status" \
      --arg last_error "$err" \
      --argjson last_success_at "$success" \
      '{
        next_retry_at: $next_retry_at,
        fail_count: $fail_count,
        last_http_status: $last_http_status,
        last_error: $last_error,
        last_success_at: $last_success_at
      }' > "$tmp" && mv "$tmp" "$meta"
}

# Pause auth failures until Claude Code refreshes credentials. OAuth refresh is
# deliberately left to Claude Code: external refreshes can race active sessions.
_write_auth_paused() {
    local http_status="$1"
    local detail="$2"
    local success="$3"
    local auth_expires_at="$4"
    local tmp
    tmp="${meta}.tmp.$$"
    mkdir -p "$(dirname "$meta")"
    jq -n \
      --arg last_http_status "${http_status:-401}" \
      --arg last_error_detail "${detail:-auth_expired}" \
      --argjson last_success_at "${success:-0}" \
      --argjson auth_paused_at "$now" \
      --arg auth_expires_at "${auth_expires_at:-}" \
      '{
        next_retry_at: 0,
        fail_count: 0,
        last_http_status: $last_http_status,
        last_error: "auth_expired",
        last_error_detail: $last_error_detail,
        last_success_at: $last_success_at,
        auth_paused_at: $auth_paused_at,
        auth_expires_at: ($auth_expires_at | tonumber? // null)
      }' > "$tmp" && mv "$tmp" "$meta"
}

# Record a failed fetch: grow the cooldown geometrically from $backoff_base,
# clamp to $backoff_max, honour a numeric retry-after override, then persist
# the new next-retry time via _write_meta. Callers pass their own resolved
# error/http details so provider-specific extraction stays inline.
#   _record_failure <fail_count> <retry_after> <http> <err> <last_success>
_record_failure() {
    local fail_count="$1"
    local retry_after="$2"
    local http="$3"
    local err="$4"
    local last_success="$5"
    local next_fail_count cooldown i=1
    next_fail_count=$((fail_count + 1))
    cooldown=$backoff_base
    while [[ $i -lt $next_fail_count ]]; do
        cooldown=$((cooldown * 2))
        [[ "$cooldown" -ge "$backoff_max" ]] && { cooldown=$backoff_max; break; }
        i=$((i + 1))
    done
    if [[ "$retry_after" == <-> ]] && [[ "$retry_after" -gt 0 ]]; then
        cooldown="$retry_after"
    fi
    [[ "$cooldown" -gt "$backoff_max" ]] && cooldown=$backoff_max
    _write_meta $((now + cooldown)) "$next_fail_count" "${http:-0}" "${err:-fetch_failed}" "$last_success"
}

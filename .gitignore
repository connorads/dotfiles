# jj: track config only; ~/.config/jj/repos/ is machine-local per-repo state
!/.config/jj/
/.config/jj/**
!/.config/jj/config.toml

# skills curation home: real files (authored + vendored). Un-ignore the dir,
# re-ignore its contents, then un-ignore the doc files and each subtree.
!/.config/skills/
/.config/skills/**
!/.config/skills/AGENTS.md
!/.config/skills/CLAUDE.md
# public is a compat symlink → ../../skills (real files live at ~/skills)
!/.config/skills/public
!/.config/skills/personal/
!/.config/skills/personal/**
!/.config/skills/vendor/
!/.config/skills/vendor/**

# raycast extension source (tracked source-only; the built bundle lives in the
# machine-local ~/.config/raycast/, which stays untracked). pnpm-lock.yaml IS
# tracked for supply-chain audit; node_modules + generated files are not.
!/.config/raycast-ext/
!/.config/raycast-ext/**
/.config/raycast-ext/**/node_modules/
/.config/raycast-ext/**/dist/
/.config/raycast-ext/**/raycast-env.d.ts
/.config/raycast-ext/**/*.js.map
/.config/raycast-ext/**/*.tsbuildinfo


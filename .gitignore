# Deny by default: `/*` covers the top level, `**` every depth below it. Both
# stay at the top - last match wins, so a deny rule placed further down silently
# resets every un-ignore above it.
/*
**

# Local machine-only profile/secrets state. These are already covered by the
# deny-by-default rule above; the explicit entries document the intended privacy
# boundary and defend against future un-ignore churn.
/.claude-profiles/
/.config/claude-profiles/
/.secrets/
/.zshrc.local

!.gitignore
!/.gitattributes
!/.gitleaks.toml
!/.npmrc
!/.yarnrc.yml
!/.bunfig.toml
!/.rumdl.toml
!/hk.pkl

!/.hk-hooks/
!/.hk-hooks/**

!/.github/
!/.github/**

!/.fresh/
!/.fresh/config.json

!/.agents/
/.agents/**
!/.agents/AGENTS.md
!/.agents/README.md
!/.agents/.skill-lock.json
!/.agents/skills/
!/.agents/skills/**
/.agents/skills/.system/

!/.claude/
/.claude/**
!/.claude/skills/
/.claude/skills/**
!/.claude/skills/*
!/.claude/commands/
!/.claude/commands/**
!/.claude/hooks/
!/.claude/hooks/**
!/.claude/system-append.md

!/.codex/
/.codex/**
!/.codex/config.toml
!/.codex/hooks.json
!/.codex/rules/
!/.codex/rules/safety.rules
!/.codex/skills/
/.codex/skills/**
!/.codex/skills/*
!/.codex/skills/playwright-interactive/
!/.codex/skills/playwright-interactive/**

!/.config/
/.config/**
!/.config/opencode/
/.config/opencode/**
!/.config/opencode/tui.json
!/.config/opencode/themes/
!/.config/opencode/themes/catppuccin-mocha.json
!/.config/opencode/command/
!/.config/opencode/command/**
!/.config/opencode/skills/
/.config/opencode/skills/**
!/.config/opencode/skills/*
!/.config/opencode/plugin/
!/.config/opencode/plugin/**
!/.config/opencode/plugin-disabled/
!/.config/opencode/plugin-disabled/**

!/.config/agents/
/.config/agents/**
!/.config/agents/skills/
/.config/agents/skills/**
!/.config/agents/skills/*

!/.config/skl/
!/.config/skl/**
/.config/skl/node_modules/


# public skills home (authoring root; symlinked from .config/skills/public).
# Staged here for a future standalone connorads/skills repo.
!/skills/
!/skills/**

!/.config/pip/
!/.config/pip/pip.conf

# build-wrap allowlist (crates whose build.rs runs unsandboxed)
!/.config/build-wrap/
!/.config/build-wrap/**

# srt sandbox config (agent-sandbox). shadow-bin wrappers are un-ignored below
# the .local block (last-match-wins ordering vs /.local/**).
!/.config/srt/
!/.config/srt/**

# sbx: Dockerfile for the untrusted-software sandbox container (see sbx function)
!/.config/sbx/
!/.config/sbx/**

# jj: track config only; ~/.config/jj/repos/ is machine-local per-repo state
!/.config/jj/
/.config/jj/**
!/.config/jj/config.toml

# skills curation home: real files (authored + vendored). Un-ignore the dir,
# re-ignore its contents, then un-ignore the doc files and each subtree.
!/.config/skills/
/.config/skills/**
!/.config/skills/AGENTS.md
!/.config/skills/CLAUDE.md
# public is a compat symlink → ../../skills (real files live at ~/skills)
!/.config/skills/public
!/.config/skills/personal/
!/.config/skills/personal/**
!/.config/skills/vendor/
!/.config/skills/vendor/**
# skills CLI fans project skills into .claude/skills as symlinks on every
# `skills update` (machine-generated; the tracked copy is .agents/skills)
/.config/skills/vendor/.claude/

# Raycast extension source (tracked source-only; the built bundle lives in the
# machine-local ~/.config/raycast/, which stays untracked). pnpm-lock.yaml IS
# tracked for supply-chain audit; node_modules + generated files are not.
!/src/
!/src/raycast/
!/src/raycast/**
/src/raycast/**/node_modules/
/src/raycast/**/dist/
/src/raycast/**/raycast-env.d.ts
/src/raycast/**/*.js.map
/src/raycast/**/*.tsbuildinfo

# Dotfiles docs site (Astro Starlight; served at dotfiles.connoradams.co.uk).
# The project's own .gitignore handles node_modules/dist/.astro.
!/src/dotfiles-docs/
!/src/dotfiles-docs/**

!/.pi/
/.pi/**
!/.pi/agent/
/.pi/agent/**
!/.pi/agent/AGENTS.md
!/.pi/agent/models.json
!/.pi/agent/settings.json
!/.pi/agent/keybindings.json
!/.pi/agent/extensions/
!/.pi/agent/extensions/**
/.pi/agent/extensions/**/node_modules/
/.pi/agent/extensions/**/pnpm-lock.yaml
!/.pi/agent/extensions/pnpm-lock.yaml
!/.pi/agent/extensions/pi-palette/pnpm-lock.yaml
!/.pi/agent/extensions/goal/pnpm-lock.yaml
!/.pi/agent/extensions/workflows/pnpm-lock.yaml
!/.pi/agent/skills/
/.pi/agent/skills/**
!/.pi/agent/skills/*

!/.config/nix/
!/.config/nix/**

!/.config/nvim/
!/.config/nvim/init.lua
!/.config/nvim/lazy-lock.json
!/.config/nvim/help.md
!/.config/nvim/practice.md
!/.config/nvim/lua/
!/.config/nvim/lua/**

!/.config/fresh/
/.config/fresh/**
!/.config/fresh/config.json
!/.config/fresh/help.md
!/.config/fresh/themes/
!/.config/fresh/themes/catppuccin-mocha.json

!/.config/tealdeer/
!/.config/tealdeer/config.toml

!/.config/kitty/
!/.config/kitty/**

!/.config/zed/
!/.config/zed/settings.json
!/.config/zed/keymap.json

!/.config/tmux/
!/.config/tmux/**
/.config/tmux/plugins/

!/.config/zellij/
!/.config/zellij/**

!/.config/lazygit/
!/.config/lazygit/**
/.config/lazygit/state.yml

!/.config/micro/
!/.config/micro/settings.json
!/.config/micro/colorschemes/
!/.config/micro/colorschemes/**

# mcp: track the example registry + subsystem doc only; registry.local.json
# (the only place client names/URLs live) stays ignored by the /.config/** rule.
!/.config/mcp/
!/.config/mcp/registry.example.json
!/.config/mcp/AGENTS.md

!/.config/mise/
!/.config/mise/**

!/.config/uv/
!/.config/uv/uv.toml

!/.config/pnpm/
!/.config/pnpm/rc
!/.config/pnpm/config.yaml

!/.config/remobi/
!/.config/remobi/remobi.config.ts

!/.config/bun/
!/.config/bun/critique-tsconfig.json

!/.config/aube/
!/.config/aube/config.toml

!/.config/zsh/
!/.config/zsh/.editorconfig
!/.config/zsh/aliases/
!/.config/zsh/aliases/**
!/.config/zsh/functions/
!/.config/zsh/functions/**
!/.config/zsh/tests/
!/.config/zsh/tests/**

!/.config/claude-watcher/
!/.config/claude-watcher/**

# gh-gate secrets (tokens, PEM, config with IDs)
/.config/gh-gate/

.DS_Store
__pycache__/

# cargo: track global config only (build-wrap linker); bin/registry are local
!/.cargo/
/.cargo/**
!/.cargo/config.toml

!/.local/
/.local/**
!/.local/bin/
!/.local/bin/**
/.local/bin/claude
/.local/bin/browser-harness

# agent-sandbox shadow-bin wrappers (symlinks to ~/.local/bin/agent-sandbox).
# Two levels deep, so re-include the share parent dir then the subtree.
!/.local/share/
!/.local/share/shadow-bin/
!/.local/share/shadow-bin/**

# tmux agent branch menus
!/.config/
!/.config/tmux/
!/.config/tmux/scripts/
!/.config/tmux/scripts/agent-branch-menu.sh
!/.config/tmux/scripts/codex-branch-menu.sh
!/.config/tmux/scripts/lib/
!/.config/tmux/scripts/lib/agent-session.sh
!/.config/zsh/
!/.config/zsh/tests/
!/.config/zsh/tests/agent-branch-menu.bats
!/.config/zsh/tests/codex-branch-menu.bats
!/.config/zsh/tests/agent-session-lib.bats

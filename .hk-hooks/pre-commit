#!/bin/sh

if [ "${HK:-1}" = "0" ]; then
  exit 0
fi

HK_BIN=""
if command -v hk >/dev/null 2>&1; then
  HK_BIN="$(command -v hk)"
elif command -v mise >/dev/null 2>&1; then
  HK_BIN="$(mise which hk 2>/dev/null || true)"
elif [ -x "$HOME/.nix-profile/bin/mise" ]; then
  HK_BIN="$($HOME/.nix-profile/bin/mise which hk 2>/dev/null || true)"
elif [ -x "$HOME/.local/bin/mise" ]; then
  HK_BIN="$($HOME/.local/bin/mise which hk 2>/dev/null || true)"
fi

if [ -z "$HK_BIN" ]; then
  echo "hk not found. Install tools with: mise install" >&2
  exit 1
fi

# Run hk from the real work-tree ($HOME). A previous tmpdir approach (a gitdir
# pointer + hk.pkl symlink, then cd into the tmpdir) made hk resolve staged
# files relative to that tmpdir, so only the symlinked hk.pkl was ever checked
# and every dot-path file — i.e. almost the entire repo — was silently skipped.
# core.worktree is already $HOME and hk.pkl lives at $HOME/hk.pkl, so running
# from $HOME is correct and simpler.
#
# HK_STASH_UNTRACKED=false: the work-tree is $HOME, so skip hk's untracked-file
# scan, which would otherwise walk all of $HOME (tens of seconds) — see hk docs
# on YADM-style repos where GIT_WORK_TREE is $HOME.
cd "$HOME" || exit 1
export GIT_DIR="$HOME/git/dotfiles"
export GIT_WORK_TREE="$HOME"
export HK_STASH_UNTRACKED=false
exec "$HK_BIN" run pre-commit "$@"

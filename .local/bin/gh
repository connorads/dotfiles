#!/bin/sh
# gh: wrapper that reads gh-gate token files dynamically
# Ensures gh-gate grant/revoke take effect in already-running sessions

config_dir="$HOME/.config/gh-gate"

# Only assert gh-gate's token on hosts gh-gate actually manages, i.e. where it
# has deployed a token file. The granting host (and any unmanaged host) holds at
# most config, so stay transparent: leave the caller's GH_TOKEN untouched (lets
# e.g. Homebrew's own token through; gh still falls back to the keyring).
if [ -r "$config_dir/active-token" ] || [ -r "$config_dir/readonly-token" ]; then
  unset GH_TOKEN   # gh-gate's revocable file token is authoritative here

  if [ -r "$config_dir/active-token" ] && [ -r "$config_dir/active-token-expires" ]; then
    expires=$(cat "$config_dir/active-token-expires")
    now=$(date +%s)
    if [ "$now" -lt "$expires" ] 2>/dev/null; then
      export GH_TOKEN=$(cat "$config_dir/active-token")
    elif [ -r "$config_dir/readonly-token" ]; then
      export GH_TOKEN=$(cat "$config_dir/readonly-token")
    fi
  elif [ -r "$config_dir/readonly-token" ]; then
    export GH_TOKEN=$(cat "$config_dir/readonly-token")
  fi
fi

# Find real gh by skipping this wrapper's directory
real_gh=""
OLDIFS="$IFS"; IFS=':'
for dir in $PATH; do
  case "$dir" in
    "$HOME/.local/bin"|"$HOME/.local/bin/") continue ;;
    "$HOME/.local/share/mise/shims"|"$HOME/.local/share/mise/shims/") continue ;;
  esac
  [ -x "$dir/gh" ] && real_gh="$dir/gh" && break
done
IFS="$OLDIFS"

# Callers with a sanitised PATH (e.g. Homebrew attestation verification) may
# drop the nix profile dirs where gh lives. Fall back to known absolute paths.
if [ -z "$real_gh" ]; then
  gh_user="${USER:-${HOME##*/}}"
  for cand in \
    "/etc/profiles/per-user/$gh_user/bin/gh" \
    "$HOME/.nix-profile/bin/gh" \
    "/run/current-system/sw/bin/gh" \
    /opt/homebrew/bin/gh \
    /usr/local/bin/gh \
    /usr/bin/gh; do
    [ -x "$cand" ] && real_gh="$cand" && break
  done
fi

if [ -z "$real_gh" ]; then
  echo "gh wrapper: cannot find real gh in PATH" >&2
  exit 127
fi

exec "$real_gh" "$@"

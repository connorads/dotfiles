# API Keys and secrets for local machine
# This file is gitignored and won't be committed to dotfiles
#
# It holds live secrets, so keep it owner-only:
#   chmod 600 ~/.zshrc.local

# Brave Search API - https://brave.com/search/api/
export BRAVE_API_KEY=

# Context7 API - https://context7.com/
export CONTEXT7_API_KEY=

# ElevenLabs API - https://elevenlabs.io/app/settings/api-keys
export ELEVENLABS_API_KEY=

# Exa API - https://exa.ai/
export EXA_API_KEY=

# Gemini API - https://ai.google.dev/
export GEMINI_API_KEY=

# xAI API (Grok) - https://console.x.ai/
export XAI_API_KEY=

# Homebrew GitHub API token - https://github.com/settings/personal-access-tokens
# Zero-permission fine-grained PAT. Lifts anon GitHub API limit (60/hr -> 5000/hr)
# so HOMEBREW_VERIFY_ATTESTATIONS (.zshrc) can verify bottle provenance during bulk
# `up` upgrades without rate-limiting. No scopes required.
# export HOMEBREW_GITHUB_TOKEN=

# Same PAT, indirected for mise. mise resolves version tags / lockfiles via the
# GitHub API and hits the 60/hr anonymous ceiling without a token. Use the
# mise-namespaced MISE_GITHUB_TOKEN, NOT the shared GITHUB_TOKEN: gh/git also read
# GITHUB_TOKEN and would auth with this zero-perm PAT, 404ing private org repos
# (the gh keyring token has that access). MISE_GITHUB_TOKEN is read only by mise.
# export MISE_GITHUB_TOKEN=$HOMEBREW_GITHUB_TOKEN

# Add more API keys as needed:
# export FIGMA_API_KEY="..."
# export SENTRY_API_KEY="..."

# Claude account launchers (examples only; keep real names local/uncommitted).
# `ccp default` runs the plain ~/.claude account; `ccp <name>` runs the
# isolated ~/.claude-profiles/code/<name> profile (CLAUDE_CONFIG_DIR, with
# ambient auth-override env vars scrubbed). `ccp` with no arg opens an fzf picker.
# Define private 2-char muscle-memory aliases for the accounts you use:
# alias cp1='ccp default'
# alias cw='ccp account1 --append-system-prompt-file "$HOME/.claude/system-append.md"'
# alias cw2='ccp account2'
# Desktop profiles use ~/.claude-profiles/desktop/<name> as --user-data-dir:
# alias cdp1='claude-desktop-profile personal'
# alias cdp2='claude-desktop-profile account1'

# NixOS only: path to the NixOS flake for this machine
# export NIXOS_FLAKE="$HOME/git/rpi5"

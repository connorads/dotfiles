// Dotfiles hk configuration - fast pre-commit checks for staged files.
amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Builtins.pkl"

exclude = List(".git", "git", "node_modules", ".cache", ".local", ".npm", ".cargo", ".rustup", ".vscode-server")

display_skip_reasons = List()
terminal_progress = false

// Vendored third-party skills are a faithful mirror of upstream. Reformatting
// them (rumdl/whitespace) would make our copy diverge from upstream, so every
// `skills update` diff carries formatting churn — which defeats the security
// diff-review the update-vendored-skills skill relies on. Exclude them from the
// formatting steps only; gitleaks + merge-conflict checks still run on them.
local vendored_skills = List("**/vendor/.agents/skills/**", "**/.agents/skills/playwright-cli/**")

// Patch files are byte-exact: a blank context line is a single space and
// trailing whitespace can be significant, so reformatting them silently
// corrupts the diff (git apply rejects it; patch only tolerates it by luck).
// Exclude every *.patch from the whitespace fixers.
local no_reformat = vendored_skills + List("**/*.patch")

local fast_steps = new Mapping<String, Step> {
    ["trailing-whitespace"] = (Builtins.trailing_whitespace) { exclude = no_reformat }
    ["newlines"] = (Builtins.newlines) { exclude = no_reformat }
    ["check-merge-conflict"] = (Builtins.check_merge_conflict) {}

    ["shfmt"] = (Builtins.shfmt) {
        batch = true
    }

    ["shellcheck"] = (Builtins.shellcheck) {
        batch = true
    }

    ["zsh-syntax"] {
        glob = List(".zshrc", ".zprofile", ".zshenv", ".config/zsh/functions/**")
        check = "zsh -n {{files}}"
    }

    ["nixfmt"] = (Builtins.nix_fmt) {
        batch = true
    }

    ["rumdl"] = (Builtins.rumdl) {
        batch = true
        exclude = vendored_skills
    }

    ["mise"] = Builtins.mise

    // Guard the tmux dimming patches against accidental removal. Vanilla tmux
    // builds fine without them, so dropping a patch from the flake overlay
    // silently loses inactive-pane dimming with no build error. Fire whenever
    // flake.nix or a patch file is staged, and assert both are still wired up.
    ["tmux-patches"] {
        glob = List(
            ".config/nix/flake.nix",
            ".config/nix/patches/dim-inactive-panes.patch",
            ".config/nix/patches/force-redraw-on-focus-change.patch"
        )
        check = "rg -q 'dim-inactive-panes.patch' .config/nix/flake.nix && rg -q 'force-redraw-on-focus-change.patch' .config/nix/flake.nix || { echo 'flake.nix no longer references both tmux dimming patches (see .config/nix/patches/README.md)' >&2; exit 1; }"
    }

    ["codex-config-trust"] {
        glob = List(".codex/config.toml")
        check = "git show :{{files}} | rg -q '^\\[projects\\.' && { echo '.codex/config.toml contains staged machine-local [projects.*] trust state' >&2; exit 1; } || exit 0"
    }

    // Block local Claude profile aliases/state and auth override variables that
    // can be forced past .gitignore with `git add -f`. The guard permits the
    // tracked generic launcher implementation, but not concrete profile names.
    ["claude-profile-leak-guard"] {
        check = "python3 .hk-hooks/claude-profile-leak-guard.py"
    }

    // Keep Claude and OpenCode security denies in lock-step (R6 drift guard).
    // Fires whenever a relevant config, the gh-api gate hook, or the checker
    // itself is staged. Runs from $HOME, so the checker's cwd-relative paths
    // resolve.
    ["permission-parity"] {
        glob = List(
            ".claude/settings.json",
            ".config/opencode/opencode.json",
            ".claude/hooks/guard-mutating-api.py",
            ".hk-hooks/permission-parity.py"
        )
        check = "python3 .hk-hooks/permission-parity.py"
    }

    // Authored agent skills must pass writing-skills' checker: spec errors
    // (invalid frontmatter, unknown keys, name/dir mismatch) block the commit;
    // hygiene findings (orphans, doc-rot phrasing, missing TOCs) print only.
    // Authored tiers only - vendored skills mirror upstream and aren't ours
    // to gate.
    ["skill-check"] {
        glob = List("skills/**", ".config/skills/personal/**")
        check = "bash .hk-hooks/skill-check.sh {{files}}"
    }

    // Secret scan: block staged secrets before they enter this public repo.
    // gitleaks reads the staged diff itself (`git --staged`), so no per-file
    // glob — the step runs once per commit. --redact keeps any match out of
    // the hook output. Backstops the /* deny-all against an `add -f` / stray
    // un-ignore; it is defence-in-depth, not the only guard.
    ["gitleaks"] {
        check = "gitleaks git --staged --no-banner --redact"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = fast_steps
    }

    ["fix"] {
        fix = true
        stash = "git"
        steps = fast_steps
    }

    ["check"] {
        steps = fast_steps
    }
}

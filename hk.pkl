// Dotfiles hk configuration - fast pre-commit checks for staged files.
amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Builtins.pkl"

exclude = List(".git", "git", "node_modules", ".cache", ".local", ".npm", ".cargo", ".rustup", ".vscode-server")

display_skip_reasons = List()
terminal_progress = false

// Vendored third-party skills are a faithful mirror of upstream. Reformatting
// them (rumdl/whitespace) would make our copy diverge from upstream, so every
// `skills update` diff carries formatting churn — which defeats the security
// diff-review the update-vendored-skills skill relies on. Exclude them from the
// formatting steps only; gitleaks + merge-conflict checks still run on them.
// skill-patch hunk files (patches/**) mirror upstream bytes too and must not
// be reformatted/linted either.
local vendored_skills = List("**/vendor/.agents/skills/**", "**/.agents/skills/playwright-cli/**", ".config/skills/vendor/patches/**")

// Patch files are byte-exact: a blank context line is a single space and
// trailing whitespace can be significant, so reformatting them silently
// corrupts the diff (git apply rejects it; patch only tolerates it by luck).
// Exclude every *.patch from the whitespace fixers.
local no_reformat = vendored_skills + List("**/*.patch")

local fast_steps = new Mapping<String, Step> {
    ["trailing-whitespace"] = (Builtins.trailing_whitespace) { exclude = no_reformat }
    ["newlines"] = (Builtins.newlines) { exclude = no_reformat }
    ["check-merge-conflict"] = (Builtins.check_merge_conflict) {}

    // Vendored scripts mirror upstream too: don't reformat (divergence) or lint
    // (upstream's style findings aren't ours to fix) — security review happens
    // in the update-vendored-skills diff flow instead.
    ["shfmt"] = (Builtins.shfmt) {
        batch = true
        exclude = vendored_skills
    }

    ["shellcheck"] = (Builtins.shellcheck) {
        batch = true
        exclude = vendored_skills
    }

    ["zsh-syntax"] {
        glob = List(".zshrc", ".zprofile", ".zshenv", ".config/zsh/functions/**")
        // Non-zsh helpers living under functions/ (e.g. the codex-windows.jq
        // classifier) would fail `zsh -n`; they carry their own extension.
        exclude = List("**/*.jq")
        check = "zsh -n {{files}}"
    }

    // Shell Function Conventions (AGENTS.md): `# <name>: <purpose>` header,
    // and dual-mode shebang XOR a `# zsh-only: <reason>` marker.
    ["zsh-fn-header"] {
        glob = List(".config/zsh/functions/**")
        exclude = List("**/*.jq")
        check = "bash .hk-hooks/zsh-fn-header-check.sh {{files}}"
    }

    ["nixfmt"] = (Builtins.nix_fmt) {
        batch = true
    }

    ["rumdl"] = (Builtins.rumdl) {
        batch = true
        exclude = vendored_skills
    }

    // First-party JS/TS lint: default correctness rules only (no type-aware
    // rules - several first-party dirs lack tsconfigs). --deny-warnings is
    // load-bearing: oxlint exits 0 on warnings by default, so without it the
    // step never blocks. Extension glob over the whole tree so future
    // first-party TS is covered automatically; vendored mirrors and fixture/
    // reference snippets are deliberately broken or upstream's style.
    ["oxlint"] {
        batch = true
        glob = List("**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "**/*.mjs", "**/*.cjs", "**/*.mts", "**/*.cts")
        exclude = vendored_skills + List(
            "**/evals/fixtures/**",
            "skills/**/references/**",
            ".config/skills/**/references/**"
        )
        check = "oxlint --deny-warnings {{files}}"
    }

    // First-party Python lint + format (ruff via mise). Config passed with
    // --config so .hk-hooks/ruff.toml gates the repo without becoming the
    // user's global XDG ruff default. Extension glob over the whole tree so
    // future first-party Python is covered; vendored mirrors and fixture/
    // reference snippets are excluded (same set as oxlint).
    ["ruff-check"] {
        batch = true
        glob = List("**/*.py", "**/*.pyi")
        exclude = vendored_skills + List(
            "**/evals/fixtures/**",
            "skills/**/references/**",
            ".config/skills/**/references/**"
        )
        check = "ruff check --config .hk-hooks/ruff.toml {{files}}"
        fix = "ruff check --config .hk-hooks/ruff.toml --fix {{files}}"
    }

    // Runs after ruff-check so lint fixes (import sorting) land before the
    // formatter takes the final pass.
    ["ruff-format"] {
        batch = true
        depends = List("ruff-check")
        glob = List("**/*.py", "**/*.pyi")
        exclude = vendored_skills + List(
            "**/evals/fixtures/**",
            "skills/**/references/**",
            ".config/skills/**/references/**"
        )
        check = "ruff format --config .hk-hooks/ruff.toml --check {{files}}"
        fix = "ruff format --config .hk-hooks/ruff.toml {{files}}"
    }

    ["mise"] = Builtins.mise

    // Guard the tmux dimming patches against accidental removal. Vanilla tmux
    // builds fine without them, so dropping a patch from the flake overlay
    // silently loses inactive-pane dimming with no build error. Fire whenever
    // flake.nix or a patch file is staged, and assert both are still wired up.
    ["tmux-patches"] {
        glob = List(
            ".config/nix/flake.nix",
            ".config/nix/patches/dim-inactive-panes.patch",
            ".config/nix/patches/force-redraw-on-focus-change.patch"
        )
        check = "rg -q 'dim-inactive-panes.patch' .config/nix/flake.nix && rg -q 'force-redraw-on-focus-change.patch' .config/nix/flake.nix || { echo 'flake.nix no longer references both tmux dimming patches (see .config/nix/patches/README.md)' >&2; exit 1; }"
    }

    // Staging a patched vendored skill whose LOCAL PATCH was clobbered by a
    // refresh must fail; deleting the patch dir/vars entry in the same commit
    // is the deliberate-removal escape hatch.
    ["vendored-skill-patches"] {
        glob = List("**/vendor/.agents/skills/**", ".config/skills/vendor/patches/**")
        check = "zsh .config/zsh/functions/patch/skill-patch check"
    }

    ["codex-config-trust"] {
        glob = List(".codex/config.toml")
        check = "git show :{{files}} | rg -q '^\\[projects\\.' && { echo '.codex/config.toml contains staged machine-local [projects.*] trust state' >&2; exit 1; } || exit 0"
    }

    // Block local Claude profile aliases/state and auth override variables that
    // can be forced past .gitignore with `git add -f`. The guard permits the
    // tracked generic launcher implementation, but not concrete profile names.
    ["claude-profile-leak-guard"] {
        check = "python3 .hk-hooks/claude-profile-leak-guard.py"
    }

    // One policy value - the 4-day quarantine - is hand-spelled in nine config
    // files across four time units. The checker normalises each spelling to
    // days and fails the commit on disagreement; doc citations warn only.
    ["quarantine-drift"] {
        glob = List(
            ".npmrc",
            ".config/pnpm/config.yaml",
            ".config/pnpm/rc",
            ".bunfig.toml",
            ".config/uv/uv.toml",
            ".config/pip/pip.conf",
            ".yarnrc.yml",
            ".config/mise/config.toml",
            ".config/aube/config.toml",
            ".hk-hooks/quarantine-drift.py"
        )
        check = "python3 .hk-hooks/quarantine-drift.py"
    }

    // Static guard against self-collision in tmux.conf: a key bound twice in one
    // key-table (tmux keeps only the last, so the earlier bind is dead) or both
    // members of a terminal-alias pair (C-i=Tab etc.). Commit-time complement to
    // the edit-time tmux-freekeys advisor. Self-path in the glob so editing the
    // checker re-triggers it.
    ["tmux-bind-lint"] {
        glob = List(".config/tmux/tmux.conf", ".hk-hooks/tmux-bind-lint.py")
        check = "python3 .hk-hooks/tmux-bind-lint.py"
    }

    // Keep Claude and OpenCode security denies in lock-step (R6 drift guard).
    // Fires whenever a relevant config, the gh-api gate hook, or the checker
    // itself is staged. Runs from $HOME, so the checker's cwd-relative paths
    // resolve.
    ["permission-parity"] {
        glob = List(
            ".claude/settings.json",
            ".config/opencode/opencode.json",
            ".claude/hooks/guard-mutating-api.py",
            ".hk-hooks/permission-parity.py"
        )
        check = "python3 .hk-hooks/permission-parity.py"
    }

    // Keep every secret-path surface in lock-step with the srt denyRead list:
    // Claude Read/Edit deny rules, the shared _secretpaths.py hook core
    // (Claude + Codex), and the pi agent-guard TS twin, plus the hook wiring
    // itself. Fires whenever the canonical list, an embedding surface, or the
    // checker is staged.
    ["secret-path-parity"] {
        glob = List(
            ".config/srt/base.json",
            ".claude/settings.json",
            ".codex/hooks.json",
            ".claude/hooks/_secretpaths.py",
            ".claude/hooks/guard-secret-paths.py",
            ".claude/hooks/guard-secret-paths-codex.py",
            ".pi/agent/extensions/agent-guard/guard.ts",
            ".hk-hooks/secret-path-parity.py"
        )
        check = "python3 .hk-hooks/secret-path-parity.py"
    }

    // Authored agent skills must pass writing-skills' checker: spec errors
    // (invalid frontmatter, unknown keys, name/dir mismatch) block the commit;
    // hygiene findings (orphans, doc-rot phrasing, missing TOCs) print only.
    // Authored tiers only - vendored skills mirror upstream and aren't ours
    // to gate.
    ["skill-check"] {
        glob = List("skills/**", ".config/skills/personal/**")
        check = "bash .hk-hooks/skill-check.sh {{files}}"
    }

    // First-party TS typecheck gates (tsgo via mise): one glob-scoped step per
    // project so only staged-project changes pay the cost. Typecheck only -
    // tests live in `mise run ts-checks` to keep hook latency low. The shared
    // script warns + exits 0 when node_modules is absent (fresh/offline
    // machines), so the gate never bricks a commit it can't evaluate.
    ["ts-typecheck-skl"] {
        glob = List(".config/skl/src/**/*.ts", ".config/skl/tests/**/*.ts", ".config/skl/tsconfig.json")
        check = "bash .hk-hooks/ts-typecheck.sh .config/skl"
    }
    ["ts-typecheck-goal"] {
        glob = List(".pi/agent/extensions/goal/*.ts", ".pi/agent/extensions/goal/tsconfig.json")
        check = "bash .hk-hooks/ts-typecheck.sh .pi/agent/extensions/goal"
    }
    ["ts-typecheck-workflows"] {
        glob = List(".pi/agent/extensions/workflows/*.ts", ".pi/agent/extensions/workflows/tsconfig.json")
        check = "bash .hk-hooks/ts-typecheck.sh .pi/agent/extensions/workflows"
    }
    ["ts-typecheck-pi-palette"] {
        glob = List(".pi/agent/extensions/pi-palette/**/*.ts", ".pi/agent/extensions/pi-palette/tsconfig.json")
        check = "bash .hk-hooks/ts-typecheck.sh .pi/agent/extensions/pi-palette"
    }
    ["ts-typecheck-extensions"] {
        glob = List(
            ".pi/agent/extensions/atuin.ts",
            ".pi/agent/extensions/agent-state/**/*.ts",
            ".pi/agent/extensions/web-search/**/*.ts",
            ".pi/agent/extensions/web-search/**/*.mjs",
            ".pi/agent/extensions/tsconfig.json"
        )
        check = "bash .hk-hooks/ts-typecheck.sh .pi/agent/extensions"
    }

    // First-party Python typecheck gates (pyrefly via mise), scoped to the two
    // hook dirs that import no uninstalled third-party deps. One glob-scoped
    // step per dir so only staged-dir changes pay the cost; per-dir
    // pyrefly.toml makes each its own project so intra-package imports resolve.
    // Typecheck only - tests live in `mise run py-checks`. The shared script
    // warns + exits 0 when pyrefly is absent (fresh/offline machines), so the
    // gate never bricks a commit it can't evaluate. Mirrors ts-typecheck-*.
    ["py-typecheck-claude-hooks"] {
        glob = List(".claude/hooks/*.py", ".claude/hooks/pyrefly.toml")
        check = "bash .hk-hooks/py-typecheck.sh .claude/hooks"
    }
    ["py-typecheck-hk-hooks"] {
        glob = List(".hk-hooks/*.py", ".hk-hooks/pyrefly.toml")
        check = "bash .hk-hooks/py-typecheck.sh .hk-hooks"
    }

    // Secret scan: block staged secrets before they enter this public repo.
    // gitleaks reads the staged diff itself (`git --staged`), so no per-file
    // glob — the step runs once per commit. --redact keeps any match out of
    // the hook output. Backstops the /* deny-all against an `add -f` / stray
    // un-ignore; it is defence-in-depth, not the only guard.
    ["gitleaks"] {
        check = "gitleaks git --staged --no-banner --redact"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = fast_steps
    }

    ["fix"] {
        fix = true
        stash = "git"
        steps = fast_steps
    }

    ["check"] {
        steps = fast_steps
    }
}

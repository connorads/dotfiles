// Worked example: hk.pkl step graph for a TypeScript / React / Next project.
// Copy into a project's hk.pkl and trim for stacks that don't apply.
// See the `hk` skill for wiring (mise.toml, .hk-hooks/, prepare script).
amends "package://github.com/jdx/hk/releases/download/v1.36.0/hk@1.36.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.36.0/hk@1.36.0#/Builtins.pkl"

exclude = List("node_modules", "dist", ".next", ".open-next", "storybook-static")
display_skip_reasons = List()
terminal_progress = false

local binary_excludes = List(
    "*.png", "*.jpg", "*.jpeg", "*.gif", "*.webp", "*.ico",
    "*.woff", "*.woff2", "*.ttf", "*.eot", "*.pdf", "*.zip"
)

hooks {
    ["pre-commit"] {
        // fix = true + stash = git means: auto-fix, re-stage fixed files,
        // stash the rest, run the gates, unstash at the end.
        // Net effect: a single `git commit` succeeds with fixed content.
        fix = true
        stash = "git"

        steps {
            // --- Tier 1: formatting (auto-fixed and staged) ---
            ["trailing-whitespace"] = (Builtins.trailing_whitespace) {
                exclude = binary_excludes
            }
            ["newlines"] = (Builtins.newlines) {
                exclude = binary_excludes
            }
            ["rumdl"] = (Builtins.rumdl) {}
            ["typos"] = (Builtins.typos) {
                exclude = binary_excludes + List("pnpm-lock.yaml", "**/*.generated.*")
            }

            // --- Tier 2: lint / format JS-TS code ---
            // Biome (via Ultracite) owns formatting + general linting.
            ["biome"] {
                glob = List("*.ts", "*.tsx", "*.js", "*.jsx", "*.mjs", "*.cjs", "*.json", "*.css")
                check = "scripts/quiet-on-success.sh pnpm exec ultracite check --error-on-warnings=true {{files}}"
                fix = "scripts/quiet-on-success.sh pnpm exec ultracite fix {{files}}"
            }
            // oxlint (Rust) runs the boundary rules in-tree with no Node dep
            // graph: no-restricted-imports, no-restricted-syntax, jsx-a11y, and
            // a multi-file import/no-cycle (which retires madge). Configure deny
            // levels in .oxlintrc.json; gate on non-zero exit.
            ["oxlint"] {
                glob = List("*.ts", "*.tsx", "*.js", "*.jsx", "*.mjs", "*.cjs")
                check = "scripts/quiet-on-success.sh pnpm exec oxlint --max-warnings=0 {{files}}"
                fix = "scripts/quiet-on-success.sh pnpm exec oxlint --fix {{files}}"
            }
            // ESLint owns only what oxlint/Biome can't yet express: import-type-
            // aware boundary rules (allowTypeImports) and framework plugins
            // (plugin:next, plugin:storybook).
            ["eslint"] {
                glob = List("*.ts", "*.tsx", "*.js", "*.jsx", "*.mjs", "*.cjs")
                check = "scripts/quiet-on-success.sh pnpm exec eslint {{files}}"
                fix = "scripts/quiet-on-success.sh pnpm exec eslint --fix {{files}}"
            }

            // --- Tier 2: lint / format Python code ---
            // Ruff check runs before Ruff format so lint fixes can add/remove
            // imports and the formatter gets the final pass.
            // ["ruff-check"] {
            //     glob = List("*.py", "*.pyi")
            //     check = "scripts/quiet-on-success.sh uv run ruff check {{files}}"
            //     fix = "scripts/quiet-on-success.sh uv run ruff check --fix --show-fixes {{files}}"
            // }
            // ["ruff-format"] {
            //     glob = List("*.py", "*.pyi")
            //     check = "scripts/quiet-on-success.sh uv run ruff format --check {{files}}"
            //     fix = "scripts/quiet-on-success.sh uv run ruff format {{files}}"
            // }

            // --- Tier 2 cont.: validation gates (no auto-fix) ---
            ["yamllint"] = (Builtins.yamllint) {}
            ["check-merge-conflict"] = (Builtins.check_merge_conflict) {}
            ["gitleaks"] {
                check = "scripts/quiet-on-success.sh gitleaks detect --no-banner --redact --log-level=error"
            }

            // --- Tier 3: typecheck ---
            // Gate, not fix — a failing typecheck must block the commit.
            // `typecheck:fast` can run tsgo (TS 7 native, ~10x faster) as the
            // local gate; keep a `tsc --noEmit` (TS 6) job in CI as the
            // authoritative check until tsgo GA is verified on the project.
            ["typecheck"] {
                check = "scripts/quiet-on-success.sh pnpm typecheck:fast"
            }
            // Python typecheck gate. Keep basedpyright as the default blocking
            // check; add pinned `ty check` only as an advisory/secondary gate
            // while ty remains beta.
            // ["basedpyright"] {
            //     glob = List("*.py", "*.pyi")
            //     check = "scripts/quiet-on-success.sh uv run basedpyright"
            // }
            // ["ty"] {
            //     glob = List("*.py", "*.pyi")
            //     check = "scripts/quiet-on-success.sh uv run ty check"
            // }

            // --- Tier 4: tests ---
            // Enforce a coverage threshold via the test runner's config, not hk.
            // For vitest: set `coverage.thresholds = { 100: true }` (or whatever
            // threshold you want) and use `/* v8 ignore next */` for unreachable
            // defensive code.
            ["test-gate"] {
                check = "scripts/quiet-on-success.sh pnpm test:unit --coverage"
            }
            // Vulture needs whole-repo visibility. Enable only after baseline
            // cleanup and keep min_confidence=100 for commit gates.
            // ["vulture"] {
            //     check = "scripts/quiet-on-success.sh uv run vulture"
            // }
        }
    }

    // Commit message validation — conventional commits.
    ["commit-msg"] {
        steps {
            ["commitlint"] {
                check = "pnpm exec commitlint --edit {{commit_msg_file}}"
            }
        }
    }

    // Pre-push is a no-op: all gates run pre-commit so the push is already clean.
    // Keeps `git push` fast and keeps the enforcement surface in one place.
    ["pre-push"] {
        steps {
            ["noop"] {
                check = "true"
            }
        }
    }
}

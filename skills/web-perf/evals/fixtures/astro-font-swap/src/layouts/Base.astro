---
// Minimal static Astro head - font self-hosted from public/fonts via
// @font-face, no preload, no metric-matched fallback. The eval scenario:
// headings paint in the system fallback then "thicken" to the webfont on
// first load. Fully prerendered, so dist/*.html is the shipped bytes.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Font swap fixture</title>
    <style is:global>
      @font-face {
        font-family: "Display";
        font-weight: 700;
        font-display: swap;
        src: url(/fonts/display-700.woff2) format("woff2");
      }
      h1 {
        font-family: "Display", sans-serif;
        font-weight: 700;
        font-size: 3rem;
      }
    </style>
  </head>
  <body>
    <h1>Headline that flashes then thickens</h1>
    <slot />
  </body>
</html>
